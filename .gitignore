# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# local product image uploads (dev only; prod uses Vercel Blob)
public/uploads/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Local-only Neon URL notes (see docs/database-neon.md)
/docs/neon-credentials.local.md

# Local Cursor session notes (keep branch clean; not product docs)
/docs/cursor_session_rules_tariff.md
/docs/cursor_tariff_prompt_sequence.md

# Local unpacked document packs (optional drops; not tracked by default)
/docs/srm/pdf/
/docs/tariff/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
.env*.local
