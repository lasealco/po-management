{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run vercel-build",
  "crons": [
    {
      "path": "/api/cron/control-tower-sla-escalation",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/control-tower-fx-refresh",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/control-tower-report-schedules",
      "schedule": "5 * * * *"
    },
    {
      "path": "/api/cron/apihub-mapping-analysis-jobs",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/wms-outbound-webhook-retries",
      "schedule": "*/5 * * * *"
    }
  ]
}
