/// Immutable billing fact derived from ops (`InventoryMovement`); amount snapshot at materialization.
model WmsBillingEvent {
  id                  String                  @id @default(cuid())
  tenantId            String
  profileSource       WmsBillingProfileSource @default(MANUAL)
  /// When set, ties the charge to a 3PL owner (from linked outbound or future inbound rules).
  crmAccountId        String?
  inventoryMovementId String?                 @unique
  movementType        InventoryMovementType
  warehouseId         String
  productId           String
  quantity            Decimal                 @db.Decimal(14, 3)
  rateCode            String
  unitRate            Decimal                 @db.Decimal(14, 4)
  amount              Decimal                 @db.Decimal(14, 2)
  currency            String                  @default("USD") @db.VarChar(3)
  occurredAt          DateTime
  invoiceRunId        String?
  createdAt           DateTime                @default(now())

  tenant            Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse         Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product           Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  crmAccount        CrmAccount?           @relation(fields: [crmAccountId], references: [id], onDelete: SetNull)
  inventoryMovement InventoryMovement?    @relation(fields: [inventoryMovementId], references: [id], onDelete: SetNull)
  invoiceRun        WmsBillingInvoiceRun? @relation(fields: [invoiceRunId], references: [id], onDelete: SetNull)

  @@index([tenantId, occurredAt])
  @@index([tenantId, invoiceRunId])
  @@index([tenantId, crmAccountId])
}

model WmsBillingInvoiceRun {
  id            String                  @id @default(cuid())
  tenantId      String
  runNo         String
  profileSource WmsBillingProfileSource @default(MANUAL)
  periodFrom    DateTime
  periodTo      DateTime
  status        WmsBillingInvoiceStatus @default(DRAFT)
  totalAmount   Decimal                 @db.Decimal(14, 2)
  currency      String                  @default("USD") @db.VarChar(3)
  csvSnapshot   String?                 @db.Text
  createdById   String
  createdAt     DateTime                @default(now())

  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User                    @relation("WmsBillingInvoiceRunCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lines     WmsBillingInvoiceLine[]
  events    WmsBillingEvent[]

  @@unique([tenantId, runNo])
  @@index([tenantId, createdAt])
}

model WmsBillingInvoiceLine {
  id           String  @id @default(cuid())
