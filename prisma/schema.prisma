generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrgUnitKind {
  GROUP
  LEGAL_ENTITY
  REGION
  COUNTRY
  SITE
  OFFICE
}

/// Process / operating role of an org node (regional hub, plant, GBS) — not app RBAC; see `docs/organization-dimensions-and-delivery-phases.md`.
enum OrgUnitOperatingRole {
  REGIONAL_HQ
  GROUP_PROCUREMENT
  PLANT
  DIST_CENTER
  SALES_HUB
  SHARED_SERVICE
  R_AND_D
  CORPORATE_FUNCTION
  LOGISTICS_HUB
}

