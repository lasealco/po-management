  onHold      Boolean  @default(false)
  holdReason  String?  @db.VarChar(500)
  updatedAt   DateTime @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  bin       WarehouseBin @relation(fields: [binId], references: [id], onDelete: Cascade)
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, binId, productId])
  @@index([tenantId, warehouseId])
}

model InventoryMovement {
  id             String               @id @default(cuid())
  tenantId       String
  warehouseId    String
  binId          String?
  productId      String
  movementType   InventoryMovementType
  quantity       Decimal              @db.Decimal(14, 3)
  referenceType  String?
  referenceId    String?
  note           String?
  createdById    String
  createdAt      DateTime             @default(now())

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  bin       WarehouseBin? @relation(fields: [binId], references: [id], onDelete: SetNull)
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  wmsBillingEvent WmsBillingEvent?

  @@index([tenantId, warehouseId, createdAt])
  @@index([referenceType, referenceId])
}

enum WmsBillingProfileSource {
  MANUAL
  CRM_ACCOUNT
}

enum WmsBillingInvoiceStatus {
  DRAFT
  POSTED
}

/// Tenant-defined unit price per inventory movement type (Phase B billing foundation).
model WmsBillingRate {
  id             String   @id @default(cuid())
  tenantId       String
  code           String
  description    String?
  movementType   InventoryMovementType?
  amountPerUnit  Decimal  @db.Decimal(14, 4)
  currency       String   @default("USD") @db.VarChar(3)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

/// Immutable billing fact derived from ops (`InventoryMovement`); amount snapshot at materialization.
model WmsBillingEvent {
  id                  String                  @id @default(cuid())
  tenantId            String
  profileSource       WmsBillingProfileSource @default(MANUAL)
  /// When set, ties the charge to a 3PL owner (from linked outbound or future inbound rules).
  crmAccountId        String?
  inventoryMovementId String?               @unique
  movementType        InventoryMovementType
  warehouseId         String
  productId           String
  quantity            Decimal                 @db.Decimal(14, 3)
  rateCode            String
  unitRate            Decimal                 @db.Decimal(14, 4)
  amount              Decimal                 @db.Decimal(14, 2)
  currency            String                  @default("USD") @db.VarChar(3)
  occurredAt          DateTime
  invoiceRunId        String?
  createdAt           DateTime                @default(now())

  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse         Warehouse            @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product           Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
