  accountSnapshotJson   Json
  operationsSummaryJson Json
  riskSummaryJson       Json
  evidenceJson          Json
  redactionJson         Json
  replyDraft            String    @db.Text
  approvedReply         String?   @db.Text
  activityLogJson       Json?
  actionQueueItemId     String?
  approvedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  crmAccount CrmAccount @relation(fields: [crmAccountId], references: [id], onDelete: Cascade)
  creator    User?      @relation("AssistantCustomerBriefCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  approver   User?      @relation("AssistantCustomerBriefApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, crmAccountId, updatedAt])
  @@index([tenantId, status, updatedAt])
