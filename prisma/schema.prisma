// --- Logistics CRM (R1 core entities; tenant-scoped, aligned with docs/crm PDFs) ---

enum CrmLeadStatus {
  NEW
  WORKING
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}

enum CrmAccountType {
  CUSTOMER
  PROSPECT
  PARTNER
  AGENT
  OTHER
}

enum CrmAccountLifecycle {
  ACTIVE
  INACTIVE
}

enum CrmOpportunityStage {
  IDENTIFIED
  QUALIFIED
  DISCOVERY
  SOLUTION_DESIGN
  PROPOSAL_SUBMITTED
  NEGOTIATION
  VERBAL_AGREEMENT
  WON_IMPLEMENTATION_PENDING
  WON_LIVE
  LOST
  ON_HOLD
}

enum CrmActivityType {
  TASK
  CALL
  MEETING
  NOTE
  EMAIL
}

enum CrmQuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model CrmLead {
  id          String @id @default(cuid())
  tenantId    String
  ownerUserId String

  companyName          String
  contactFirstName     String?
  contactLastName      String?
  contactEmail         String?
  contactPhone         String?
  status               CrmLeadStatus @default(NEW)
  source               String        @default("MANUAL")
  serviceInterest      String?
  qualificationNotes   String?       @db.Text
  estimatedAnnualSpend Decimal?      @db.Decimal(14, 2)
  targetStartDate      DateTime?

  convertedAt        DateTime?
  convertedAccountId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner  User   @relation("CrmLeadOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, status])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, createdAt])
}

model CrmAccount {
  id          String @id @default(cuid())
  tenantId    String
  ownerUserId String

  name          String
  legalName     String?
  website       String?
  accountType   CrmAccountType      @default(PROSPECT)
  lifecycle     CrmAccountLifecycle @default(ACTIVE)
  industry      String?
  segment       String?
  strategicFlag Boolean             @default(false)

  parentAccountId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner    User         @relation("CrmAccountOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  parent   CrmAccount?  @relation("CrmAccountHierarchy", fields: [parentAccountId], references: [id], onDelete: SetNull)
  children CrmAccount[] @relation("CrmAccountHierarchy")

  contacts                 CrmContact[]
  opportunities            CrmOpportunity[]
  activities               CrmActivity[]            @relation("CrmActivityAccount")
  quotes                   CrmQuote[]
  outboundOrders           OutboundOrder[]
  wmsBillingEvents         WmsBillingEvent[]
  shipmentsAsCustomer      Shipment[]               @relation("ShipmentCustomerAccount")
  purchaseOrdersAsCustomer PurchaseOrder[]          @relation("PurchaseOrderCustomerCrm")
  salesOrders              SalesOrder[]
  assistantCustomerBriefs  AssistantCustomerBrief[]
  customerPortalUsers      User[]                   @relation("UserCustomerPortalScope")
  assistantEmailThreads    AssistantEmailThread[]

  @@index([tenantId, lifecycle])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, name])
}

model CrmContact {
  id          String @id @default(cuid())
  tenantId    String
  accountId   String
  ownerUserId String

  firstName    String
  lastName     String
  email        String?
  phone        String?
  title        String?
  department   String?
  decisionRole String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account    CrmAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  owner      User             @relation("CrmContactOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  primaryFor CrmOpportunity[] @relation("CrmOpportunityPrimaryContact")
  activities CrmActivity[]    @relation("CrmActivityContact")

  @@index([tenantId, accountId])
  @@index([tenantId, email])
}

model CrmOpportunity {
  id               String  @id @default(cuid())
  tenantId         String
  accountId        String
  ownerUserId      String
  primaryContactId String?

  name                String
  stage               CrmOpportunityStage @default(IDENTIFIED)
  probability         Int                 @default(10)
  forecastCategory    String?
  estimatedRevenue    Decimal?            @db.Decimal(14, 2)
  estimatedNetRevenue Decimal?            @db.Decimal(14, 2)
  currency            String?             @db.VarChar(3)
  closeDate           DateTime?
  nextStep            String?             @db.Text
  nextStepDate        DateTime?
  competitorName      String?
  lostReason          String?             @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account        CrmAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  owner          User          @relation("CrmOpportunityOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  primaryContact CrmContact?   @relation("CrmOpportunityPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)
  activities     CrmActivity[] @relation("CrmActivityOpportunity")
  quotes         CrmQuote[]

  @@index([tenantId, stage])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, accountId])
  @@index([tenantId, closeDate])
}

model CrmActivity {
  id          String @id @default(cuid())
  tenantId    String
  ownerUserId String

  type    CrmActivityType
  subject String
  body    String?         @db.Text
  status  String          @default("OPEN")

  dueDate   DateTime?
  startTime DateTime?
  endTime   DateTime?

  relatedAccountId     String?
  relatedContactId     String?
  relatedOpportunityId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner              User            @relation("CrmActivityOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  relatedAccount     CrmAccount?     @relation("CrmActivityAccount", fields: [relatedAccountId], references: [id], onDelete: SetNull)
  relatedContact     CrmContact?     @relation("CrmActivityContact", fields: [relatedContactId], references: [id], onDelete: SetNull)
  relatedOpportunity CrmOpportunity? @relation("CrmActivityOpportunity", fields: [relatedOpportunityId], references: [id], onDelete: SetNull)

  @@index([tenantId, ownerUserId])
  @@index([tenantId, dueDate])
  @@index([relatedAccountId])
  @@index([relatedOpportunityId])
}

model CrmQuote {
  id            String  @id @default(cuid())
  tenantId      String
  ownerUserId   String
  accountId     String
  opportunityId String?

  title       String
  status      CrmQuoteStatus @default(DRAFT)
  quoteNumber String?
  validUntil  DateTime?
  currency    String         @default("USD") @db.VarChar(3)
  notes       String?        @db.Text
  subtotal    Decimal?       @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User            @relation("CrmQuoteOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  account     CrmAccount      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  opportunity CrmOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  lines       CrmQuoteLine[]

  @@index([tenantId, accountId])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, status])
}

model CrmQuoteLine {
  id             String   @id @default(cuid())
  quoteId        String
  sortOrder      Int      @default(0)
  description    String
  quantity       Decimal  @db.Decimal(14, 4)
  unitPrice      Decimal  @db.Decimal(14, 4)
  extendedAmount Decimal? @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quote CrmQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

// --- Tariff engine (Phase 1): tables mapped to starter-pack names; tenant = existing Tenant ---

enum TariffProviderType {
  OCEAN_CARRIER
  NVOCC
  FORWARDER
  AIRLINE
  TRUCKER
  RAIL_OPERATOR
  WAREHOUSE
  BROKER
  COURIER
  OTHER
}

/// Distinct from logistics `TransportMode` on Shipment — tariff contract / charge scope.
enum TariffTransportMode {
  OCEAN
  LCL
  AIR
  TRUCK
  RAIL
  LOCAL_SERVICE
}

enum TariffContractStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  EXPIRED
  SUPERSEDED
  ARCHIVED
}

enum TariffSourceType {
  MANUAL
  EXCEL
  PDF
  API
  EDI
  EMAIL
  SYSTEM
}

enum TariffApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum QuoteRequestStatus {
  DRAFT
  OPEN
  CLOSED
  AWARDED
  CANCELLED
}

enum QuoteRecipientInvitationStatus {
  PENDING
  INVITED
  DECLINED
  RESPONDED
}

enum QuoteResponseStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  AWARDED
  REJECTED
  WITHDRAWN
}

enum QuoteClarificationVisibility {
  INTERNAL
  RECIPIENTS
}

enum PricingSnapshotSourceType {
  TARIFF_CONTRACT_VERSION
  QUOTE_RESPONSE
  /// Sum of multiple contract versions (e.g. forwarder + pre-carriage + ocean); see breakdownJson.components.
  COMPOSITE_CONTRACT_VERSION
}

enum TariffGeographyType {
  GLOBAL_REGION
  SUBREGION
  COUNTRY
  PORT
  INLAND_POINT
  RAIL_RAMP
  ZONE
  ALIAS_GROUP
}

enum TariffLineRateType {
  BASE_RATE
  ALL_IN
  GATE_IN
  GATE_IN_ALL_IN
  GATE_IN_GATE_OUT
  ADD_ON
  LOCAL_CHARGE
  SURCHARGE
  CUSTOMS
  PRE_CARRIAGE
  ON_CARRIAGE
}

enum TariffChargeFamily {
  MAIN_CARRIAGE
  FUEL_ENVIRONMENTAL
  SEASONAL_EMERGENCY
  ORIGIN_TERMINAL
  DEST_TERMINAL
  ORIGIN_INLAND
  DEST_INLAND
  CUSTOMS_REGULATORY
  HANDLING_SPECIAL
  FREE_TIME_DELAY
  ADMIN_OTHER
}

enum TariffRuleType {
  DEMURRAGE
  DETENTION
  COMBINED_DD
  STORAGE
  PLUGIN
  OTHER
}

model TariffLegalEntity {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  code         String?
  countryCode  String?  @db.VarChar(2)
  baseCurrency String?  @db.VarChar(3)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractHeaders TariffContractHeader[]
  importBatches   TariffImportBatch[]

  @@index([tenantId])
  @@map("legal_entities")
}

model TariffProvider {
  id           String             @id @default(cuid())
  legalName    String
  tradingName  String?
  providerType TariffProviderType
  countryCode  String?            @db.VarChar(2)
  status       String             @default("ACTIVE")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  chargeAliases   TariffChargeAlias[]
  contractHeaders TariffContractHeader[]

  @@map("providers")
}

model TariffGeographyGroup {
  id            String              @id @default(cuid())
  geographyType TariffGeographyType
  name          String
  code          String?
  aliasSource   String?
  validFrom     DateTime?           @db.Date
  validTo       DateTime?           @db.Date
  active        Boolean             @default(true)
  createdAt     DateTime            @default(now())

  members                TariffGeographyMember[]
  rateLinesAsOrigin      TariffRateLine[]        @relation("TariffRateLineOrigin")
  rateLinesAsDestination TariffRateLine[]        @relation("TariffRateLineDestination")
  chargeLines            TariffChargeLine[]
  freeTimeRules          TariffFreeTimeRule[]

  @@map("geography_groups")
}

model TariffGeographyMember {
  id               String              @id @default(cuid())
  geographyGroupId String
  memberCode       String
  memberName       String?
  memberType       TariffGeographyType
  validFrom        DateTime?           @db.Date
  validTo          DateTime?           @db.Date

  geographyGroup TariffGeographyGroup @relation(fields: [geographyGroupId], references: [id], onDelete: Cascade)

  @@index([geographyGroupId])
  @@map("geography_members")
}

model TariffNormalizedChargeCode {
  id            String               @id @default(cuid())
  code          String               @unique
  displayName   String
  chargeFamily  TariffChargeFamily
  transportMode TariffTransportMode?
  isLocalCharge Boolean              @default(false)
  isSurcharge   Boolean              @default(false)
  active        Boolean              @default(true)
  createdAt     DateTime             @default(now())

  aliases     TariffChargeAlias[]
  chargeLines TariffChargeLine[]

  @@map("normalized_charge_codes")
}

model TariffChargeAlias {
  id                     String  @id @default(cuid())
  normalizedChargeCodeId String
  aliasText              String
  providerId             String?
  notes                  String? @db.Text

  normalizedChargeCode TariffNormalizedChargeCode @relation(fields: [normalizedChargeCodeId], references: [id], onDelete: Cascade)
  provider             TariffProvider?            @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([normalizedChargeCodeId])
  @@index([providerId])
  @@map("charge_aliases")
}

model TariffContractHeader {
  id             String               @id @default(cuid())
  tenantId       String
  legalEntityId  String?
  providerId     String
  transportMode  TariffTransportMode
  contractNumber String?
  title          String
  tradeScope     String?              @db.Text
  status         TariffContractStatus @default(DRAFT)
  ownerUserId    String?
  notes          String?              @db.Text
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalEntity TariffLegalEntity?      @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  provider    TariffProvider          @relation(fields: [providerId], references: [id], onDelete: Restrict)
  owner       User?                   @relation("TariffContractHeaderOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  versions    TariffContractVersion[]

  @@index([tenantId])
  @@index([providerId])
  @@map("contract_headers")
}

model TariffContractVersion {
  id                   String               @id @default(cuid())
  contractHeaderId     String
  versionNo            Int
  sourceType           TariffSourceType
  sourceReference      String?
  sourceFileUrl        String?
  approvalStatus       TariffApprovalStatus @default(PENDING)
  status               TariffContractStatus @default(DRAFT)
  validFrom            DateTime?            @db.Date
  validTo              DateTime?            @db.Date
  bookingDateValidFrom DateTime?            @db.Date
  bookingDateValidTo   DateTime?            @db.Date
  sailingDateValidFrom DateTime?            @db.Date
  sailingDateValidTo   DateTime?            @db.Date
  comments             String?              @db.Text
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  contractHeader       TariffContractHeader        @relation(fields: [contractHeaderId], references: [id], onDelete: Cascade)
  rateLines            TariffRateLine[]
  chargeLines          TariffChargeLine[]
  freeTimeRules        TariffFreeTimeRule[]
  shipmentApplications TariffShipmentApplication[]

  @@unique([contractHeaderId, versionNo])
  @@index([contractHeaderId])
  @@index([validFrom, validTo])
  @@map("contract_versions")
}

model TariffRateLine {
  id                 String             @id @default(cuid())
  contractVersionId  String
  originScopeId      String?
  destinationScopeId String?
  rateType           TariffLineRateType
  equipmentType      String?
  commodityScope     String?            @db.Text
  serviceScope       String?            @db.Text
  unitBasis          String
  currency           String             @db.VarChar(3)
  amount             Decimal            @db.Decimal(18, 4)
  includedChargeSet  Json?
  excludedChargeSet  Json?
  rawRateDescription String?            @db.Text
  validFrom          DateTime?          @db.Date
  validTo            DateTime?          @db.Date
  notes              String?            @db.Text

  contractVersion  TariffContractVersion @relation(fields: [contractVersionId], references: [id], onDelete: Cascade)
  originScope      TariffGeographyGroup? @relation("TariffRateLineOrigin", fields: [originScopeId], references: [id], onDelete: SetNull)
  destinationScope TariffGeographyGroup? @relation("TariffRateLineDestination", fields: [destinationScopeId], references: [id], onDelete: SetNull)

  @@index([contractVersionId])
  @@map("rate_lines")
}

model TariffChargeLine {
  id                     String    @id @default(cuid())
  contractVersionId      String
  normalizedChargeCodeId String?
  rawChargeName          String
  geographyScopeId       String?
  directionScope         String?
  equipmentScope         String?
  conditionScope         String?
  unitBasis              String
  currency               String    @db.VarChar(3)
  amount                 Decimal   @db.Decimal(18, 4)
  isIncluded             Boolean   @default(false)
  isMandatory            Boolean   @default(true)
  validFrom              DateTime? @db.Date
  validTo                DateTime? @db.Date
  notes                  String?   @db.Text

  contractVersion      TariffContractVersion       @relation(fields: [contractVersionId], references: [id], onDelete: Cascade)
  normalizedChargeCode TariffNormalizedChargeCode? @relation(fields: [normalizedChargeCodeId], references: [id], onDelete: SetNull)
  geographyScope       TariffGeographyGroup?       @relation(fields: [geographyScopeId], references: [id], onDelete: SetNull)

  @@index([contractVersionId])
  @@map("charge_lines")
}

model TariffFreeTimeRule {
  id                String         @id @default(cuid())
  contractVersionId String
  geographyScopeId  String?
  importExportScope String?
  equipmentScope    String?
  ruleType          TariffRuleType
  freeDays          Int
  validFrom         DateTime?      @db.Date
  validTo           DateTime?      @db.Date
  notes             String?        @db.Text

  contractVersion TariffContractVersion @relation(fields: [contractVersionId], references: [id], onDelete: Cascade)
  geographyScope  TariffGeographyGroup? @relation(fields: [geographyScopeId], references: [id], onDelete: SetNull)

  @@index([contractVersionId])
  @@map("free_time_rules")
}

model TariffImportBatch {
  id               String           @id @default(cuid())
  tenantId         String?
  legalEntityId    String?
  sourceType       TariffSourceType
  uploadedFilename String?
  sourceReference  String?
  /**
   * Stored file URL (Vercel Blob or dev /uploads/tariffs/...).
   */
  sourceFileUrl    String?          @db.Text
  sourceMimeType   String?
  sourceByteSize   Int?
  /**
   * Original client metadata: checksum, headers, uploader id, etc.
   */
  sourceMetadata   Json?
  parseStatus      String           @default("UPLOADED")
  confidenceScore  Decimal?         @db.Decimal(5, 2)
  reviewStatus     String           @default("PENDING")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant      Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  legalEntity TariffLegalEntity?       @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  stagingRows TariffImportStagingRow[]

  @@index([tenantId])
  @@map("import_batches")
}

model TariffImportStagingRow {
  id                String   @id @default(cuid())
  importBatchId     String
  rowType           String
  rawPayload        Json
  normalizedPayload Json?
  confidenceScore   Decimal? @db.Decimal(5, 2)
  unresolvedFlags   Json?
  approved          Boolean  @default(false)
  createdAt         DateTime @default(now())

  importBatch TariffImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([importBatchId])
  @@map("import_staging_rows")
}

model TariffApprovalRecord {
  id             String               @id @default(cuid())
  objectType     String
  objectId       String
  stepName       String?
  approverUserId String?
  decision       TariffApprovalStatus
  decisionNote   String?              @db.Text
  decidedAt      DateTime             @default(now())

  approver User? @relation("TariffApprovalApprover", fields: [approverUserId], references: [id], onDelete: SetNull)

  @@index([objectType, objectId])
  @@map("approval_records")
}

model TariffAuditLog {
  id         String   @id @default(cuid())
  objectType String
  objectId   String
  action     String
  userId     String?
  oldValue   Json?
  newValue   Json?
  createdAt  DateTime @default(now())

  user User? @relation("TariffAuditLogActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([objectType, objectId])
  @@map("audit_logs")
}

/// Links a logistics shipment to the tariff contract version used for quoting / audit (product glue).
model TariffShipmentApplication {
  id                String   @id @default(cuid())
  tenantId          String
  shipmentId        String
  contractVersionId String
  isPrimary         Boolean  @default(true)
  /// MANUAL | RATING_ENGINE | SNAPSHOT
  source            String   @default("MANUAL")
  polCode           String?  @db.VarChar(16)
  podCode           String?  @db.VarChar(16)
  equipmentType     String?  @db.VarChar(32)
  appliedNotes      String?  @db.Text
  createdById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment        Shipment              @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  contractVersion TariffContractVersion @relation(fields: [contractVersionId], references: [id], onDelete: Restrict)
  createdBy       User?                 @relation("TariffShipmentApplicationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([shipmentId, contractVersionId])
  @@index([tenantId, shipmentId])
  @@index([contractVersionId])
  @@map("tariff_shipment_applications")
}

/// Buyer-initiated ad hoc ocean (or other mode) procurement request.
model QuoteRequest {
  id               String              @id @default(cuid())
  tenantId         String
  title            String
  description      String?             @db.Text
  status           QuoteRequestStatus  @default(DRAFT)
  transportMode    TariffTransportMode @default(OCEAN)
  originLabel      String              @db.Text
  destinationLabel String              @db.Text
  equipmentSummary String?
  cargoDescription String?             @db.Text
  quotesDueAt      DateTime?
  ownerUserId      String?
  /// Reserved for future broadcast automation (email / portal).
  lastBroadcastAt  DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  tenant                         Tenant                          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner                          User?                           @relation("QuoteRequestOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  recipients                     QuoteRequestRecipient[]
  responses                      QuoteResponse[]
  clarifications                 QuoteClarificationMessage[]
  transportationProcurementPlans TransportationProcurementPlan[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("quote_requests")
}

model QuoteRequestRecipient {
  id                 String                         @id @default(cuid())
  quoteRequestId     String
  supplierId         String?
  displayName        String
  contactEmail       String?                        @db.VarChar(320)
  invitationStatus   QuoteRecipientInvitationStatus @default(PENDING)
  invitedAt          DateTime?
  respondedAt        DateTime?
  /// Future outbound integration: template id, message id, last error, etc.
  lastInviteMetadata Json?
  createdAt          DateTime                       @default(now())

  quoteRequest   QuoteRequest                @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  supplier       Supplier?                   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  response       QuoteResponse?
  clarifications QuoteClarificationMessage[]

  @@index([quoteRequestId])
  @@index([supplierId])
  @@map("quote_request_recipients")
}

model QuoteResponse {
  id                  String              @id @default(cuid())
  quoteRequestId      String
  recipientId         String              @unique
  status              QuoteResponseStatus @default(DRAFT)
  currency            String              @default("USD") @db.VarChar(3)
  totalAllInAmount    Decimal?            @db.Decimal(18, 4)
  validityFrom        DateTime?           @db.Date
  validityTo          DateTime?           @db.Date
  includedChargesJson Json?
  excludedChargesJson Json?
  freeTimeSummaryJson Json?
  reviewNotes         String?             @db.Text
  submittedAt         DateTime?
  reviewedAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  quoteRequest   QuoteRequest                @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  recipient      QuoteRequestRecipient       @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  lines          QuoteResponseLine[]
  clarifications QuoteClarificationMessage[]

  @@index([quoteRequestId])
  @@map("quote_responses")
}

model QuoteResponseLine {
  id              String   @id @default(cuid())
  quoteResponseId String
  sortOrder       Int      @default(0)
  lineType        String
  label           String
  amount          Decimal? @db.Decimal(18, 4)
  currency        String   @default("USD") @db.VarChar(3)
  unitBasis       String?
  isIncluded      Boolean  @default(true)
  notes           String?  @db.Text

  quoteResponse QuoteResponse @relation(fields: [quoteResponseId], references: [id], onDelete: Cascade)

  @@index([quoteResponseId])
  @@map("quote_response_lines")
}

model QuoteClarificationMessage {
  id              String                       @id @default(cuid())
  quoteRequestId  String
  recipientId     String?
  quoteResponseId String?
  authorUserId    String?
  body            String                       @db.Text
  visibility      QuoteClarificationVisibility @default(INTERNAL)
  /// Future email drafts: { "subject", "to": [] } — not sent by the app yet.
  metadata        Json?
  createdAt       DateTime                     @default(now())

  quoteRequest  QuoteRequest           @relation(fields: [quoteRequestId], references: [id], onDelete: Cascade)
  recipient     QuoteRequestRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  quoteResponse QuoteResponse?         @relation(fields: [quoteResponseId], references: [id], onDelete: SetNull)
  author        User?                  @relation("QuoteClarificationAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([quoteRequestId])
  @@map("quote_clarification_messages")
}

/// AMP16: governed transportation procurement recommendation linking RFQ, snapshots, execution, and invoice feedback.
model TransportationProcurementPlan {
  id                    String    @id @default(cuid())
  tenantId              String
  createdByUserId       String?
  quoteRequestId        String?
  title                 String
  status                String    @default("DRAFT") @db.VarChar(32)
  recommendedCarrier    String?   @db.VarChar(256)
  recommendedSupplierId String?
  recommendedResponseId String?
  recommendedSnapshotId String?
  allocationScore       Int       @default(0)
  carrierScorecardJson  Json
  rfqEvidenceJson       Json
  snapshotEvidenceJson  Json
  invoiceFeedbackJson   Json
  allocationPlanJson    Json
  tenderDraftJson       Json
  actionQueueItemId     String?
  approvedAt            DateTime?
  approvalNote          String?   @db.Text
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator      User?         @relation("TransportationProcurementPlanCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  quoteRequest QuoteRequest? @relation(fields: [quoteRequestId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, updatedAt])
  @@index([tenantId, quoteRequestId])
  @@map("transportation_procurement_plans")
}

/// Immutable capture of estimated booking economics at a point in time (contract or RFQ basis).
/// Rows are never updated when underlying tariffs/quotes change — create a new snapshot instead.
model BookingPricingSnapshot {
  id                 String                    @id @default(cuid())
  tenantId           String
  shipmentBookingId  String?
  sourceType         PricingSnapshotSourceType
  /// Contract version id or quote response id (matches sourceType).
  sourceRecordId     String
  sourceSummary      String?                   @db.Text
  currency           String                    @db.VarChar(3)
  totalEstimatedCost Decimal                   @db.Decimal(18, 4)
  breakdownJson      Json
  freeTimeBasisJson  Json
  /// Documents how totalEstimatedCost was derived (MVP: sum of rate + charge amounts).
  totalDerivation    String                    @default("SUM_RATE_AND_CHARGE_AMOUNTS")
  frozenAt           DateTime                  @default(now())
  createdByUserId    String?
  /// Reserved for buy/sell split, margin, counterparty totals, etc.
  commercialJson     Json?
  /// Reserved e.g. BUY | SELL when dual-basis UI exists.
  basisSide          String?                   @db.VarChar(16)
  /// Commercial term label (FOB, EXW, DDP, …) captured at freeze; drives which legs you include in practice.
  incoterm           String?                   @db.VarChar(16)

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipmentBooking     ShipmentBooking?     @relation(fields: [shipmentBookingId], references: [id], onDelete: SetNull)
  creator             User?                @relation("BookingPricingSnapshotCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  invoiceIntakes      InvoiceIntake[]
  invoiceAuditResults InvoiceAuditResult[]

  @@index([tenantId])
  @@index([tenantId, frozenAt])
  @@index([shipmentBookingId])
  @@index([sourceType, sourceRecordId])
  @@map("booking_pricing_snapshots")
}

enum InvoiceIntakeStatus {
  DRAFT
  RECEIVED
  PARSED
  AUDITED
  FAILED
}

enum InvoiceAuditRollupOutcome {
  NONE
  PENDING
  PASS
  WARN
  FAIL
}

enum InvoiceAuditLineOutcome {
  GREEN
  AMBER
  RED
  UNKNOWN
}

enum InvoiceReviewDecision {
  NONE
  APPROVED
  OVERRIDDEN
}

/// Tenant-scoped tolerance defaults for invoice vs snapshot amount comparison.
model InvoiceToleranceRule {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  priority           Int      @default(0)
  active             Boolean  @default(true)
  /// Absolute amount difference allowed (same currency as invoice line).
  amountAbsTolerance Decimal? @db.Decimal(18, 4)
  /// Relative tolerance as ratio, e.g. 0.01 = 1%.
  percentTolerance   Decimal? @db.Decimal(9, 6)
  /// When set, rule applies only to intakes in this currency (ISO 4217).
  currencyScope      String?  @db.VarChar(3)
  /// Optional JSON list of discrepancy category keys this rule optimizes for (MVP: unused).
  categoryScope      Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditResults InvoiceAuditResult[]

  @@index([tenantId, active, priority])
  @@map("tolerance_rules")
}

/// Carrier / forwarder invoice uploaded or keyed in for audit against a frozen pricing snapshot.
model InvoiceIntake {
  id                         String                    @id @default(cuid())
  tenantId                   String
  status                     InvoiceIntakeStatus       @default(RECEIVED)
  bookingPricingSnapshotId   String
  externalInvoiceNo          String?                   @db.VarChar(128)
  vendorLabel                String?                   @db.VarChar(256)
  invoiceDate                DateTime?                 @db.Date
  currency                   String                    @default("USD") @db.VarChar(3)
  /// Optional port of loading (UN/LOCODE or 5-letter) for geography-aware matching.
  polCode                    String?                   @db.VarChar(8)
  /// Optional port of discharge for geography-aware matching.
  podCode                    String?                   @db.VarChar(8)
  rawSourceNotes             String?                   @db.Text
  /// Parser or importer hard failure — surfaced to UI (no silent failures).
  parseError                 String?                   @db.Text
  parseWarnings              Json?
  /// Last audit engine failure (distinct from line-level RED outcomes).
  auditRunError              String?                   @db.Text
  lastAuditAt                DateTime?
  rollupOutcome              InvoiceAuditRollupOutcome @default(NONE)
  greenLineCount             Int                       @default(0)
  amberLineCount             Int                       @default(0)
  redLineCount               Int                       @default(0)
  unknownLineCount           Int                       @default(0)
  reviewDecision             InvoiceReviewDecision     @default(NONE)
  reviewNote                 String?                   @db.Text
  reviewedByUserId           String?
  reviewedAt                 DateTime?
  /// When true, finance has cleared this audited intake for downstream accounting / export (separate from APPROVED/OVERRIDDEN review).
  approvedForAccounting      Boolean                   @default(false)
  accountingApprovedAt       DateTime?
  accountingApprovedByUserId String?
  accountingApprovalNote     String?                   @db.Text
  /// AMP5: durable finance packet linking invoice audit, frozen pricing snapshot, dispute note, and accounting handoff.
  financeHandoffStatus       String                    @default("DRAFT") @db.VarChar(32)
  financeHandoffSummary      String?                   @db.Text
  disputeDraft               String?                   @db.Text
  accountingPacketJson       Json?
  financeHandoffUpdatedAt    DateTime?
  createdByUserId            String?
  receivedAt                 DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt

  tenant                 Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookingPricingSnapshot BookingPricingSnapshot @relation(fields: [bookingPricingSnapshotId], references: [id], onDelete: Restrict)
  reviewer               User?                  @relation("InvoiceIntakeReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  accountingApprover     User?                  @relation("InvoiceIntakeAccountingApprover", fields: [accountingApprovedByUserId], references: [id], onDelete: SetNull)
  creator                User?                  @relation("InvoiceIntakeCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines                  InvoiceLine[]
  auditResults           InvoiceAuditResult[]

  @@index([tenantId])
  @@index([tenantId, receivedAt])
  @@index([tenantId, financeHandoffStatus, updatedAt])
  @@index([bookingPricingSnapshotId])
  @@map("invoice_intakes")
}

/// Parsed charge lines from the supplier invoice.
model InvoiceLine {
  id                  String   @id @default(cuid())
  invoiceIntakeId     String
  lineNo              Int
  rawDescription      String   @db.Text
  normalizedLabel     String?  @db.VarChar(512)
  currency            String   @db.VarChar(3)
  amount              Decimal  @db.Decimal(18, 4)
  unitBasis           String?  @db.VarChar(64)
  quantity            Decimal? @db.Decimal(18, 6)
  /// e.g. 40HC, 20DV — improves rate-line matching.
  equipmentType       String?  @db.VarChar(32)
  /// ALL_IN = compare to snapshot basket / RFQ total; ITEMIZED = per-line; null = auto-detect from description.
  chargeStructureHint String?  @db.VarChar(24)
  sourceRowJson       Json?
  parseConfidence     String?  @db.VarChar(32)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  intake      InvoiceIntake       @relation(fields: [invoiceIntakeId], references: [id], onDelete: Cascade)
  auditResult InvoiceAuditResult?

  @@unique([invoiceIntakeId, lineNo])
  @@index([invoiceIntakeId])
  @@map("invoice_lines")
}

/// Tenant dictionary: invoice text patterns → canonical tokens for better snapshot line matching.
model InvoiceChargeAlias {
  id              String   @id @default(cuid())
  tenantId        String
  name            String?  @db.Text
  /// Normalized substring match on invoice description (lowercase storage recommended).
  pattern         String   @db.Text
  /// JSON string array of tokens that strongly associate with a snapshot charge/rate label.
  canonicalTokens Json
  /// When set, only boost candidates of this kind (CONTRACT_RATE | CONTRACT_CHARGE | RFQ_LINE).
  targetKind      String?  @db.VarChar(24)
  priority        Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, active, priority])
  @@map("invoice_charge_aliases")
}

/// Per invoice-line match against a booking pricing snapshot (immutable audit trail).
model InvoiceAuditResult {
  id                       String                  @id @default(cuid())
  invoiceIntakeId          String
  invoiceLineId            String                  @unique
  bookingPricingSnapshotId String
  toleranceRuleId          String?
  outcome                  InvoiceAuditLineOutcome
  discrepancyCategories    Json
  expectedAmount           Decimal?                @db.Decimal(18, 4)
  amountVariance           Decimal?                @db.Decimal(18, 4)
  percentVariance          Decimal?                @db.Decimal(9, 6)
  snapshotMatchedJson      Json?
  explanation              String                  @db.Text
  createdAt                DateTime                @default(now())

  intake        InvoiceIntake          @relation(fields: [invoiceIntakeId], references: [id], onDelete: Cascade)
  line          InvoiceLine            @relation(fields: [invoiceLineId], references: [id], onDelete: Cascade)
  snapshot      BookingPricingSnapshot @relation(fields: [bookingPricingSnapshotId], references: [id], onDelete: Restrict)
  toleranceRule InvoiceToleranceRule?  @relation(fields: [toleranceRuleId], references: [id], onDelete: SetNull)

  @@index([invoiceIntakeId])
  @@index([bookingPricingSnapshotId])
  @@map("audit_results")
}

// ---------------------------------------------------------------------------
// Global reference catalogs (not tenant-scoped): ISO countries, SCAC ocean
// carriers, IATA airlines + AWB prefixes. Seeded from public datasets; edit
// under Settings → Reference data. Downstream modules should gradually FK or
// validate against these instead of unconstrained free text.
// ---------------------------------------------------------------------------

/// ISO 3166-1 country/territory (alpha-2 + alpha-3 + common English name).
model ReferenceCountry {
  id         String   @id @default(cuid())
  isoAlpha2  String   @unique @db.VarChar(2)
  isoAlpha3  String   @unique @db.VarChar(3)
  name       String
  /// Optional macro-region for tariffs / lanes (e.g. EU, NA, APAC, LATAM, MEA, OCE).
  regionCode String?  @db.VarChar(16)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([regionCode, isActive])
  @@map("reference_countries")
}

/// Ocean mainline / VOCC identifiers (SCAC-style codes used in contracts and EDI).
model ReferenceOceanCarrier {
  id        String   @id @default(cuid())
  /// Standard Carrier Alpha Code or equivalent 2–4 letter code.
  scac      String   @unique @db.VarChar(4)
  name      String
  notes     String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reference_ocean_carriers")
}

/// Passenger / cargo airline (IATA designator + optional ICAO + AWB prefix).
model ReferenceAirline {
  id         String   @id @default(cuid())
  /// IATA airline designator (usually 2 letters; 3 chars allowed for edge cases).
  iataCode   String   @unique @db.VarChar(3)
  /// ICAO airline designator (3 letters), when known.
  icaoCode   String?  @unique @db.VarChar(3)
  /// IATA three-digit AWB accounting prefix (Resolution 670).
  awbPrefix3 String   @db.VarChar(3)
  name       String
  notes      String?  @db.Text
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([awbPrefix3])
  @@map("reference_airlines")
}

/// Twin risk / alert severity (PRD-aligned vocabulary; extend with care).
enum TwinRiskSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Tenant-scoped risk or alert signal row (minimal slice-22 foundation).
model SupplyChainTwinRiskSignal {
  id                    String           @id @default(cuid())
  tenantId              String
  /// Stable code for upserts and routing (e.g. `DEMO-SCTWIN-SEED-RISK`).
  code                  String
  severity              TwinRiskSeverity
  title                 String
  detail                String?
  acknowledged          Boolean          @default(false)
  acknowledgedAt        DateTime?
  acknowledgedByActorId String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, severity])
  /// Slice 66: keyset list (`listRiskSignalsForTenantPage` — `createdAt` desc, `id` desc).
  @@index([tenantId, createdAt])
}

/// AMP10: assistant-authored twin insight linking graph confidence, scenarios, risks, and human work.
model SupplyChainTwinAssistantInsight {
  id                        String   @id @default(cuid())
  tenantId                  String
  createdByUserId           String?
  prompt                    String   @db.Text
  summary                   String   @db.Text
  graphConfidenceScore      Int      @default(0)
  scenarioDraftId           String?
  riskSignalId              String?
  actionQueueItemId         String?
  assistantEvidenceRecordId String?
  status                    String   @default("OPEN") @db.VarChar(32)
  evidenceJson              Json
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User?  @relation("SupplyChainTwinAssistantInsightCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, scenarioDraftId])
  @@index([tenantId, riskSignalId])
}

/// Tenant-scoped Supply Chain Twin entity node (materialized snapshot + JSON payload).
model SupplyChainTwinEntitySnapshot {
  id         String   @id @default(cuid())
  tenantId   String
  /// Twin graph discriminator (see `TwinEntityKind` in app types).
  entityKind String
  /// Stable business key for this node within the tenant (upstream id, composite key, etc.).
  entityKey  String
  /// Additional attributes, provenance, or denormalized fields for the twin.
  payload    Json     @default("{}")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant        Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outgoingEdges SupplyChainTwinEntityEdge[] @relation("TwinEntityEdgeFrom")
  incomingEdges SupplyChainTwinEntityEdge[] @relation("TwinEntityEdgeTo")

  @@unique([tenantId, entityKind, entityKey])
  @@index([tenantId])
  @@index([tenantId, entityKind])
  /// Slice 66: keyset / newest-first catalog list (`listForTenantPage` — `updatedAt` desc, `id` desc).
  @@index([tenantId, updatedAt])
}

/// Directed edge between two twin entity snapshots (same tenant).
model SupplyChainTwinEntityEdge {
  id             String   @id @default(cuid())
  tenantId       String
  fromSnapshotId String
  toSnapshotId   String
  /// Optional semantic label (e.g. fulfills, ships_to).
  relation       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromSnapshot SupplyChainTwinEntitySnapshot @relation("TwinEntityEdgeFrom", fields: [fromSnapshotId], references: [id], onDelete: Cascade)
  toSnapshot   SupplyChainTwinEntitySnapshot @relation("TwinEntityEdgeTo", fields: [toSnapshotId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, fromSnapshotId])
  @@index([tenantId, toSnapshotId])
}

/// Append-only “twin saw X” ingestion spine (no background worker in this slice).
/// **Payload policy:** max serialized JSON byte length must be enforced in the writer slice (reject oversize before insert).
model SupplyChainTwinIngestEvent {
  id             String   @id @default(cuid())
  tenantId       String
  /// Event discriminator (e.g. `entity_upsert`, `edge_upsert`, `signal`) — vocabulary owned by writers.
  type           String
  /// JSON body; keep small — hard cap enforced in application code, not in the database.
  payloadJson    Json     @default("{}")
  /// When set (via `Idempotency-Key` on POST), duplicate appends for the same tenant return the first row (no second insert).
  idempotencyKey String?
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, createdAt, type])
  @@index([tenantId, type, createdAt])
}

/// Tenant-scoped what-if scenario draft (JSON only; no solver in Slice 24).
model SupplyChainTwinScenarioDraft {
  id        String   @id @default(cuid())
  tenantId  String
  title     String?
  /// Workflow state label (e.g. `draft`); vocabulary may evolve with scenario engine.
  status    String   @default("draft")
  draftJson Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant                            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  revisions SupplyChainTwinScenarioRevision[]

  @@index([tenantId])
  @@index([tenantId, updatedAt])
  @@index([tenantId, updatedAt, id])
}

/// Append-only metadata revisions for scenario audit timeline (no draftJson payload copies).
model SupplyChainTwinScenarioRevision {
  id              String   @id @default(cuid())
  tenantId        String
  scenarioDraftId String
  actorId         String?
  action          String
  titleBefore     String?
  titleAfter      String?
  statusBefore    String?
  statusAfter     String?
  createdAt       DateTime @default(now())

  tenant        Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  scenarioDraft SupplyChainTwinScenarioDraft @relation(fields: [scenarioDraftId], references: [id], onDelete: Cascade)

  @@index([tenantId], map: "SupplyChainTwinScenarioRevision_tenantId_idx")
  @@index([tenantId, scenarioDraftId, createdAt], map: "sctwin_scen_rev_draft_created_idx")
  @@index([tenantId, scenarioDraftId, createdAt, id], map: "sctwin_scen_rev_draft_created_id_idx")
}

/// Supply Chain Risk Intelligence — triage state on an external event (docs/SCRI).
enum ScriEventReviewState {
  NEW
  UNDER_REVIEW
  WATCH
  ACTION_REQUIRED
  DISMISSED
  RESOLVED
}

enum ScriRecommendationStatus {
  ACTIVE
  ACCEPTED
  REJECTED
  SNOOZED
}

/// SCRI R1: clustered external risk / disruption event (ingest + feed + detail).
model ScriExternalEvent {
  id                String               @id @default(cuid())
  tenantId          String
  /// Idempotency key for ingest (stable per tenant).
  ingestKey         String               @db.VarChar(256)
  /// Optional fingerprint for future clustering across sources.
  clusterKey        String?              @db.VarChar(256)
  eventType         String               @db.VarChar(64)
  title             String               @db.VarChar(512)
  shortSummary      String?              @db.Text
  longSummary       String?              @db.Text
  eventTime         DateTime?
  discoveredTime    DateTime             @default(now())
  severity          TwinRiskSeverity
  /// 0–100 confidence in classification / relevance (R1 default from ingest).
  confidence        Int                  @default(50)
  reviewState       ScriEventReviewState @default(NEW)
  /// Optional assignee for triage (R3).
  ownerUserId       String?
  sourceCount       Int                  @default(0)
  sourceTrustScore  Int?
  aiSummary         String?              @db.Text
  /// CONNECTOR = supplied on ingest; DETERMINISTIC_V1 = platform template; null = legacy / none.
  aiSummarySource   String?              @db.VarChar(32)
  structuredPayload Json                 @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner            User?                     @relation("ScriEventOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  sources          ScriEventSource[]
  geographies      ScriEventGeography[]
  affectedEntities ScriEventAffectedEntity[]
  reviewLogs       ScriEventReviewLog[]
  taskLinks        ScriEventTaskLink[]
  recommendations  ScriEventRecommendation[]

  @@unique([tenantId, ingestKey])
  @@index([tenantId, discoveredTime])
  @@index([tenantId, reviewState, discoveredTime])
  @@index([tenantId, severity])
  @@index([ownerUserId])
}

model ScriEventSource {
  id                   String    @id @default(cuid())
  eventId              String
  sourceType           String    @db.VarChar(64)
  publisher            String?   @db.VarChar(256)
  url                  String?   @db.VarChar(2000)
  headline             String?   @db.VarChar(512)
  publishedAt          DateTime?
  extractedText        String?   @db.Text
  extractionConfidence Int?

  createdAt DateTime @default(now())

  event ScriExternalEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model ScriEventGeography {
  id          String  @id @default(cuid())
  eventId     String
  countryCode String? @db.VarChar(2)
  region      String? @db.VarChar(128)
  portUnloc   String? @db.VarChar(8)
  label       String? @db.VarChar(256)
  raw         Json?

  event ScriExternalEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

/// SCRI R2: deterministic link from an external event to an internal object (see docs/SCRI data model).
model ScriEventAffectedEntity {
  id              String  @id @default(cuid())
  tenantId        String
  eventId         String
  /// e.g. SHIPMENT, PURCHASE_ORDER, SUPPLIER, SALES_ORDER
  objectType      String  @db.VarChar(32)
  objectId        String
  matchType       String  @db.VarChar(64)
  matchConfidence Int     @default(50)
  impactLevel     String? @db.VarChar(32)
  rationale       String  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event  ScriExternalEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, objectType, objectId, matchType])
  @@index([tenantId, objectType])
  @@index([eventId])
  @@index([tenantId, eventId])
}

/// SCRI R3: append-only triage / review history.
model ScriEventReviewLog {
  id              String               @id @default(cuid())
  tenantId        String
  eventId         String
  actorUserId     String
  reviewStateFrom ScriEventReviewState
  reviewStateTo   ScriEventReviewState
  ownerUserIdFrom String?
  ownerUserIdTo   String?
  note            String?              @db.VarChar(2000)
  createdAt       DateTime             @default(now())

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event  ScriExternalEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  actor  User              @relation("ScriReviewLogActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([eventId, createdAt])
  @@index([tenantId, createdAt])
}

/// SCRI R3: link to an external task / ticket (Jira, email thread ID, etc.).
model ScriEventTaskLink {
  id           String   @id @default(cuid())
  tenantId     String
  eventId      String
  sourceModule String   @db.VarChar(64)
  taskRef      String   @db.VarChar(512)
  status       String?  @db.VarChar(32)
  note         String?  @db.Text
  createdById  String
  createdAt    DateTime @default(now())

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event     ScriExternalEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy User              @relation("ScriTaskLinkCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([eventId, createdAt])
  @@index([tenantId])
}

/// SCRI R5: rule-based recommendation row (regenerated when R2 match runs).
model ScriEventRecommendation {
  id                 String                   @id @default(cuid())
  tenantId           String
  eventId            String
  recommendationType String                   @db.VarChar(64)
  targetObjectType   String?                  @db.VarChar(32)
  targetObjectId     String?
  priority           Int                      @default(50)
  confidence         Int                      @default(60)
  expectedEffect     String?                  @db.Text
  status             ScriRecommendationStatus @default(ACTIVE)
  statusNote         String?                  @db.VarChar(2000)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event  ScriExternalEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, recommendationType])
  @@index([eventId, status])
  @@index([tenantId])
}

/// SCRI R7: per-tenant tuning (trust floor, geo aliases, optional ingest automation).
model ScriTenantTuning {
  id                    String            @id @default(cuid())
  tenantId              String            @unique
  /// Hide or flag ingest below this trust score in dashboards (null = off).
  sourceTrustMin        Int?
  /// Minimum severity to highlight on the risk dashboard (null = off).
  severityHighlightMin  TwinRiskSeverity?
  /// Map non-standard country tokens to ISO-3166 alpha-2 (e.g. `{"UK":"GB"}`), applied at ingest normalization.
  geoAliases            Json              @default("{}")
  /// When true, new/updated events at or above `automationMinSeverity` move from NEW → WATCH if an automation actor is set.
  automationAutoWatch   Boolean           @default(false)
  automationMinSeverity TwinRiskSeverity  @default(MEDIUM)
  automationActorUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  automationActor User?  @relation("ScriTuningAutomationActor", fields: [automationActorUserId], references: [id], onDelete: SetNull)
}

/// SCRI R7: watchlist rule (filter events by severity, type, geography).
model ScriWatchlistRule {
  id           String            @id @default(cuid())
  tenantId     String
  name         String            @db.VarChar(256)
  isActive     Boolean           @default(true)
  /// Minimum event severity for this rule (null = any).
  minSeverity  TwinRiskSeverity?
  /// JSON string[] of event type codes; empty array = match all types.
  eventTypes   Json              @default("[]")
  /// JSON string[] of ISO-2 country codes from event geographies; empty = any country.
  countryCodes Json              @default("[]")
  sortOrder    Int               @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
}
