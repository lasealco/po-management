enum WarehouseType {
  CFS
  WAREHOUSE
}

enum LocationCodeType {
  UN_LOCODE
  PORT
  AIRPORT
}

model LocationCode {
  id          String           @id @default(cuid())
  tenantId    String
  type        LocationCodeType
  code        String
  name        String
  countryCode String?          @db.VarChar(2)
  subdivision String?
  source      String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, code])
  @@index([tenantId, type, isActive])
  @@index([tenantId, code])
}

model Warehouse {
  id           String        @id @default(cuid())
  tenantId     String
  code         String?
  name         String
  type         WarehouseType @default(CFS)
  addressLine1 String?
  city         String?
  region       String?
  countryCode  String?       @db.VarChar(2)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loadPlans LoadPlan[]
  zones     WarehouseZone[]
  bins      WarehouseBin[]
  inventoryBalances InventoryBalance[]
  inventoryMovements InventoryMovement[]
  wmsTasks  WmsTask[]
  wmsWaves  WmsWave[]
  replenishmentRules ReplenishmentRule[]
  outboundOrders OutboundOrder[]
  wmsBillingEvents WmsBillingEvent[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

enum WarehouseZoneType {
  RECEIVING
  PICKING
  RESERVE
  QUARANTINE
  STAGING
  SHIPPING
}

model WarehouseZone {
  id          String            @id @default(cuid())
  tenantId    String
  warehouseId String
  code        String
  name        String
  zoneType    WarehouseZoneType
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  bins      WarehouseBin[]
  sourceRules ReplenishmentRule[] @relation("ReplenishmentSourceZone")
  targetRules ReplenishmentRule[] @relation("ReplenishmentTargetZone")

  @@unique([warehouseId, code])
  @@index([tenantId, warehouseId, zoneType])
}

enum BinStorageType {
  PALLET
  FLOOR
  SHELF
  QUARANTINE
  STAGING
}

model WarehouseBin {
  id          String   @id @default(cuid())
  tenantId    String
  warehouseId String
  zoneId      String?
  code        String
  name        String
  storageType BinStorageType @default(PALLET)
  isPickFace  Boolean        @default(false)
  maxPallets  Int?
  /// Groups bins into one physical rack / bay run for layout maps (e.g. `R-A01`).
  rackCode       String? @db.VarChar(64)
  aisle          String? @db.VarChar(32)
  bay            String? @db.VarChar(32)
  /// 1-based shelf level (floor = 1) when using rack maps.
  level          Int?
  /// 1-based slot along the rack front (width axis) for grid columns.
  positionIndex  Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  zone      WarehouseZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  inventoryBalances InventoryBalance[]
  inventoryMovements InventoryMovement[]
  wmsTasks WmsTask[]

  @@unique([warehouseId, code])
  @@index([tenantId, warehouseId])
  @@index([zoneId])
  @@index([warehouseId, rackCode])
}

model ReplenishmentRule {
  id             String   @id @default(cuid())
  tenantId       String
  warehouseId    String
  productId      String
  sourceZoneId   String?
  targetZoneId   String?
  minPickQty     Decimal  @db.Decimal(14, 3)
  maxPickQty     Decimal  @db.Decimal(14, 3)
  replenishQty   Decimal  @db.Decimal(14, 3)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceZone  WarehouseZone? @relation("ReplenishmentSourceZone", fields: [sourceZoneId], references: [id], onDelete: SetNull)
  targetZone  WarehouseZone? @relation("ReplenishmentTargetZone", fields: [targetZoneId], references: [id], onDelete: SetNull)

  @@unique([warehouseId, productId])
  @@index([tenantId, warehouseId])
}

enum InventoryMovementType {
  RECEIPT
  PUTAWAY
  PICK
  ADJUSTMENT
  SHIPMENT
}

model InventoryBalance {
  id          String   @id @default(cuid())
  tenantId    String
  warehouseId String
  binId       String
  productId   String
  onHandQty   Decimal  @default(0) @db.Decimal(14, 3)
  allocatedQty Decimal @default(0) @db.Decimal(14, 3)
