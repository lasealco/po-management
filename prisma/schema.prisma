  actionQueueItemId     String?
  requestedDeliveryDate DateTime?
  demandJson            Json
  matchJson             Json
  atpJson               Json
  proposalJson          Json
  approvalNote          String?   @db.Text
  approvedAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User?  @relation("AssistantOrderOrchestrationPlanCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, updatedAt])
  @@index([tenantId, customerCrmAccountId, createdAt])
  @@index([tenantId, salesOrderId])
