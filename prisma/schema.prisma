/// MP15/MP18: durable assistant answer/action memory with grounding and feedback.
model AssistantAuditEvent {
  id            String    @id @default(cuid())
  tenantId      String
  actorUserId   String?
  surface       String    @default("dock") @db.VarChar(64)
  prompt        String    @db.Text
  answerKind    String    @db.VarChar(32)
  message       String?   @db.Text
  evidence      Json?
  quality       Json?
  actions       Json?
  playbook      Json?
  objectType    String?   @db.VarChar(64)
  objectId      String?
  feedback      String?   @db.VarChar(32)
  feedbackAt    DateTime?
  archivedAt    DateTime?
  archiveReason String?   @db.Text
  createdAt     DateTime  @default(now())

  tenant               Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor                User?                          @relation("AssistantAuditEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  evidenceRecords      AssistantEvidenceRecord[]
  reviewExamples       AssistantReviewExample[]
  actionItems          AssistantActionQueueItem[]
  automationShadowRuns AssistantAutomationShadowRun[]
  playbookRuns         AssistantPlaybookRun[]

  @@index([tenantId, createdAt])
  @@index([tenantId, actorUserId, createdAt])
  @@index([tenantId, objectType, objectId, createdAt])
  @@index([tenantId, feedback, createdAt])
  @@index([tenantId, archivedAt, createdAt])
}

/// AMP8: governed automation policy, never implicit; controls shadow/enabled/paused state per low-risk action kind.
model AssistantAutomationPolicy {
  id              String    @id @default(cuid())
  tenantId        String
  policyKey       String    @db.VarChar(128)
  actionKind      String    @db.VarChar(64)
  label           String
  status          String    @default("SHADOW") @db.VarChar(32)
  readinessScore  Int       @default(0)
  threshold       Int       @default(80)
  guardrailsJson  Json
  rollbackPlan    String?   @db.Text
  enabledByUserId String?
  enabledAt       DateTime?
  pausedAt        DateTime?
  lastEvaluatedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant     Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enabledBy  User?                          @relation("AssistantAutomationPolicyEnabledBy", fields: [enabledByUserId], references: [id], onDelete: SetNull)
  shadowRuns AssistantAutomationShadowRun[]

  @@unique([tenantId, policyKey])
  @@index([tenantId, status, updatedAt])
  @@index([tenantId, actionKind, status])
}

/// AMP8: shadow comparison between proposed automation and actual human decision.
model AssistantAutomationShadowRun {
  id                  String   @id @default(cuid())
  tenantId            String
  policyId            String?
  auditEventId        String?
  actionQueueItemId   String?
  actionKind          String   @db.VarChar(64)
  predictedStatus     String   @db.VarChar(32)
  humanStatus         String?  @db.VarChar(32)
  matched             Boolean?
  wouldExecutePayload Json?
  runMode             String   @default("SHADOW") @db.VarChar(32)
  notes               String?  @db.Text
  createdAt           DateTime @default(now())

  tenant     Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  policy     AssistantAutomationPolicy? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  auditEvent AssistantAuditEvent?       @relation(fields: [auditEventId], references: [id], onDelete: SetNull)
  actionItem AssistantActionQueueItem?  @relation(fields: [actionQueueItemId], references: [id], onDelete: SetNull)

  @@index([tenantId, actionKind, createdAt])
  @@index([tenantId, runMode, createdAt])
  @@index([policyId, createdAt])
  @@index([actionQueueItemId])
}

/// AMP11: durable operator control snapshot for assistant rollout, thresholds, and compliance packet exports.
model AssistantAdminControl {
  id              String   @id @default(cuid())
  tenantId        String
  controlKey      String   @db.VarChar(128)
  rolloutMode     String   @default("PILOT") @db.VarChar(32)
  pilotRolesJson  Json     @default("[]")
  pilotSitesJson  Json     @default("[]")
  thresholdsJson  Json
  flagsJson       Json
  packetJson      Json?
  packetStatus    String   @default("DRAFT") @db.VarChar(32)
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedBy User?  @relation("AssistantAdminControlUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, controlKey])
  @@index([tenantId, rolloutMode, updatedAt])
  @@index([tenantId, packetStatus, updatedAt])
}

/// AMP12: customer-ready assistant operating report, generated from live assistant telemetry and demo readiness.
model AssistantOperatingReport {
  id              String   @id @default(cuid())
  tenantId        String
  createdByUserId String?
  reportKey       String   @db.VarChar(128)
  title           String
  status          String   @default("DRAFT") @db.VarChar(32)
  score           Int      @default(0)
  summary         String   @db.Text
  reportJson      Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User?  @relation("AssistantOperatingReportCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, reportKey, createdAt])
  @@index([tenantId, status, createdAt])
}

/// AMP13: governed demand-to-order orchestration plan with ATP and split/reservation proposal evidence.
model AssistantOrderOrchestrationPlan {
