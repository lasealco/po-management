generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  roles             Role[]
  suppliers         Supplier[]
  products          Product[]
  productCategories ProductCategory[]
  productDivisions  ProductDivision[]
  supplierOffices   SupplierOffice[]
  supplierContacts  SupplierContact[]
  supplierServiceCapabilities SupplierServiceCapability[]
  orders            PurchaseOrder[]
  salesOrders       SalesOrder[]
  warehouses        Warehouse[]
  warehouseZones    WarehouseZone[]
  warehouseBins     WarehouseBin[]
  inventoryBalances InventoryBalance[]
  inventoryMovements InventoryMovement[]
  wmsTasks          WmsTask[]
  wmsWaves          WmsWave[]
  replenishmentRules ReplenishmentRule[]
  outboundOrders    OutboundOrder[]
  outboundOrderLines OutboundOrderLine[]
  wmsBillingRates         WmsBillingRate[]
  wmsBillingEvents        WmsBillingEvent[]
  wmsBillingInvoiceRuns   WmsBillingInvoiceRun[]
  wmsBillingInvoiceLines  WmsBillingInvoiceLine[]
  loadPlans         LoadPlan[]
  userPreferences   UserPreference[]
  workflows         Workflow[]
  crmLeads          CrmLead[]
  crmAccounts       CrmAccount[]
  crmContacts       CrmContact[]
  crmOpportunities  CrmOpportunity[]
  crmActivities     CrmActivity[]
  crmQuotes         CrmQuote[]
  ctTrackingMilestones CtTrackingMilestone[]
  ctShipmentDocuments CtShipmentDocument[]
  ctShipmentNotes   CtShipmentNote[]
  ctFinancialSnapshots CtShipmentFinancialSnapshot[]
  ctAlerts            CtAlert[]
  ctExceptions        CtException[]
  ctAuditLogs         CtAuditLog[]
  ctSavedFilters      CtSavedFilter[]
  ctSavedReports      CtSavedReport[]
  ctDashboardWidgets  CtDashboardWidget[]
  ctShipmentLegs     CtShipmentLeg[]
  ctShipmentContainers CtShipmentContainer[]
  ctFxRates          CtFxRate[]
  ctShipmentCostLines CtShipmentCostLine[]
  ctMilestoneTemplatePacks CtMilestoneTemplatePack[]
  ctContainerCargoLines CtContainerCargoLine[]
  ctExceptionCodes      CtExceptionCode[]
  locationCodes         LocationCode[]
  ctReportSchedules     CtReportSchedule[]
  tariffLegalEntities   TariffLegalEntity[]
  tariffContractHeaders TariffContractHeader[]
  tariffImportBatches   TariffImportBatch[]
  tariffShipmentApplications TariffShipmentApplication[]
  quoteRequests         QuoteRequest[]
  bookingPricingSnapshots BookingPricingSnapshot[]
  invoiceIntakes        InvoiceIntake[]
  invoiceToleranceRules InvoiceToleranceRule[]
  invoiceChargeAliases  InvoiceChargeAlias[]
  apiHubConnectors      ApiHubConnector[]
  apiHubConnectorAuditLogs ApiHubConnectorAuditLog[]
  apiHubIngestionRuns   ApiHubIngestionRun[]
  apiHubIngestionApplyIdempotencies ApiHubIngestionApplyIdempotency[]
  apiHubIngestionRunAuditLogs ApiHubIngestionRunAuditLog[]
  apiHubMappingTemplates ApiHubMappingTemplate[]
  apiHubMappingTemplateAuditLogs ApiHubMappingTemplateAuditLog[]
  apiHubMappingAnalysisJobs ApiHubMappingAnalysisJob[]
  apiHubStagingBatches ApiHubStagingBatch[]
  apiHubStagingRows ApiHubStagingRow[]
  supplyChainTwinEntitySnapshots SupplyChainTwinEntitySnapshot[]
  supplyChainTwinEntityEdges     SupplyChainTwinEntityEdge[]
  supplyChainTwinIngestEvents    SupplyChainTwinIngestEvent[]
  supplyChainTwinRiskSignals     SupplyChainTwinRiskSignal[]
  supplyChainTwinScenarioDrafts  SupplyChainTwinScenarioDraft[]
  supplyChainTwinScenarioRevisions SupplyChainTwinScenarioRevision[]
  scriExternalEvents              ScriExternalEvent[]
  scriEventAffectedEntities       ScriEventAffectedEntity[]
  scriEventReviewLogs             ScriEventReviewLog[]
  scriEventTaskLinks              ScriEventTaskLink[]
  scriEventRecommendations        ScriEventRecommendation[]
  scriWatchlistRules              ScriWatchlistRule[]
  scriTenantTuning                ScriTenantTuning?
  supplierOnboardingTasks         SupplierOnboardingTask[]
  srmSupplierDocuments            SrmSupplierDocument[]
  srmSupplierDocumentAuditLogs    SrmSupplierDocumentAuditLog[]
  srmIntegrationIdempotencies     SrmIntegrationIdempotency[]
  srmOperatorNotifications        SrmOperatorNotification[]
}

/// Integration / API hub — registry row for an external or internal data source (Phase 1 stub).
model ApiHubConnector {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  /// High-level source label until taxonomy lands (e.g. `stub`, `file`, `api`).
  sourceKind String  @default("unspecified")
  /// Auth mode metadata only (no credential values in this table).
  authMode  String   @default("none")
  /// Secret manager / vault reference, never plaintext credentials.
  authConfigRef String?
  /// Operator-facing configuration readiness state.
  authState String   @default("not_configured")
  status    String   @default("draft")
  /// Populated when sync jobs exist; nullable for stub rows.
  lastSyncAt DateTime?
  /// Operator-facing health / connectivity summary (no secrets).
  healthSummary String?
  /// Operator-written metadata (non-secret); capped in API layer.
  opsNote   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs ApiHubConnectorAuditLog[]
  ingestionRuns ApiHubIngestionRun[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  /// Connector list filters + sort (Slice 58).
  @@index([tenantId, status, createdAt])
  @@index([tenantId, authMode, createdAt])
  @@index([tenantId, updatedAt])
}

model ApiHubConnectorAuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  connectorId String
  actorUserId String
  action      String
  note        String?
  createdAt   DateTime @default(now())

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connector ApiHubConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  actorUser User            @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@index([connectorId, createdAt])
  @@index([actorUserId, createdAt])
}

model ApiHubIngestionRun {
  id                String   @id @default(cuid())
  tenantId          String
  connectorId       String?
  requestedByUserId String
  idempotencyKey    String?
  status            String   @default("queued")
  /// How the run was triggered (`manual` | `api` | `scheduled`); list filter in Slice 22.
  triggerKind       String   @default("api")
  attempt           Int      @default(1)
  maxAttempts       Int      @default(3)
  resultSummary     String?
  errorCode         String?
  errorMessage      String?
  enqueuedAt        DateTime @default(now())
  startedAt         DateTime?
  finishedAt        DateTime?
  retryOfRunId      String?
  /// Set when mapping/results were applied to downstream systems (Slice 28).
  appliedAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connector   ApiHubConnector?  @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  requestedBy User              @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)
  retryOf     ApiHubIngestionRun? @relation("ApiHubIngestionRunRetryChain", fields: [retryOfRunId], references: [id], onDelete: SetNull)
  retries     ApiHubIngestionRun[] @relation("ApiHubIngestionRunRetryChain")

  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([connectorId, createdAt])
  @@index([requestedByUserId, createdAt])
  @@index([retryOfRunId, createdAt])
  /// List + keyset pagination when filtering by connector (Slice 58).
  @@index([tenantId, connectorId, createdAt])
  /// In-flight counts and connector-scoped status filters (Slice 58).
  @@index([tenantId, connectorId, status])
  /// List runs filtered by trigger kind (Slice 58).
  @@index([tenantId, triggerKind, createdAt])
  /// Retry-tree expansion under tenant scope (Slice 58).
  @@index([tenantId, retryOfRunId])
  @@unique([tenantId, idempotencyKey])
}

/// Cached apply POST outcomes for safe client retries (Slice 42).
model ApiHubIngestionApplyIdempotency {
  id               String   @id @default(cuid())
  tenantId         String
  idempotencyKey   String
  ingestionRunId   String
  dryRun           Boolean
  /// Stable hash of apply shape (marker vs downstream target/rows/matchKey) for safe idempotent replay.
  requestFingerprint String @default("v1:marker")
  responseStatus   Int
  responseBody     Json
  createdAt        DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, ingestionRunId])
}

/// Append-only audit for ingestion apply / retry decisions (Slice 45). `ingestionRunId` is not a FK so history survives run deletes.
model ApiHubIngestionRunAuditLog {
  id             String   @id @default(cuid())
  tenantId       String
  ingestionRunId String
  actorUserId    String
  action         String
  note           String?
  metadata       Json
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User   @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@index([ingestionRunId, createdAt])
  @@index([actorUserId, createdAt])
  /// Apply/retry alert queries: tenant + action + sort by time (Slice 58).
  @@index([tenantId, action, createdAt])
}

/// Tenant-scoped field mapping rule sets for ingestion / integration hub (Slice 35).
model ApiHubMappingTemplate {
  id              String   @id @default(cuid())
  tenantId        String
  createdByUserId String
  name            String
  description     String?
  rules           Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation("ApiHubMappingTemplateCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
}

/**
 * Append-only audit for mapping templates (Slice 36). `templateId` is not a foreign key so rows
 * remain after the template is deleted.
 */
model ApiHubMappingTemplateAuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  templateId  String
  actorUserId String
  action      String
  note        String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User   @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, templateId, createdAt])
  @@index([tenantId, createdAt])
}

/// P2 — async mapping analysis job: structured rule proposals (deterministic heuristic today; LLM optional later).
model ApiHubMappingAnalysisJob {
  id                String   @id @default(cuid())
  tenantId          String
  requestedByUserId String
  /// `queued` | `processing` | `succeeded` | `failed`
  status            String   @default("queued")
  /// `{ schemaVersion, records, targetFields?, note? }` — no secrets; size-capped in API.
  inputPayload      Json
  /// `{ schemaVersion, engine, rules, notes?, stagingPreview? }` when succeeded.
  outputProposal    Json?
  errorMessage      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  startedAt         DateTime?
  finishedAt        DateTime?

  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedBy  User   @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)
  stagingBatches ApiHubStagingBatch[]

  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
}

/// Normalized staging batch (pre-commit rows) for operator review — linked from mapping analysis or future ingest.
model ApiHubStagingBatch {
  id                         String   @id @default(cuid())
  tenantId                   String
  createdByUserId            String
  sourceMappingAnalysisJobId String?
  title                      String?
  /// `open` | `promoted` | `discarded`
  status                     String   @default("open")
  rowCount                   Int      @default(0)
  /// Set when rows were applied to downstream modules (SO/PO/CT audit) via API Hub apply.
  appliedAt                  DateTime?
  /// Last apply outcome: target, dryRun, row results (ids/errors).
  applySummary               Json?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdByUserId], references: [id], onDelete: Restrict)
  sourceJob ApiHubMappingAnalysisJob? @relation(fields: [sourceMappingAnalysisJobId], references: [id], onDelete: SetNull)
  rows      ApiHubStagingRow[]

  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
}

model ApiHubStagingRow {
  id           String   @id @default(cuid())
  tenantId     String
  batchId      String
  rowIndex     Int
  sourceRecord Json?
  mappedRecord Json?
  issues       Json?
  createdAt    DateTime @default(now())

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  batch  ApiHubStagingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, rowIndex])
  @@index([tenantId, batchId])
}

/// Tenant-scoped milestone template packs (override or extend built-in packs in code).
model CtMilestoneTemplatePack {
  id          String   @id @default(cuid())
  tenantId    String
  slug        String
  title       String
  description String?  @db.Text
  milestones  Json
  isBuiltIn   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  name      String
  passwordHash String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles           UserRole[]
  orderChats          OrderChatMessage[]
  purchaseOrders      PurchaseOrder[]
  salesOrdersCreated  SalesOrder[]
  orderTransitionLogs OrderTransitionLog[]
  splitProposals      SplitProposal[]
  shipmentsCreated    Shipment[]
  shipmentBookingsCreated ShipmentBooking[] @relation("ShipmentBookingCreatedBy")
  shipmentBookingsUpdated ShipmentBooking[] @relation("ShipmentBookingUpdatedBy")
  shipmentMilestonesUpdated ShipmentMilestone[]
  inventoryMovementsCreated InventoryMovement[]
  wmsTasksCreated    WmsTask[] @relation("WmsTaskCreatedBy")
  wmsTasksCompleted  WmsTask[] @relation("WmsTaskCompletedBy")
  wmsWavesCreated    WmsWave[]
  outboundOrdersCreated OutboundOrder[]
  loadPlansCreated    LoadPlan[]
  preferences         UserPreference[]
  crmLeadsOwned       CrmLead[]          @relation("CrmLeadOwner")
  crmAccountsOwned    CrmAccount[]      @relation("CrmAccountOwner")
  crmContactsOwned    CrmContact[]      @relation("CrmContactOwner")
  crmOpportunitiesOwned CrmOpportunity[] @relation("CrmOpportunityOwner")
  crmActivitiesOwned  CrmActivity[]      @relation("CrmActivityOwner")
  crmQuotesOwned      CrmQuote[]         @relation("CrmQuoteOwner")
  wmsBillingInvoiceRunsCreated WmsBillingInvoiceRun[] @relation("WmsBillingInvoiceRunCreatedBy")
  ctTrackingMilestonesUpdated CtTrackingMilestone[]
  ctShipmentDocumentsUploaded CtShipmentDocument[]
  ctShipmentNotesCreated CtShipmentNote[]
  ctFinancialSnapshotsCreated CtShipmentFinancialSnapshot[]
  ctAlertsOwned CtAlert[] @relation("CtAlertOwner")
  ctAlertsAcknowledged CtAlert[] @relation("CtAlertAckBy")
  ctExceptionsOwned CtException[] @relation("CtExceptionOwner")
  ctAuditLogsActor CtAuditLog[]
  ctSavedFilters CtSavedFilter[]
  ctSavedReports CtSavedReport[]
  ctDashboardWidgets CtDashboardWidget[]
  ctReportSchedules CtReportSchedule[]
  ctShipmentCostLinesCreated CtShipmentCostLine[]
  shipmentsOpsAssigned       Shipment[] @relation("ShipmentOpsAssignee")
  /// When set, Control Tower (and similar) list/detail is limited to shipments tagged with this CRM account.
  customerCrmAccountId String?
  customerCrmAccount   CrmAccount? @relation("UserCustomerPortalScope", fields: [customerCrmAccountId], references: [id], onDelete: SetNull)
  tariffContractHeadersOwned TariffContractHeader[] @relation("TariffContractHeaderOwner")
  tariffApprovalRecords      TariffApprovalRecord[] @relation("TariffApprovalApprover")
  tariffAuditLogs            TariffAuditLog[] @relation("TariffAuditLogActor")
  quoteRequestsOwned         QuoteRequest[]         @relation("QuoteRequestOwner")
  quoteClarificationsAuthored QuoteClarificationMessage[] @relation("QuoteClarificationAuthor")
  bookingPricingSnapshotsCreated BookingPricingSnapshot[] @relation("BookingPricingSnapshotCreator")
  invoiceIntakesCreated          InvoiceIntake[]          @relation("InvoiceIntakeCreator")
  invoiceIntakesReviewed         InvoiceIntake[]          @relation("InvoiceIntakeReviewer")
  apiHubConnectorAuditLogs       ApiHubConnectorAuditLog[]
  apiHubIngestionRunsRequested   ApiHubIngestionRun[]
  apiHubMappingTemplatesCreated  ApiHubMappingTemplate[] @relation("ApiHubMappingTemplateCreatedBy")
  apiHubMappingTemplateAuditLogs ApiHubMappingTemplateAuditLog[]
  apiHubIngestionRunAuditLogs ApiHubIngestionRunAuditLog[]
  apiHubMappingAnalysisJobsRequested ApiHubMappingAnalysisJob[]
  apiHubStagingBatchesCreated ApiHubStagingBatch[]
  invoiceIntakesAccountingApproved InvoiceIntake[]         @relation("InvoiceIntakeAccountingApprover")
  tariffShipmentApplicationsCreated TariffShipmentApplication[] @relation("TariffShipmentApplicationCreator")
  scriEventsOwned                 ScriExternalEvent[]           @relation("ScriEventOwner")
  scriReviewLogsAuthored          ScriEventReviewLog[]          @relation("ScriReviewLogActor")
  scriTaskLinksCreated            ScriEventTaskLink[]           @relation("ScriTaskLinkCreatedBy")
  scriTuningAutomationActorOf     ScriTenantTuning[]            @relation("ScriTuningAutomationActor")
  supplierOnboardingTasksAssigned  SupplierOnboardingTask[]      @relation("SupplierOnboardingTaskAssignee")
  srmOperatorNotificationsReceived SrmOperatorNotification[]     @relation("SrmOperatorNotificationRecipient")
  srmOperatorNotificationsAsActor  SrmOperatorNotification[]   @relation("SrmOperatorNotificationActor")
  srmDocumentsUploaded             SrmSupplierDocument[]         @relation("SrmSupplierDocumentUploadedBy")
  srmDocumentsLastTouched         SrmSupplierDocument[]         @relation("SrmSupplierDocumentLastTouchedBy")
  srmSupplierDocumentAuditAuthored SrmSupplierDocumentAuditLog[] @relation("SrmSupplierDocumentAuditActor")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([customerCrmAccountId])
}

model UserPreference {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([tenantId, key])
}

model Role {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id               String  @id @default(cuid())
  roleId           String
  resource         String
  action           String
  effect           String
  workflowStatusId String?

  role           Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  workflowStatus WorkflowStatus? @relation(fields: [workflowStatusId], references: [id], onDelete: SetNull)

  @@unique([roleId, resource, action, workflowStatusId])
  @@index([roleId])
  @@index([workflowStatusId])
}

enum SrmSupplierCategory {
  product
  logistics
}

enum SupplierApprovalStatus {
  pending_approval
  approved
  rejected
}

/// Phase G (operator): coarse lifecycle step beyond the default checklist; not supplier portal.
enum SrmOnboardingStage {
  intake
  diligence
  review
  cleared
}

model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  code      String?
  name      String
  email     String?
  phone     String?
  isActive  Boolean  @default(true)

  /// Procurement: materials vs logistics partners (forwarders, carriers-as-parties, etc.).
  srmCategory SrmSupplierCategory @default(product)
  /// Buyer-created suppliers start pending until an approver activates them.
  approvalStatus SupplierApprovalStatus @default(approved)
  /// Operator-facing onboarding pipeline stage (Phase G; parallel to checklist tasks).
  srmOnboardingStage SrmOnboardingStage @default(intake)

  /// Legal / registered business name if different from trade name.
  legalName String?
  /// VAT, EIN, company registration, etc.
  taxId     String?
  website   String?

  registeredAddressLine1 String?
  registeredAddressLine2 String?
  registeredCity         String?
  registeredRegion       String?
  registeredPostalCode   String?
  registeredCountryCode  String? @db.VarChar(2)

  /// e.g. 30 for Net 30; use with paymentTermsLabel.
  paymentTermsDays   Int?
  paymentTermsLabel  String?
  creditLimit        Decimal? @db.Decimal(14, 2)
  creditCurrency     String?  @db.VarChar(3)
  defaultIncoterm    String?
  internalNotes      String?  @db.Text

  /// Hours allowed for booking confirmation after send (logistics partners). Null = tenant default (24h).
  bookingConfirmationSlaHours Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders           PurchaseOrder[]
  offices          SupplierOffice[]
  contacts         SupplierContact[]
  serviceCapabilities SupplierServiceCapability[]
  productSuppliers ProductSupplier[]
  shipmentBookings ShipmentBooking[]
  shipmentsCarrier Shipment[] @relation("ShipmentCarrierSupplier")
  ctShipmentLegsCarrier CtShipmentLeg[] @relation("CtLegCarrierSupplier")
  ctShipmentCostLinesVendor CtShipmentCostLine[] @relation("CtCostLineVendorSupplier")
  quoteRequestRecipients    QuoteRequestRecipient[]
  onboardingTasks           SupplierOnboardingTask[]
  srmDocuments              SrmSupplierDocument[]
  srmOperatorNotifications SrmOperatorNotification[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

/// SRM Phase B: checklist rows for supplier onboarding (assignee, due date, done).
model SupplierOnboardingTask {
  id         String   @id @default(cuid())
  tenantId   String
  supplierId String
  /// Idempotent default key, e.g. `supplier_profile`.
  taskKey    String   @db.VarChar(64)
  title      String   @db.VarChar(256)
  sortOrder  Int      @default(0)
  done       Boolean  @default(false)
  assigneeUserId String?
  dueAt      DateTime?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  assignee User?    @relation("SupplierOnboardingTaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  srmOperatorNotifications SrmOperatorNotification[]

  @@unique([supplierId, taskKey])
  @@index([tenantId, supplierId])
  @@index([tenantId, assigneeUserId])
}

/// SRM Phase C — compliance vault: uploaded files tied to a supplier.
enum SrmSupplierDocumentType {
  certificate_of_insurance
  w9
  code_of_conduct
  quality_agreement
  tax_certificate
  other
}

enum SrmSupplierDocumentStatus {
  active
  archived
  superseded
}

/// Metadata + object storage URL for a supplier compliance document.
model SrmSupplierDocument {
  id           String  @id @default(cuid())
  tenantId     String
  supplierId   String
  documentType SrmSupplierDocumentType
  status         SrmSupplierDocumentStatus @default(active)
  title          String? @db.VarChar(256)
  fileName       String
  mimeType       String
  fileSize       Int
  /// Blob object basename or local key; optional when `fileUrl` is self-sufficient.
  storageKey     String? @db.VarChar(512)
  fileUrl        String  @db.Text
  expiresAt      DateTime?
  uploadedById   String
  lastModifiedById String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier       Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  uploadedBy     User     @relation("SrmSupplierDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  lastModifiedBy User?    @relation("SrmSupplierDocumentLastTouchedBy", fields: [lastModifiedById], references: [id], onDelete: SetNull)
  auditLogs      SrmSupplierDocumentAuditLog[]

  @@index([tenantId, supplierId])
  @@index([tenantId, status])
  @@index([tenantId, expiresAt])
}

/// Append-only triage for supplier documents (upload + metadata/single updates).
model SrmSupplierDocumentAuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  documentId String
  at         DateTime @default(now())
  actorUserId String
  action     String   @db.VarChar(32)
  details    Json?

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document SrmSupplierDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  actor    User                @relation("SrmSupplierDocumentAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([documentId, at])
  @@index([tenantId, at])
}

/// SRM Phase E — replay cache for `POST` integration routes (e.g. supplier upsert) keyed by `Idempotency-Key`.
model SrmIntegrationIdempotency {
  id        String   @id @default(cuid())
  tenantId  String
  /// Route surface, e.g. `supplier_upsert_v1`.
  surface   String   @db.VarChar(64)
  key       String   @db.VarChar(256)
  bodySha256 String  @db.VarChar(64)
  statusCode Int
  responseBody String @db.Text
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, surface, key])
  @@index([tenantId, createdAt])
}

/// Phase G: in-app row for buyers/operators (not supplier portal). Task assign + future hooks.
model SrmOperatorNotification {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  /// e.g. ONBOARDING_TASK_ASSIGNED
  kind       String   @db.VarChar(64)
  title      String   @db.VarChar(256)
  body       String?  @db.Text
  readAt     DateTime?
  supplierId String?
  /// Optional link for UI / deep-link.
  taskId     String?
  actorUserId String?
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User     @relation("SrmOperatorNotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  task     SupplierOnboardingTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  actor    User?    @relation("SrmOperatorNotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, userId, readAt])
  @@index([tenantId, userId, createdAt])
}

/// SRM: declared transport / service scope (modes, service lines, geography). See PRD “Service capabilities”.
model SupplierServiceCapability {
  id          String   @id @default(cuid())
  tenantId    String
  supplierId  String
  /// OCEAN | AIR | ROAD | RAIL when mode-specific; optional.
  mode        String?  @db.VarChar(16)
  subMode     String?  @db.VarChar(64)
  /// Short label, e.g. Freight forwarding, Customs brokerage.
  serviceType String   @db.VarChar(128)
  geography   String?  @db.VarChar(256)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([tenantId, supplierId])
}

/// People at the supplier (sales, AP, operations).
model SupplierContact {
  id         String   @id @default(cuid())
  tenantId   String
  supplierId String
  name       String
  title      String?
  /// e.g. Sales, Accounts payable, Quality
  role       String?
  email      String?
  phone      String?
  notes      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  shipmentBookings ShipmentBooking[]

  @@index([tenantId])
  @@index([supplierId])
}

/// Buyer-facing catalog category (Settings → category management).
model ProductCategory {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String?
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Organizational division for reporting and filters.
model ProductDivision {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Supplier office / site used on the product form (dropdown).
model SupplierOffice {
  id           String   @id @default(cuid())
  tenantId     String
  supplierId   String
  name         String
  addressLine1 String?
  addressLine2 String?
  city         String?
  region       String?
  postalCode   String?
  countryCode  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  products Product[]
  shipmentBookings ShipmentBooking[]

  @@unique([supplierId, name])
  @@index([tenantId])
  @@index([supplierId])
}

model Product {
  id          String  @id @default(cuid())
  tenantId    String
  /// Shown as “product code” in the legacy UI (e.g. BC-CB40).
  productCode String?
  sku         String?
  name        String
  description String? @db.VarChar(2000)
  unit        String?

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  divisionId String?
  division   ProductDivision? @relation(fields: [divisionId], references: [id], onDelete: SetNull)

  ean           String? @db.VarChar(32)
  customerName  String? @db.Text
  /// Legacy “product image” until blob storage is wired; can be a CDN URL.
  primaryImageUrl String?
  hsCode        String?

  isDangerousGoods    Boolean @default(false)
  dangerousGoodsClass String?
  unNumber            String?
  properShippingName  String?
  packingGroup        String?
  flashPoint          Decimal? @db.Decimal(10, 2)
  flashPointUnit      String?
  msdsUrl             String?

  isTemperatureControlled Boolean @default(false)
  temperatureRangeText    String?
  temperatureUnit       String?
  coolingType           String?
  packagingNotes        String? @db.Text
  humidityRequirements  String?
  storageDescription    String? @db.Text
  isForReexport         Boolean @default(false)

  supplierOfficeId String?
  supplierOffice   SupplierOffice? @relation(fields: [supplierOfficeId], references: [id], onDelete: SetNull)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItems     PurchaseOrderItem[]
  inventoryBalances InventoryBalance[]
  inventoryMovements InventoryMovement[]
  wmsBillingEvents WmsBillingEvent[]
  wmsTasks WmsTask[]
  replenishmentRules ReplenishmentRule[]
  outboundOrderLines OutboundOrderLine[]
  documents      ProductDocument[]
  productSuppliers ProductSupplier[]

  @@unique([tenantId, sku])
  @@unique([tenantId, productCode])
  @@index([tenantId])
  @@index([categoryId])
  @@index([divisionId])
}

/// Which suppliers can supply this SKU (legacy “Suppliers: N” column).
model ProductSupplier {
  productId  String
  supplierId String
  createdAt  DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([productId, supplierId])
  @@index([supplierId])
}

enum ProductDocumentKind {
  PRIMARY_IMAGE
  MSDS
  OTHER
}

/// File metadata; `url` holds a storage URL (S3, Vercel Blob, etc.) when uploads exist.
model ProductDocument {
  id        String              @id @default(cuid())
  productId String
  kind      ProductDocumentKind @default(OTHER)
  fileName  String
  url       String
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime            @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Workflow {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  code             String
  isDefault        Boolean  @default(false)
  supplierPortalOn Boolean  @default(false)
  allowSplitOrders Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  statuses    WorkflowStatus[]
  transitions WorkflowTransition[]
  actions     WorkflowAction[]
  orders      PurchaseOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model WorkflowStatus {
  id         String   @id @default(cuid())
  workflowId String
  code       String
  label      String
  category   String?
  isStart    Boolean  @default(false)
  isEnd      Boolean  @default(false)
  sortOrder  Int
  createdAt  DateTime @default(now())

  workflow        Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromTransitions WorkflowTransition[] @relation("FromStatus")
  toTransitions   WorkflowTransition[] @relation("ToStatus")
  orders          PurchaseOrder[]
  permissions     RolePermission[]

  @@unique([workflowId, code])
  @@index([workflowId, sortOrder])
}

model WorkflowTransition {
  id              String  @id @default(cuid())
  workflowId      String
  fromStatusId    String
  toStatusId      String
  actionCode      String
  label           String
  requiresComment Boolean @default(false)

  workflow   Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromStatus WorkflowStatus @relation("FromStatus", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus   WorkflowStatus @relation("ToStatus", fields: [toStatusId], references: [id], onDelete: Cascade)

  @@unique([workflowId, fromStatusId, toStatusId, actionCode])
  @@index([workflowId, fromStatusId])
}

model WorkflowAction {
  id         String  @id @default(cuid())
  workflowId String
  code       String
  label      String
  isEnabled  Boolean @default(true)

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, code])
  @@index([workflowId])
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  tenantId      String
  workflowId    String
  orderNumber   String
  title         String?
  requesterId   String
  supplierId    String?
  statusId      String
  currency      String   @default("USD")
  subtotal      Decimal  @db.Decimal(14, 2)
  taxAmount     Decimal  @db.Decimal(14, 2)
  totalAmount   Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  splitParentId String?
  splitIndex    Int?
  splitProposalId String?

  /// Buyer / internal reference (e.g. requisition #).
  buyerReference    String?
  /// Supplier acknowledgment or their order #.
  supplierReference String?
  paymentTermsDays   Int?
  paymentTermsLabel  String?
  incoterm           String?
  requestedDeliveryDate DateTime?

  shipToName         String?
  shipToLine1        String?
  shipToLine2        String?
  shipToCity         String?
  shipToRegion       String?
  shipToPostalCode   String?
  shipToCountryCode  String? @db.VarChar(2)

  internalNotes   String? @db.Text
  notesToSupplier String? @db.Text

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow      Workflow             @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  requester     User                 @relation(fields: [requesterId], references: [id], onDelete: Restrict)
  supplier      Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  status        WorkflowStatus       @relation(fields: [statusId], references: [id], onDelete: Restrict)
  splitProposal SplitProposal?       @relation("SplitProposalDraftOrders", fields: [splitProposalId], references: [id], onDelete: SetNull)
  items         PurchaseOrderItem[]
  shipments     Shipment[]
  wmsTasks      WmsTask[]
  transitions   OrderTransitionLog[]
  chats         OrderChatMessage[]
  splitChildren PurchaseOrder[]      @relation("OrderSplitParent")
  splitParent   PurchaseOrder?       @relation("OrderSplitParent", fields: [splitParentId], references: [id])
  splitProposalsAsParent SplitProposal[] @relation("SplitProposalParent")

  @@unique([tenantId, orderNumber])
  @@index([tenantId, createdAt])
  @@index([tenantId, statusId])
  @@index([workflowId])
  @@index([splitParentId])
  @@index([splitProposalId])
}

model PurchaseOrderItem {
  id          String  @id @default(cuid())
  orderId     String
  lineNo      Int
  productId   String?
  description String
  quantity    Decimal @db.Decimal(14, 3)
  unitPrice   Decimal @db.Decimal(14, 4)
  lineTotal   Decimal @db.Decimal(14, 2)

  order              PurchaseOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  splitProposalLines SplitProposalLine[]
  shipmentItems      ShipmentItem[]

  @@unique([orderId, lineNo])
  @@index([orderId])
}

model SalesOrder {
  id                  String           @id @default(cuid())
  tenantId            String
  soNumber            String
  status              SalesOrderStatus @default(DRAFT)
  customerName        String
  customerCrmAccountId String?
  externalRef         String?
  requestedShipDate   DateTime?
  requestedDeliveryDate DateTime?
  currency            String           @default("USD") @db.VarChar(3)
  notes               String?          @db.Text
  createdById         String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerCrmAccount CrmAccount? @relation(fields: [customerCrmAccountId], references: [id], onDelete: SetNull)
  createdBy User @relation(fields: [createdById], references: [id], onDelete: Restrict)
  shipments Shipment[]

  @@unique([tenantId, soNumber])
  @@index([tenantId, status, createdAt])
  @@index([customerCrmAccountId])
}

enum ShipmentStatus {
  /// Internal draft: booking data captured, not yet submitted to forwarder.
  BOOKING_DRAFT
  /// Booking request sent; awaiting forwarder confirmation within SLA.
  BOOKING_SUBMITTED
  SHIPPED
  VALIDATED
  BOOKED
  IN_TRANSIT
  DELIVERED
  RECEIVED
}

enum ShipmentBookingStatus {
  DRAFT
  /// Sent to forwarder / carrier channel; awaiting confirmation.
  SENT
  CONFIRMED
  CANCELLED
}

enum ShipmentMilestoneCode {
  ASN_SUBMITTED
  ASN_VALIDATED
  BOOKING_CONFIRMED
  DEPARTED
  ARRIVED
  DELIVERED
  RECEIVED
}

enum ShipmentMilestoneSource {
  SUPPLIER
  INTERNAL
  FORWARDER
  SYSTEM
}

enum TransportMode {
  OCEAN
  AIR
  ROAD
  RAIL
}

enum SalesOrderStatus {
  DRAFT
  OPEN
  CLOSED
}

model Shipment {
  id           String         @id @default(cuid())
  orderId      String
  salesOrderId String?
  shipmentNo   String?
  status       ShipmentStatus @default(BOOKING_DRAFT)
  shippedAt    DateTime
  receivedAt   DateTime?
  /// Supplier / forwarder ASN or notice id (WMS receiving layer).
  asnReference     String?
  /// Expected arrival at CFS / warehouse for receiving planning.
  expectedReceiveAt DateTime?
  carrierSupplierId String?
  carrier      String?
  trackingNo   String?
  transportMode TransportMode?
  estimatedVolumeCbm Decimal? @db.Decimal(12, 3)
  estimatedWeightKg Decimal? @db.Decimal(12, 3)
  /// Outward package / collo count (forwarder cargo).
  cargoOuterPackageCount Int?
  /// Chargeable / billable weight where different from estimatedWeightKg (e.g. air).
  cargoChargeableWeightKg Decimal? @db.Decimal(12, 3)
  /// Freeform dimensions (e.g. 120×80×100 cm) until structured L/W/H exist.
  cargoDimensionsText String? @db.VarChar(512)
  /// Main commodity description for customs / booking screens.
  cargoCommoditySummary String? @db.Text
  notes        String?
  /// Logistics customer (e.g. 3PL shipper account) for visibility and reporting.
  customerCrmAccountId String?
  /// Primary Control Tower / ops owner for this shipment (optional).
  opsAssigneeUserId String?
  createdById  String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  order     PurchaseOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  salesOrder SalesOrder?   @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  carrierSupplier Supplier? @relation("ShipmentCarrierSupplier", fields: [carrierSupplierId], references: [id], onDelete: SetNull)
  customerCrmAccount CrmAccount? @relation("ShipmentCustomerAccount", fields: [customerCrmAccountId], references: [id], onDelete: SetNull)
  opsAssignee User? @relation("ShipmentOpsAssignee", fields: [opsAssigneeUserId], references: [id], onDelete: SetNull)
  createdBy User           @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items     ShipmentItem[]
  loadPlanShipment LoadPlanShipment?
  booking ShipmentBooking?
  milestones ShipmentMilestone[]
  wmsTasks WmsTask[]
  ctReferences CtShipmentReference[]
  ctTrackingMilestones CtTrackingMilestone[]
  ctDocuments CtShipmentDocument[]
  ctNotes CtShipmentNote[]
  ctFinancialSnapshots CtShipmentFinancialSnapshot[]
  ctAlerts CtAlert[]
  ctExceptions CtException[]
  ctAuditLogs CtAuditLog[]
  ctLegs     CtShipmentLeg[]
  ctContainers CtShipmentContainer[]
  ctCostLines CtShipmentCostLine[]
  tariffShipmentApplications TariffShipmentApplication[]

  @@index([orderId, createdAt])
  @@index([status])
  @@index([customerCrmAccountId])
  @@index([carrierSupplierId])
  @@index([salesOrderId])
  @@index([opsAssigneeUserId])
}

model ShipmentItem {
  id               String   @id @default(cuid())
  shipmentId       String
  orderItemId      String
  quantityShipped  Decimal  @db.Decimal(14, 3)
  quantityReceived Decimal  @default(0) @db.Decimal(14, 3)
  plannedShipDate  DateTime?
  /// Line-level outward packages (optional; may differ from PO qty unit).
  cargoPackageCount Int?
  cargoGrossWeightKg Decimal? @db.Decimal(14, 3)
  cargoVolumeCbm   Decimal? @db.Decimal(12, 6)
  cargoDimensionsText String? @db.VarChar(512)

  shipment  Shipment          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderItem  PurchaseOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  containerCargoLines CtContainerCargoLine[]

  @@index([shipmentId])
  @@index([orderItemId])
  @@unique([shipmentId, orderItemId])
}

model ShipmentBooking {
  id                  String                @id @default(cuid())
  shipmentId          String                @unique
  status              ShipmentBookingStatus @default(DRAFT)
  bookingNo           String?
  serviceLevel        String?
  forwarderSupplierId String?
  forwarderOfficeId   String?
  forwarderContactId  String?
  mode                TransportMode?
  originCode          String?
  destinationCode     String?
  etd                 DateTime?
  eta                 DateTime?
  latestEta           DateTime?
  /// When the booking request was submitted to the forwarder (EDI / email / portal).
  bookingSentAt           DateTime?
  /// Deadline for forwarder booking confirmation per SLA (derived from Supplier or default).
  bookingConfirmSlaDueAt DateTime?
  notes               String?
  createdById         String
  updatedById         String
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  shipment        Shipment        @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  forwarderSupplier Supplier?     @relation(fields: [forwarderSupplierId], references: [id], onDelete: SetNull)
  forwarderOffice SupplierOffice? @relation(fields: [forwarderOfficeId], references: [id], onDelete: SetNull)
  forwarderContact SupplierContact? @relation(fields: [forwarderContactId], references: [id], onDelete: SetNull)
  createdBy       User            @relation("ShipmentBookingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy       User            @relation("ShipmentBookingUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  pricingSnapshots  BookingPricingSnapshot[]

  @@index([status])
  @@index([forwarderSupplierId])
}

model ShipmentMilestone {
  id          String                  @id @default(cuid())
  shipmentId  String
  code        ShipmentMilestoneCode
  source      ShipmentMilestoneSource @default(INTERNAL)
  plannedAt   DateTime?
  actualAt    DateTime?
  note        String?
  updatedById String
  createdAt   DateTime                @default(now())

  shipment  Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  updatedBy User     @relation(fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([shipmentId, createdAt])
  @@index([code])
}

/// Extra reference numbers (master/house B/L, AWB, etc.) for Control Tower.
model CtShipmentReference {
  id          String   @id @default(cuid())
  shipmentId String
  refType     String
  refValue    String
  createdAt   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([refValue])
}

/// Flexible planned / predicted / actual milestones (beyond enum `ShipmentMilestone`).
model CtTrackingMilestone {
  id          String    @id @default(cuid())
  tenantId    String
  shipmentId  String
  code        String
  label       String?
  plannedAt   DateTime?
  predictedAt DateTime?
  actualAt    DateTime?
  sourceType  String    @default("MANUAL")
  sourceRef   String?
  confidence  Int?
  notes       String?   @db.Text
  updatedById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment  Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  updatedBy User     @relation(fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([tenantId, shipmentId])
  @@index([code])
}

enum CtDocVisibility {
  INTERNAL
  CUSTOMER_SHAREABLE
}

enum CtShipmentDocumentSource {
  UPLOAD
  INTEGRATION
}

model CtShipmentDocument {
  id           String          @id @default(cuid())
  tenantId     String
  shipmentId   String
  /// Canonical code (see `shipment-document-types.ts`) or integration-specific code.
  docType      String
  fileName     String
  /// File URL in object storage (or public path in local dev) — not the file bytes.
  blobUrl      String
  visibility   CtDocVisibility @default(INTERNAL)
  version      Int             @default(1)
  uploadedById String
  createdAt    DateTime        @default(now())
  source                    CtShipmentDocumentSource @default(UPLOAD)
  /// When `source` is INTEGRATION: e.g. CARGOWISE, FREIGHTOS.
  integrationProvider       String?
  /// External document / message id for dedupe and support (optional).
  externalRef               String?

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([shipmentId])
  @@index([shipmentId, source])
}

enum CtNoteVisibility {
  INTERNAL
  SHARED
}

model CtShipmentNote {
  id          String           @id @default(cuid())
  tenantId    String
  shipmentId  String
  body        String           @db.Text
  visibility  CtNoteVisibility @default(INTERNAL)
  createdById String
  createdAt   DateTime         @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment  Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([shipmentId])
}

model CtShipmentFinancialSnapshot {
  id                   String    @id @default(cuid())
  tenantId             String
  shipmentId           String
  customerVisibleCost  Decimal?  @db.Decimal(14, 2)
  internalCost         Decimal?  @db.Decimal(14, 2)
  internalRevenue      Decimal?  @db.Decimal(14, 2)
  internalNet          Decimal?  @db.Decimal(14, 2)
  internalMarginPct    Decimal?  @db.Decimal(9, 4)
  currency             String    @default("USD") @db.VarChar(3)
  asOf                 DateTime  @default(now())
  createdById          String

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment  Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([shipmentId, asOf])
}

enum CtAlertSeverity {
  INFO
  WARN
  CRITICAL
}

enum CtAlertStatus {
  OPEN
  ACKNOWLEDGED
  CLOSED
}

model CtAlert {
  id                 String          @id @default(cuid())
  tenantId           String
  shipmentId         String
  type               String
  severity           CtAlertSeverity @default(WARN)
  title              String
  body               String?         @db.Text
  ownerUserId        String?
  acknowledgedAt     DateTime?
  acknowledgedById String?
  status             CtAlertStatus    @default(OPEN)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment       Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  owner          User?    @relation("CtAlertOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  acknowledgedBy User?    @relation("CtAlertAckBy", fields: [acknowledgedById], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([shipmentId])
}

enum CtExceptionStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

/// Tenant catalog of exception types for Control Tower (dropdown + defaults).
model CtExceptionCode {
  id               String          @id @default(cuid())
  tenantId         String
  code             String
  label            String
  defaultSeverity  CtAlertSeverity @default(WARN)
  sortOrder        Int             @default(0)
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model CtException {
  id          String            @id @default(cuid())
  tenantId    String
  shipmentId  String
  type        String
  severity    CtAlertSeverity   @default(WARN)
  ownerUserId String?
  rootCause   String?           @db.Text
  status      CtExceptionStatus @default(OPEN)
  claimAmount Decimal?          @db.Decimal(14, 2)
  resolvedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  owner    User?    @relation("CtExceptionOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([shipmentId])
  @@index([tenantId, status])
}

model CtAuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  shipmentId  String?
  entityType  String
  entityId    String
  action      String
  payload     Json?
  actorUserId String
  createdAt   DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  actor    User      @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, shipmentId])
  @@index([entityType, entityId])
}

model CtSavedFilter {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  name        String
  filtersJson Json
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Which product domain a saved report belongs to (unified reporting; engines vary by dataset).
enum ReportDataset {
  CONTROL_TOWER
  PO
  CRM
  WMS
}

enum CtReportScheduleFrequency {
  DAILY
  WEEKLY
}

model CtReportSchedule {
  id             String                    @id @default(cuid())
  tenantId       String
  userId         String
  savedReportId  String
  recipientEmail String                    @db.VarChar(320)
  frequency      CtReportScheduleFrequency
  hourUtc        Int
  /// 0 = Sunday … 6 = Saturday (UTC). Required when frequency is WEEKLY; must be null when DAILY.
  dayOfWeek      Int?
  isActive       Boolean                   @default(true)
  lastRunAt      DateTime?
  lastError      String?                   @db.Text
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedReport CtSavedReport @relation(fields: [savedReportId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive, hourUtc])
}

model CtSavedReport {
  id          String         @id @default(cuid())
  tenantId    String
  userId      String
  name        String
  description String?
  configJson  Json
  isShared    Boolean        @default(false)
  dataset     ReportDataset  @default(CONTROL_TOWER)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  dashboardWidgets CtDashboardWidget[]
  reportSchedules  CtReportSchedule[]

  @@index([tenantId, userId, createdAt])
  @@index([tenantId, isShared, createdAt])
  @@index([tenantId, dataset, createdAt])
}

model CtDashboardWidget {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  savedReportId String
  title         String
  sortOrder     Int      @default(0)
  layoutJson    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedReport CtSavedReport @relation(fields: [savedReportId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, sortOrder, createdAt])
  @@index([savedReportId])
}

model CtFxRate {
  id            String   @id @default(cuid())
  tenantId      String
  baseCurrency  String   @db.VarChar(3)
  quoteCurrency String   @db.VarChar(3)
  rate          Decimal  @db.Decimal(18, 8)
  rateDate      DateTime
  provider      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, baseCurrency, quoteCurrency, rateDate])
  @@index([tenantId, baseCurrency, quoteCurrency, rateDate])
}

model CtShipmentCostLine {
  id          String   @id @default(cuid())
  tenantId    String
  shipmentId  String
  category    String
  description String?
  vendorSupplierId String?
  vendor      String?
  invoiceNo   String?
  invoiceDate DateTime?
  amountMinor BigInt
  currency    String   @db.VarChar(3)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  vendorSupplier Supplier? @relation("CtCostLineVendorSupplier", fields: [vendorSupplierId], references: [id], onDelete: SetNull)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, shipmentId, createdAt])
  @@index([shipmentId, currency])
  @@index([vendorSupplierId])
}

/// Multi-leg routing (ocean/air/truck segments) for Control Tower.
model CtShipmentLeg {
  id               String          @id @default(cuid())
  tenantId         String
  shipmentId       String
  legNo            Int             @default(1)
  originCode      String?
  destinationCode String?
  carrierSupplierId String?
  carrier          String?
  transportMode    TransportMode?
  plannedEtd       DateTime?
  plannedEta       DateTime?
  actualAtd        DateTime?
  actualAta        DateTime?
  notes            String?         @db.Text
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment  Shipment             @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  carrierSupplier Supplier?      @relation("CtLegCarrierSupplier", fields: [carrierSupplierId], references: [id], onDelete: SetNull)
  containers CtShipmentContainer[]

  @@unique([shipmentId, legNo])
  @@index([tenantId, shipmentId])
  @@index([carrierSupplierId])
}

model CtShipmentContainer {
  id               String    @id @default(cuid())
  tenantId         String
  shipmentId       String
  legId            String?
  containerNumber  String
  containerType    String?
  seal             String?
  status           String?
  gateInAt         DateTime?
  gateOutAt        DateTime?
  notes            String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment Shipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  leg      CtShipmentLeg? @relation(fields: [legId], references: [id], onDelete: SetNull)
  cargoLines CtContainerCargoLine[]

  @@index([shipmentId])
  @@index([tenantId, containerNumber])
  @@index([legId])
}

/// Quantities of a shipment line allocated to a specific container (stuffing / load plan).
model CtContainerCargoLine {
  id             String   @id @default(cuid())
  tenantId       String
  containerId    String
  shipmentItemId String
  /// Same unit as `ShipmentItem.quantityShipped` (order line UOM).
  quantity       Decimal  @db.Decimal(14, 3)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  container    CtShipmentContainer  @relation(fields: [containerId], references: [id], onDelete: Cascade)
  shipmentItem ShipmentItem         @relation(fields: [shipmentItemId], references: [id], onDelete: Cascade)

  @@unique([containerId, shipmentItemId])
  @@index([tenantId, containerId])
  @@index([shipmentItemId])
}

enum WarehouseType {
  CFS
  WAREHOUSE
}

enum LocationCodeType {
  UN_LOCODE
  PORT
  AIRPORT
}

model LocationCode {
  id          String           @id @default(cuid())
  tenantId    String
  type        LocationCodeType
  code        String
  name        String
  countryCode String?          @db.VarChar(2)
  subdivision String?
  source      String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, code])
  @@index([tenantId, type, isActive])
  @@index([tenantId, code])
}

model Warehouse {
  id           String        @id @default(cuid())
  tenantId     String
  code         String?
  name         String
  type         WarehouseType @default(CFS)
  addressLine1 String?
  city         String?
  region       String?
  countryCode  String?       @db.VarChar(2)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loadPlans LoadPlan[]
  zones     WarehouseZone[]
  bins      WarehouseBin[]
  inventoryBalances InventoryBalance[]
  inventoryMovements InventoryMovement[]
  wmsTasks  WmsTask[]
  wmsWaves  WmsWave[]
  replenishmentRules ReplenishmentRule[]
  outboundOrders OutboundOrder[]
  wmsBillingEvents WmsBillingEvent[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

enum WarehouseZoneType {
  RECEIVING
  PICKING
  RESERVE
  QUARANTINE
  STAGING
  SHIPPING
}

model WarehouseZone {
  id          String            @id @default(cuid())
  tenantId    String
  warehouseId String
  code        String
  name        String
  zoneType    WarehouseZoneType
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  bins      WarehouseBin[]
  sourceRules ReplenishmentRule[] @relation("ReplenishmentSourceZone")
  targetRules ReplenishmentRule[] @relation("ReplenishmentTargetZone")

  @@unique([warehouseId, code])
  @@index([tenantId, warehouseId, zoneType])
}

enum BinStorageType {
  PALLET
  FLOOR
  SHELF
  QUARANTINE
  STAGING
}

model WarehouseBin {
  id          String   @id @default(cuid())
  tenantId    String
  warehouseId String
  zoneId      String?
  code        String
  name        String
  storageType BinStorageType @default(PALLET)
  isPickFace  Boolean        @default(false)
  maxPallets  Int?
  /// Groups bins into one physical rack / bay run for layout maps (e.g. `R-A01`).
  rackCode       String? @db.VarChar(64)
  aisle          String? @db.VarChar(32)
  bay            String? @db.VarChar(32)
  /// 1-based shelf level (floor = 1) when using rack maps.
  level          Int?
  /// 1-based slot along the rack front (width axis) for grid columns.
  positionIndex  Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  zone      WarehouseZone? @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  inventoryBalances InventoryBalance[]
  inventoryMovements InventoryMovement[]
  wmsTasks WmsTask[]

  @@unique([warehouseId, code])
  @@index([tenantId, warehouseId])
  @@index([zoneId])
  @@index([warehouseId, rackCode])
}

model ReplenishmentRule {
  id             String   @id @default(cuid())
  tenantId       String
  warehouseId    String
  productId      String
  sourceZoneId   String?
  targetZoneId   String?
  minPickQty     Decimal  @db.Decimal(14, 3)
  maxPickQty     Decimal  @db.Decimal(14, 3)
  replenishQty   Decimal  @db.Decimal(14, 3)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  sourceZone  WarehouseZone? @relation("ReplenishmentSourceZone", fields: [sourceZoneId], references: [id], onDelete: SetNull)
  targetZone  WarehouseZone? @relation("ReplenishmentTargetZone", fields: [targetZoneId], references: [id], onDelete: SetNull)

  @@unique([warehouseId, productId])
  @@index([tenantId, warehouseId])
}

enum InventoryMovementType {
  RECEIPT
  PUTAWAY
  PICK
  ADJUSTMENT
  SHIPMENT
}

model InventoryBalance {
  id          String   @id @default(cuid())
  tenantId    String
  warehouseId String
  binId       String
  productId   String
  onHandQty   Decimal  @default(0) @db.Decimal(14, 3)
  allocatedQty Decimal @default(0) @db.Decimal(14, 3)
  /// QC / quarantine: when true, picks and wave allocation skip this bin-product row.
  onHold      Boolean  @default(false)
  holdReason  String?  @db.VarChar(500)
  updatedAt   DateTime @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  bin       WarehouseBin @relation(fields: [binId], references: [id], onDelete: Cascade)
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, binId, productId])
  @@index([tenantId, warehouseId])
}

model InventoryMovement {
  id             String               @id @default(cuid())
  tenantId       String
  warehouseId    String
  binId          String?
  productId      String
  movementType   InventoryMovementType
  quantity       Decimal              @db.Decimal(14, 3)
  referenceType  String?
  referenceId    String?
  note           String?
  createdById    String
  createdAt      DateTime             @default(now())

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  bin       WarehouseBin? @relation(fields: [binId], references: [id], onDelete: SetNull)
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  wmsBillingEvent WmsBillingEvent?

  @@index([tenantId, warehouseId, createdAt])
  @@index([referenceType, referenceId])
}

enum WmsBillingProfileSource {
  MANUAL
  CRM_ACCOUNT
}

enum WmsBillingInvoiceStatus {
  DRAFT
  POSTED
}

/// Tenant-defined unit price per inventory movement type (Phase B billing foundation).
model WmsBillingRate {
  id             String   @id @default(cuid())
  tenantId       String
  code           String
  description    String?
  movementType   InventoryMovementType?
  amountPerUnit  Decimal  @db.Decimal(14, 4)
  currency       String   @default("USD") @db.VarChar(3)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

/// Immutable billing fact derived from ops (`InventoryMovement`); amount snapshot at materialization.
model WmsBillingEvent {
  id                  String                  @id @default(cuid())
  tenantId            String
  profileSource       WmsBillingProfileSource @default(MANUAL)
  /// When set, ties the charge to a 3PL owner (from linked outbound or future inbound rules).
  crmAccountId        String?
  inventoryMovementId String?               @unique
  movementType        InventoryMovementType
  warehouseId         String
  productId           String
  quantity            Decimal                 @db.Decimal(14, 3)
  rateCode            String
  unitRate            Decimal                 @db.Decimal(14, 4)
  amount              Decimal                 @db.Decimal(14, 2)
  currency            String                  @default("USD") @db.VarChar(3)
  occurredAt          DateTime
  invoiceRunId        String?
  createdAt           DateTime                @default(now())

  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse         Warehouse            @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product           Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  crmAccount        CrmAccount?          @relation(fields: [crmAccountId], references: [id], onDelete: SetNull)
  inventoryMovement InventoryMovement?   @relation(fields: [inventoryMovementId], references: [id], onDelete: SetNull)
  invoiceRun        WmsBillingInvoiceRun? @relation(fields: [invoiceRunId], references: [id], onDelete: SetNull)

  @@index([tenantId, occurredAt])
  @@index([tenantId, invoiceRunId])
  @@index([tenantId, crmAccountId])
}

model WmsBillingInvoiceRun {
  id            String                  @id @default(cuid())
  tenantId      String
  runNo         String
  profileSource WmsBillingProfileSource @default(MANUAL)
  periodFrom    DateTime
  periodTo      DateTime
  status        WmsBillingInvoiceStatus @default(DRAFT)
  totalAmount   Decimal                 @db.Decimal(14, 2)
  currency      String                  @default("USD") @db.VarChar(3)
  csvSnapshot   String?                 @db.Text
  createdById   String
  createdAt     DateTime                @default(now())

  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User                    @relation("WmsBillingInvoiceRunCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lines     WmsBillingInvoiceLine[]
  events    WmsBillingEvent[]

  @@unique([tenantId, runNo])
  @@index([tenantId, createdAt])
}

model WmsBillingInvoiceLine {
  id           String   @id @default(cuid())
  tenantId     String
  invoiceRunId String
  lineNo       Int
  description  String
  quantity     Decimal  @db.Decimal(14, 3)
  unitAmount   Decimal  @db.Decimal(14, 4)
  lineAmount   Decimal  @db.Decimal(14, 2)

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceRun WmsBillingInvoiceRun @relation(fields: [invoiceRunId], references: [id], onDelete: Cascade)

  @@unique([invoiceRunId, lineNo])
  @@index([tenantId, invoiceRunId])
}

enum WmsTaskType {
  PUTAWAY
  PICK
  REPLENISH
  CYCLE_COUNT
}

enum WmsTaskStatus {
  OPEN
  DONE
  CANCELLED
}

enum WmsWaveStatus {
  OPEN
  RELEASED
  DONE
  CANCELLED
}

model WmsWave {
  id          String        @id @default(cuid())
  tenantId    String
  warehouseId String
  waveNo      String
  status      WmsWaveStatus @default(OPEN)
  note        String?
  createdById String
  releasedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  tasks     WmsTask[]

  @@unique([tenantId, waveNo])
  @@index([tenantId, warehouseId, status])
}

model WmsTask {
  id            String       @id @default(cuid())
  tenantId      String
  warehouseId   String
  taskType      WmsTaskType
  status        WmsTaskStatus @default(OPEN)
  shipmentId    String?
  orderId       String?
  waveId        String?
  productId     String?
  binId         String?
  referenceType String?
  referenceId   String?
  quantity      Decimal      @default(0) @db.Decimal(14, 3)
  note          String?
  createdById   String
  completedById String?
  completedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  shipment    Shipment?    @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  order       PurchaseOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  wave        WmsWave?     @relation(fields: [waveId], references: [id], onDelete: SetNull)
  product     Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  bin         WarehouseBin? @relation(fields: [binId], references: [id], onDelete: SetNull)
  createdBy   User         @relation("WmsTaskCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  completedBy User?        @relation("WmsTaskCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([tenantId, warehouseId, status, taskType])
  @@index([referenceType, referenceId])
  @@index([waveId])
}

enum OutboundOrderStatus {
  DRAFT
  RELEASED
  PICKING
  PACKED
  SHIPPED
  CANCELLED
}

model OutboundOrder {
  id            String              @id @default(cuid())
  tenantId      String
  warehouseId   String
  outboundNo    String
  customerRef   String?
  shipToName    String?
  shipToLine1   String?
  shipToCity    String?
  shipToCountryCode String? @db.VarChar(2)
  requestedShipDate DateTime?
  status        OutboundOrderStatus @default(DRAFT)
  notes         String?
  /** Optional 3PL owner / bill-to CRM account (same tenant). */
  crmAccountId  String?
  createdById   String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  crmAccount  CrmAccount? @relation(fields: [crmAccountId], references: [id], onDelete: SetNull)
  createdBy   User        @relation(fields: [createdById], references: [id], onDelete: Restrict)
  lines       OutboundOrderLine[]

  @@unique([tenantId, outboundNo])
  @@index([tenantId, warehouseId, status])
  @@index([tenantId, crmAccountId])
}

model OutboundOrderLine {
  id             String   @id @default(cuid())
  tenantId       String
  outboundOrderId String
  lineNo         Int
  productId      String
  quantity       Decimal  @db.Decimal(14, 3)
  pickedQty      Decimal  @default(0) @db.Decimal(14, 3)
  packedQty      Decimal  @default(0) @db.Decimal(14, 3)
  shippedQty     Decimal  @default(0) @db.Decimal(14, 3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outboundOrder OutboundOrder @relation(fields: [outboundOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([outboundOrderId, lineNo])
  @@index([tenantId, outboundOrderId])
}

enum LoadPlanStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

enum ContainerSize {
  LCL
  FCL_20
  FCL_40
  FCL_40HC
  TRUCK_13_6
  AIR_ULD
}

model LoadPlan {
  id          String         @id @default(cuid())
  tenantId    String
  reference   String
  warehouseId String
  transportMode TransportMode @default(OCEAN)
  containerSize ContainerSize @default(LCL)
  plannedEta  DateTime?
  status      LoadPlanStatus @default(DRAFT)
  notes       String?
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  createdBy    User               @relation(fields: [createdById], references: [id], onDelete: Restrict)
  assignments  LoadPlanShipment[]

  @@unique([tenantId, reference])
  @@index([tenantId, createdAt])
  @@index([warehouseId])
}

model LoadPlanShipment {
  id         String   @id @default(cuid())
  loadPlanId String
  shipmentId String   @unique
  createdAt  DateTime @default(now())

  loadPlan LoadPlan @relation(fields: [loadPlanId], references: [id], onDelete: Cascade)
  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([loadPlanId, shipmentId])
  @@index([loadPlanId])
}

enum SplitProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model SplitProposal {
  id               String              @id @default(cuid())
  parentOrderId    String
  status           SplitProposalStatus @default(PENDING)
  version          Int                 @default(1)
  proposedByUserId String
  comment          String?
  createdAt        DateTime            @default(now())
  resolvedAt       DateTime?

  parentOrder    PurchaseOrder       @relation("SplitProposalParent", fields: [parentOrderId], references: [id], onDelete: Cascade)
  proposedBy     User                @relation(fields: [proposedByUserId], references: [id], onDelete: Restrict)
  lines          SplitProposalLine[]
  draftChildOrders PurchaseOrder[]   @relation("SplitProposalDraftOrders")

  @@index([parentOrderId])
  @@index([status])
}

model SplitProposalLine {
  id              String   @id @default(cuid())
  proposalId      String
  sourceLineId    String
  quantity        Decimal  @db.Decimal(14, 3)
  plannedShipDate DateTime
  childIndex      Int

  proposal   SplitProposal      @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  sourceLine PurchaseOrderItem  @relation(fields: [sourceLineId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([sourceLineId])
}

model OrderTransitionLog {
  id           String   @id @default(cuid())
  orderId      String
  fromStatusId String?
  toStatusId   String
  actionCode   String
  actorUserId  String
  comment      String?
  createdAt    DateTime @default(now())

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor User          @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
}

model OrderChatMessage {
  id           String   @id @default(cuid())
  orderId      String
  authorUserId String
  body         String
  isInternal   Boolean  @default(true)
  createdAt    DateTime @default(now())

  order  PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
}

// --- Logistics CRM (R1 core entities; tenant-scoped, aligned with docs/crm PDFs) ---

enum CrmLeadStatus {
  NEW
  WORKING
  QUALIFIED
  DISQUALIFIED
  CONVERTED
}

enum CrmAccountType {
  CUSTOMER
  PROSPECT
  PARTNER
  AGENT
  OTHER
}

enum CrmAccountLifecycle {
  ACTIVE
  INACTIVE
}

enum CrmOpportunityStage {
  IDENTIFIED
  QUALIFIED
  DISCOVERY
  SOLUTION_DESIGN
  PROPOSAL_SUBMITTED
  NEGOTIATION
  VERBAL_AGREEMENT
  WON_IMPLEMENTATION_PENDING
  WON_LIVE
  LOST
  ON_HOLD
}

enum CrmActivityType {
  TASK
  CALL
  MEETING
  NOTE
  EMAIL
}

enum CrmQuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model CrmLead {
  id        String @id @default(cuid())
  tenantId  String
  ownerUserId String

  companyName       String
  contactFirstName  String?
  contactLastName   String?
  contactEmail      String?
  contactPhone      String?
  status            CrmLeadStatus @default(NEW)
  source            String        @default("MANUAL")
  serviceInterest   String?
  qualificationNotes String?      @db.Text
  estimatedAnnualSpend Decimal?   @db.Decimal(14, 2)
  targetStartDate   DateTime?

  convertedAt         DateTime?
  convertedAccountId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner    User   @relation("CrmLeadOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, status])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, createdAt])
}

model CrmAccount {
  id         String @id @default(cuid())
  tenantId   String
  ownerUserId String

  name       String
  legalName  String?
  website    String?
  accountType CrmAccountType @default(PROSPECT)
  lifecycle CrmAccountLifecycle @default(ACTIVE)
  industry  String?
  segment   String?
  strategicFlag Boolean @default(false)

  parentAccountId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner    User   @relation("CrmAccountOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  parent   CrmAccount?  @relation("CrmAccountHierarchy", fields: [parentAccountId], references: [id], onDelete: SetNull)
  children CrmAccount[] @relation("CrmAccountHierarchy")

  contacts      CrmContact[]
  opportunities CrmOpportunity[]
  activities    CrmActivity[] @relation("CrmActivityAccount")
  quotes          CrmQuote[]
  outboundOrders OutboundOrder[]
  wmsBillingEvents WmsBillingEvent[]
  shipmentsAsCustomer Shipment[] @relation("ShipmentCustomerAccount")
  salesOrders         SalesOrder[]
  customerPortalUsers User[] @relation("UserCustomerPortalScope")

  @@index([tenantId, lifecycle])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, name])
}

model CrmContact {
  id         String @id @default(cuid())
  tenantId   String
  accountId  String
  ownerUserId String

  firstName   String
  lastName    String
  email       String?
  phone       String?
  title       String?
  department  String?
  decisionRole String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account      CrmAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  owner        User   @relation("CrmContactOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  primaryFor   CrmOpportunity[] @relation("CrmOpportunityPrimaryContact")
  activities   CrmActivity[] @relation("CrmActivityContact")

  @@index([tenantId, accountId])
  @@index([tenantId, email])
}

model CrmOpportunity {
  id         String @id @default(cuid())
  tenantId   String
  accountId  String
  ownerUserId String
  primaryContactId String?

  name        String
  stage       CrmOpportunityStage @default(IDENTIFIED)
  probability Int                 @default(10)
  forecastCategory String?
  estimatedRevenue    Decimal? @db.Decimal(14, 2)
  estimatedNetRevenue Decimal? @db.Decimal(14, 2)
  currency    String? @db.VarChar(3)
  closeDate   DateTime?
  nextStep    String? @db.Text
  nextStepDate DateTime?
  competitorName String?
  lostReason  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account  CrmAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  owner    User   @relation("CrmOpportunityOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  primaryContact CrmContact? @relation("CrmOpportunityPrimaryContact", fields: [primaryContactId], references: [id], onDelete: SetNull)
  activities CrmActivity[] @relation("CrmActivityOpportunity")
  quotes     CrmQuote[]

  @@index([tenantId, stage])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, accountId])
  @@index([tenantId, closeDate])
}

model CrmActivity {
  id         String @id @default(cuid())
  tenantId   String
  ownerUserId String

  type    CrmActivityType
  subject String
  body    String? @db.Text
  status  String  @default("OPEN")

  dueDate    DateTime?
  startTime  DateTime?
  endTime    DateTime?

  relatedAccountId     String?
  relatedContactId     String?
  relatedOpportunityId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner        User   @relation("CrmActivityOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  relatedAccount     CrmAccount?     @relation("CrmActivityAccount", fields: [relatedAccountId], references: [id], onDelete: SetNull)
  relatedContact     CrmContact?     @relation("CrmActivityContact", fields: [relatedContactId], references: [id], onDelete: SetNull)
  relatedOpportunity CrmOpportunity? @relation("CrmActivityOpportunity", fields: [relatedOpportunityId], references: [id], onDelete: SetNull)

  @@index([tenantId, ownerUserId])
  @@index([tenantId, dueDate])
  @@index([relatedAccountId])
  @@index([relatedOpportunityId])
}

model CrmQuote {
  id              String          @id @default(cuid())
  tenantId        String
  ownerUserId     String
  accountId       String
  opportunityId   String?

  title           String
  status          CrmQuoteStatus  @default(DRAFT)
  quoteNumber     String?
  validUntil      DateTime?
  currency        String          @default("USD") @db.VarChar(3)
  notes           String?         @db.Text
  subtotal        Decimal?        @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User           @relation("CrmQuoteOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  account     CrmAccount     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  opportunity CrmOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  lines       CrmQuoteLine[]

  @@index([tenantId, accountId])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, status])
}

model CrmQuoteLine {
  id             String   @id @default(cuid())
  quoteId        String
  sortOrder      Int      @default(0)
  description    String
  quantity       Decimal  @db.Decimal(14, 4)
  unitPrice      Decimal  @db.Decimal(14, 4)
  extendedAmount Decimal? @db.Decimal(14, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quote CrmQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

// --- Tariff engine (Phase 1): tables mapped to starter-pack names; tenant = existing Tenant ---

enum TariffProviderType {
  OCEAN_CARRIER
  NVOCC
  FORWARDER
  AIRLINE
  TRUCKER
  RAIL_OPERATOR
  WAREHOUSE
  BROKER
  COURIER
  OTHER
}

/// Distinct from logistics `TransportMode` on Shipment — tariff contract / charge scope.
enum TariffTransportMode {
  OCEAN
  LCL
  AIR
  TRUCK
  RAIL
  LOCAL_SERVICE
}

enum TariffContractStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  EXPIRED
  SUPERSEDED
  ARCHIVED
}

enum TariffSourceType {
  MANUAL
  EXCEL
  PDF
  API
  EDI
  EMAIL
  SYSTEM
}

enum TariffApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

enum QuoteRequestStatus {
  DRAFT
  OPEN
  CLOSED
  AWARDED
  CANCELLED
}

enum QuoteRecipientInvitationStatus {
  PENDING
  INVITED
  DECLINED
  RESPONDED
}

enum QuoteResponseStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  AWARDED
  REJECTED
  WITHDRAWN
}

enum QuoteClarificationVisibility {
  INTERNAL
  RECIPIENTS
}

enum PricingSnapshotSourceType {
  TARIFF_CONTRACT_VERSION
  QUOTE_RESPONSE
  /// Sum of multiple contract versions (e.g. forwarder + pre-carriage + ocean); see breakdownJson.components.
  COMPOSITE_CONTRACT_VERSION
}

enum TariffGeographyType {
  GLOBAL_REGION
  SUBREGION
  COUNTRY
  PORT
  INLAND_POINT
  RAIL_RAMP
  ZONE
  ALIAS_GROUP
}

enum TariffLineRateType {
  BASE_RATE
  ALL_IN
  GATE_IN
  GATE_IN_ALL_IN
  GATE_IN_GATE_OUT
  ADD_ON
  LOCAL_CHARGE
  SURCHARGE
  CUSTOMS
  PRE_CARRIAGE
  ON_CARRIAGE
}

enum TariffChargeFamily {
  MAIN_CARRIAGE
  FUEL_ENVIRONMENTAL
  SEASONAL_EMERGENCY
  ORIGIN_TERMINAL
  DEST_TERMINAL
  ORIGIN_INLAND
  DEST_INLAND
  CUSTOMS_REGULATORY
  HANDLING_SPECIAL
  FREE_TIME_DELAY
  ADMIN_OTHER
}

enum TariffRuleType {
  DEMURRAGE
  DETENTION
  COMBINED_DD
  STORAGE
  PLUGIN
  OTHER
}

model TariffLegalEntity {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  code         String?
  countryCode  String?  @db.VarChar(2)
  baseCurrency String?  @db.VarChar(3)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractHeaders TariffContractHeader[]
  importBatches   TariffImportBatch[]

  @@index([tenantId])
  @@map("legal_entities")
}

model TariffProvider {
  id           String             @id @default(cuid())
  legalName    String
  tradingName  String?
  providerType TariffProviderType
  countryCode  String?            @db.VarChar(2)
  status       String             @default("ACTIVE")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  chargeAliases   TariffChargeAlias[]
  contractHeaders TariffContractHeader[]

  @@map("providers")
}

model TariffGeographyGroup {
  id            String              @id @default(cuid())
  geographyType TariffGeographyType
  name          String
  code          String?
  aliasSource   String?
  validFrom     DateTime?           @db.Date
  validTo       DateTime?           @db.Date
  active        Boolean             @default(true)
  createdAt     DateTime            @default(now())

  members                TariffGeographyMember[]
  rateLinesAsOrigin      TariffRateLine[]      @relation("TariffRateLineOrigin")
  rateLinesAsDestination TariffRateLine[]      @relation("TariffRateLineDestination")
  chargeLines            TariffChargeLine[]
  freeTimeRules          TariffFreeTimeRule[]

  @@map("geography_groups")
}

model TariffGeographyMember {
  id               String              @id @default(cuid())
  geographyGroupId String
  memberCode       String
  memberName       String?
  memberType       TariffGeographyType
  validFrom        DateTime?           @db.Date
  validTo          DateTime?           @db.Date

  geographyGroup TariffGeographyGroup @relation(fields: [geographyGroupId], references: [id], onDelete: Cascade)

  @@index([geographyGroupId])
  @@map("geography_members")
}

model TariffNormalizedChargeCode {
  id              String               @id @default(cuid())
  code            String               @unique
  displayName     String
  chargeFamily    TariffChargeFamily
  transportMode   TariffTransportMode?
  isLocalCharge   Boolean              @default(false)
  isSurcharge     Boolean              @default(false)
  active          Boolean              @default(true)
  createdAt       DateTime             @default(now())

  aliases     TariffChargeAlias[]
  chargeLines TariffChargeLine[]

  @@map("normalized_charge_codes")
}

model TariffChargeAlias {
  id                     String @id @default(cuid())
  normalizedChargeCodeId String
  aliasText              String
  providerId             String?
  notes                  String? @db.Text

  normalizedChargeCode TariffNormalizedChargeCode @relation(fields: [normalizedChargeCodeId], references: [id], onDelete: Cascade)
  provider               TariffProvider?            @relation(fields: [providerId], references: [id], onDelete: SetNull)

  @@index([normalizedChargeCodeId])
  @@index([providerId])
  @@map("charge_aliases")
}

model TariffContractHeader {
  id             String              @id @default(cuid())
  tenantId       String
  legalEntityId  String?
  providerId     String
  transportMode  TariffTransportMode
  contractNumber String?
  title          String
  tradeScope     String?             @db.Text
  status         TariffContractStatus @default(DRAFT)
  ownerUserId    String?
  notes          String?             @db.Text
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalEntity  TariffLegalEntity?  @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  provider     TariffProvider      @relation(fields: [providerId], references: [id], onDelete: Restrict)
  owner        User?               @relation("TariffContractHeaderOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  versions     TariffContractVersion[]

  @@index([tenantId])
  @@index([providerId])
  @@map("contract_headers")
}

model TariffContractVersion {
  id                   String               @id @default(cuid())
  contractHeaderId     String
  versionNo            Int
  sourceType           TariffSourceType
  sourceReference      String?
  sourceFileUrl        String?
  approvalStatus       TariffApprovalStatus @default(PENDING)
  status               TariffContractStatus @default(DRAFT)
  validFrom            DateTime?            @db.Date
  validTo              DateTime?            @db.Date
  bookingDateValidFrom DateTime?            @db.Date
  bookingDateValidTo   DateTime?            @db.Date
  sailingDateValidFrom DateTime?            @db.Date
  sailingDateValidTo   DateTime?            @db.Date
  comments             String?              @db.Text
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  contractHeader TariffContractHeader @relation(fields: [contractHeaderId], references: [id], onDelete: Cascade)
  rateLines      TariffRateLine[]
  chargeLines    TariffChargeLine[]
  freeTimeRules  TariffFreeTimeRule[]
  shipmentApplications TariffShipmentApplication[]

  @@unique([contractHeaderId, versionNo])
  @@index([contractHeaderId])
  @@index([validFrom, validTo])
  @@map("contract_versions")
}

model TariffRateLine {
  id                  String             @id @default(cuid())
  contractVersionId   String
  originScopeId       String?
  destinationScopeId  String?
  rateType            TariffLineRateType
  equipmentType       String?
  commodityScope      String?            @db.Text
  serviceScope        String?            @db.Text
  unitBasis           String
  currency            String             @db.VarChar(3)
  amount              Decimal            @db.Decimal(18, 4)
  includedChargeSet Json?
  excludedChargeSet Json?
  rawRateDescription  String?            @db.Text
  validFrom           DateTime?          @db.Date
  validTo             DateTime?          @db.Date
  notes               String?            @db.Text

  contractVersion  TariffContractVersion @relation(fields: [contractVersionId], references: [id], onDelete: Cascade)
  originScope      TariffGeographyGroup? @relation("TariffRateLineOrigin", fields: [originScopeId], references: [id], onDelete: SetNull)
  destinationScope TariffGeographyGroup? @relation("TariffRateLineDestination", fields: [destinationScopeId], references: [id], onDelete: SetNull)

  @@index([contractVersionId])
  @@map("rate_lines")
}

model TariffChargeLine {
  id                     String  @id @default(cuid())
  contractVersionId      String
  normalizedChargeCodeId String?
  rawChargeName          String
  geographyScopeId       String?
  directionScope         String?
  equipmentScope         String?
  conditionScope         String?
  unitBasis              String
  currency               String  @db.VarChar(3)
  amount                 Decimal @db.Decimal(18, 4)
  isIncluded             Boolean @default(false)
  isMandatory            Boolean @default(true)
  validFrom              DateTime? @db.Date
  validTo                DateTime? @db.Date
  notes                  String?   @db.Text

  contractVersion      TariffContractVersion      @relation(fields: [contractVersionId], references: [id], onDelete: Cascade)
  normalizedChargeCode TariffNormalizedChargeCode? @relation(fields: [normalizedChargeCodeId], references: [id], onDelete: SetNull)
  geographyScope       TariffGeographyGroup?      @relation(fields: [geographyScopeId], references: [id], onDelete: SetNull)

  @@index([contractVersionId])
  @@map("charge_lines")
}

model TariffFreeTimeRule {
  id                 String         @id @default(cuid())
  contractVersionId  String
  geographyScopeId   String?
  importExportScope  String?
  equipmentScope     String?
  ruleType           TariffRuleType
  freeDays           Int
  validFrom          DateTime?      @db.Date
  validTo            DateTime?      @db.Date
  notes              String?        @db.Text

  contractVersion TariffContractVersion @relation(fields: [contractVersionId], references: [id], onDelete: Cascade)
  geographyScope  TariffGeographyGroup? @relation(fields: [geographyScopeId], references: [id], onDelete: SetNull)

  @@index([contractVersionId])
  @@map("free_time_rules")
}

model TariffImportBatch {
  id               String           @id @default(cuid())
  tenantId         String?
  legalEntityId    String?
  sourceType       TariffSourceType
  uploadedFilename String?
  sourceReference  String?
  /** Stored file URL (Vercel Blob or dev /uploads/tariffs/...). */
  sourceFileUrl    String?          @db.Text
  sourceMimeType   String?
  sourceByteSize   Int?
  /** Original client metadata: checksum, headers, uploader id, etc. */
  sourceMetadata   Json?
  parseStatus      String           @default("UPLOADED")
  confidenceScore  Decimal?         @db.Decimal(5, 2)
  reviewStatus     String           @default("PENDING")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant       Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  legalEntity  TariffLegalEntity? @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  stagingRows  TariffImportStagingRow[]

  @@index([tenantId])
  @@map("import_batches")
}

model TariffImportStagingRow {
  id                String   @id @default(cuid())
  importBatchId     String
  rowType           String
