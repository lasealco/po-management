/**
 * Hierarchical org chart inside a tenant (global HQ → region → country → site, etc.).
 * Does not replace `ProductDivision` (product / commercial matrix); use both via `User`.
 */
model OrgUnit {
  id        String      @id @default(cuid())
  tenantId  String
  parentId  String?
  name      String
  /// Unique per tenant (e.g. GLOBAL, APAC, US, US-TX-HOU)
  code      String
  kind      OrgUnitKind
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tenant                      Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent                      OrgUnit?                     @relation("OrgUnitHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children                    OrgUnit[]                    @relation("OrgUnitHierarchy")
  usersPrimary                User[]                       @relation("UserPrimaryOrgUnit")
  roleAssignments             OrgUnitRoleAssignment[]
  servedOnPurchaseOrders      PurchaseOrder[]              @relation("PurchaseOrderServedOrg")
  servedOnSalesOrders         SalesOrder[]                 @relation("SalesOrderServedOrg")
  /// Statutory / document profile (optional; Phase 1). Distinct from `TariffLegalEntity` (tariff pricing).
  companyLegalEntity          CompanyLegalEntity?
  companyLegalEntityAuditLogs CompanyLegalEntityAuditLog[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, parentId])
  @@index([parentId])
}

/**
 * In-tenant statutory / document identity for a single org node (typically `OrgUnitKind.LEGAL_ENTITY`).
 * Used for sales / contracting footers, invoicing, and regional admin; not the same as `TariffLegalEntity`
 * (tariff contracts, table `legal_entities`). At most one row per `orgUnitId`.
 */
model CompanyLegalEntity {
  id        String @id @default(cuid())
  tenantId  String
  /// Org node this legal profile extends (1:1). Kind `LEGAL_ENTITY` is enforced in application/API layers.
  orgUnitId String @unique

  registeredLegalName String
  tradeName           String?
  /// VAT / USt-IdNr. / etc. (format validation in later phases)
  taxVatId            String?
  taxLocalId          String?

  addressLine1       String?
  addressLine2       String?
  addressCity        String?
  addressRegion      String?
  addressPostalCode  String?
  addressCountryCode String? @db.VarChar(2)
  phone              String?
  companyEmail       String?

  effectiveFrom DateTime? @db.Date
  effectiveTo   DateTime? @db.Date
  /// ACTIVE | INACTIVE
  status        String    @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orgUnit   OrgUnit                      @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)
  auditLogs CompanyLegalEntityAuditLog[]

  @@index([tenantId])
  @@map("company_legal_entities")
}

/// Append-only history for company legal profile changes (Phase 5).
model CompanyLegalEntityAuditLog {
  id                   String   @id @default(cuid())
  tenantId             String
  companyLegalEntityId String?
  orgUnitId            String
  actorUserId          String
  /// CREATE | UPDATE | DELETE
  action               String
  metadata             Json?
  createdAt            DateTime @default(now())

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orgUnit            OrgUnit             @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)
  companyLegalEntity CompanyLegalEntity? @relation(fields: [companyLegalEntityId], references: [id], onDelete: SetNull)
  actor              User                @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@index([orgUnitId])
  @@index([companyLegalEntityId])
  @@index([actorUserId])
  @@map("company_legal_entity_audit_logs")
}

/// Zero or more operating-role tags per org unit (unique per org + role).
model OrgUnitRoleAssignment {
  id        String               @id @default(cuid())
  orgUnitId String
  role      OrgUnitOperatingRole
  createdAt DateTime             @default(now())

  orgUnit OrgUnit @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)

  @@unique([orgUnitId, role])
  @@index([orgUnitId])
  @@map("org_unit_role_assignments")
}

/**
 * Matrix: user responsibility for one or more product divisions (e.g. global category lead).
 */
model UserProductDivision {
  userId            String
  productDivisionId String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  productDivision   ProductDivision @relation(fields: [productDivisionId], references: [id], onDelete: Cascade)

  @@id([userId, productDivisionId])
  @@index([productDivisionId])
}

/// Single-use email link to reset a password; raw token is never stored.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model UserPreference {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  key       String
