/// Which product domain a saved report belongs to (unified reporting; engines vary by dataset).
enum ReportDataset {
  CONTROL_TOWER
  PO
  CRM
  WMS
}

model CtSavedReport {
  id          String         @id @default(cuid())
  tenantId    String
  userId      String
