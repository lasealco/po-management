/// AMP17: cross-module incident command room with linked evidence, blast radius, playbook, and closure notes.
model AssistantExceptionIncident {
  id                     String    @id @default(cuid())
  tenantId               String
  createdByUserId        String?
  title                  String
  status                 String    @default("OPEN") @db.VarChar(32)
  severity               String    @default("MEDIUM") @db.VarChar(16)
  incidentKey            String    @db.VarChar(256)
  severityScore          Int       @default(0)
  sourceSummaryJson      Json
  linkedObjectsJson      Json
  blastRadiusJson        Json
  timelineJson           Json
  playbookJson           Json
  communicationDraftJson Json
  customerImpact         String?   @db.Text
  rootCauseNote          String?   @db.Text
  actionQueueItemId      String?
  mergedIntoIncidentId   String?
  splitFromIncidentId    String?
  closedAt               DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User?  @relation("AssistantExceptionIncidentCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, severity, updatedAt])
  @@index([tenantId, incidentKey])
  @@index([tenantId, mergedIntoIncidentId])
}

/// AMP18: customer/account intelligence brief with redacted evidence and logged customer-ready reply draft.
model AssistantCustomerBrief {
  id                    String    @id @default(cuid())
  tenantId              String
  crmAccountId          String
  createdByUserId       String?
  approvedByUserId      String?
  title                 String
  status                String    @default("DRAFT") @db.VarChar(32)
