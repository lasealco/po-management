generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  roles             Role[]
  suppliers         Supplier[]
  products          Product[]
  productCategories ProductCategory[]
  productDivisions  ProductDivision[]
  supplierOffices   SupplierOffice[]
  supplierContacts  SupplierContact[]
  orders            PurchaseOrder[]
  warehouses        Warehouse[]
  loadPlans         LoadPlan[]
  userPreferences   UserPreference[]
  workflows         Workflow[]
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  name      String
  passwordHash String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles           UserRole[]
  orderChats          OrderChatMessage[]
  purchaseOrders      PurchaseOrder[]
  orderTransitionLogs OrderTransitionLog[]
  splitProposals      SplitProposal[]
  shipmentsCreated    Shipment[]
  loadPlansCreated    LoadPlan[]
  preferences         UserPreference[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model UserPreference {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([tenantId, key])
}

model Role {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id               String  @id @default(cuid())
  roleId           String
  resource         String
  action           String
  effect           String
  workflowStatusId String?

  role           Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  workflowStatus WorkflowStatus? @relation(fields: [workflowStatusId], references: [id], onDelete: SetNull)

  @@unique([roleId, resource, action, workflowStatusId])
  @@index([roleId])
  @@index([workflowStatusId])
}

model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  code      String?
  name      String
  email     String?
  phone     String?
  isActive  Boolean  @default(true)

  /// Legal / registered business name if different from trade name.
  legalName String?
  /// VAT, EIN, company registration, etc.
  taxId     String?
  website   String?

  registeredAddressLine1 String?
  registeredAddressLine2 String?
  registeredCity         String?
  registeredRegion       String?
  registeredPostalCode   String?
  registeredCountryCode  String? @db.VarChar(2)

  /// e.g. 30 for Net 30; use with paymentTermsLabel.
  paymentTermsDays   Int?
  paymentTermsLabel  String?
  creditLimit        Decimal? @db.Decimal(14, 2)
  creditCurrency     String?  @db.VarChar(3)
  defaultIncoterm    String?
  internalNotes      String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders           PurchaseOrder[]
  offices          SupplierOffice[]
  contacts         SupplierContact[]
  productSuppliers ProductSupplier[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

/// People at the supplier (sales, AP, operations).
model SupplierContact {
  id         String   @id @default(cuid())
  tenantId   String
  supplierId String
  name       String
  title      String?
  /// e.g. Sales, Accounts payable, Quality
  role       String?
  email      String?
  phone      String?
  notes      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([supplierId])
}

/// Buyer-facing catalog category (Settings → category management).
model ProductCategory {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String?
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Organizational division for reporting and filters.
model ProductDivision {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Supplier office / site used on the product form (dropdown).
model SupplierOffice {
  id           String   @id @default(cuid())
  tenantId     String
  supplierId   String
  name         String
  addressLine1 String?
  addressLine2 String?
  city         String?
  region       String?
  postalCode   String?
  countryCode  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([supplierId, name])
  @@index([tenantId])
  @@index([supplierId])
}

model Product {
  id          String  @id @default(cuid())
  tenantId    String
  /// Shown as “product code” in the legacy UI (e.g. BC-CB40).
  productCode String?
  sku         String?
  name        String
  description String? @db.VarChar(2000)
  unit        String?

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  divisionId String?
  division   ProductDivision? @relation(fields: [divisionId], references: [id], onDelete: SetNull)

  ean           String? @db.VarChar(32)
  customerName  String? @db.Text
  /// Legacy “product image” until blob storage is wired; can be a CDN URL.
  primaryImageUrl String?
  hsCode        String?

  isDangerousGoods    Boolean @default(false)
  dangerousGoodsClass String?
  unNumber            String?
  properShippingName  String?
  packingGroup        String?
  flashPoint          Decimal? @db.Decimal(10, 2)
  flashPointUnit      String?
  msdsUrl             String?

  isTemperatureControlled Boolean @default(false)
  temperatureRangeText    String?
  temperatureUnit       String?
  coolingType           String?
  packagingNotes        String? @db.Text
  humidityRequirements  String?
  storageDescription    String? @db.Text
  isForReexport         Boolean @default(false)

  supplierOfficeId String?
  supplierOffice   SupplierOffice? @relation(fields: [supplierOfficeId], references: [id], onDelete: SetNull)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItems     PurchaseOrderItem[]
  documents      ProductDocument[]
  productSuppliers ProductSupplier[]

  @@unique([tenantId, sku])
  @@unique([tenantId, productCode])
  @@index([tenantId])
  @@index([categoryId])
  @@index([divisionId])
}

/// Which suppliers can supply this SKU (legacy “Suppliers: N” column).
model ProductSupplier {
  productId  String
  supplierId String
  createdAt  DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([productId, supplierId])
  @@index([supplierId])
}

enum ProductDocumentKind {
  PRIMARY_IMAGE
  MSDS
  OTHER
}

/// File metadata; `url` holds a storage URL (S3, Vercel Blob, etc.) when uploads exist.
model ProductDocument {
  id        String              @id @default(cuid())
  productId String
  kind      ProductDocumentKind @default(OTHER)
  fileName  String
  url       String
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime            @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Workflow {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  code             String
  isDefault        Boolean  @default(false)
  supplierPortalOn Boolean  @default(false)
  allowSplitOrders Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  statuses    WorkflowStatus[]
  transitions WorkflowTransition[]
  actions     WorkflowAction[]
  orders      PurchaseOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model WorkflowStatus {
  id         String   @id @default(cuid())
  workflowId String
  code       String
  label      String
  category   String?
  isStart    Boolean  @default(false)
  isEnd      Boolean  @default(false)
  sortOrder  Int
  createdAt  DateTime @default(now())

  workflow        Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromTransitions WorkflowTransition[] @relation("FromStatus")
  toTransitions   WorkflowTransition[] @relation("ToStatus")
  orders          PurchaseOrder[]
  permissions     RolePermission[]

  @@unique([workflowId, code])
  @@index([workflowId, sortOrder])
}

model WorkflowTransition {
  id              String  @id @default(cuid())
  workflowId      String
  fromStatusId    String
  toStatusId      String
  actionCode      String
  label           String
  requiresComment Boolean @default(false)

  workflow   Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromStatus WorkflowStatus @relation("FromStatus", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus   WorkflowStatus @relation("ToStatus", fields: [toStatusId], references: [id], onDelete: Cascade)

  @@unique([workflowId, fromStatusId, toStatusId, actionCode])
  @@index([workflowId, fromStatusId])
}

model WorkflowAction {
  id         String  @id @default(cuid())
  workflowId String
  code       String
  label      String
  isEnabled  Boolean @default(true)

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, code])
  @@index([workflowId])
}

model PurchaseOrder {
  id            String   @id @default(cuid())
  tenantId      String
  workflowId    String
  orderNumber   String
  title         String?
  requesterId   String
  supplierId    String?
  statusId      String
  currency      String   @default("USD")
  subtotal      Decimal  @db.Decimal(14, 2)
  taxAmount     Decimal  @db.Decimal(14, 2)
  totalAmount   Decimal  @db.Decimal(14, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  splitParentId String?
  splitIndex    Int?
  splitProposalId String?

  /// Buyer / internal reference (e.g. requisition #).
  buyerReference    String?
  /// Supplier acknowledgment or their order #.
  supplierReference String?
  paymentTermsDays   Int?
  paymentTermsLabel  String?
  incoterm           String?
  requestedDeliveryDate DateTime?

  shipToName         String?
  shipToLine1        String?
  shipToLine2        String?
  shipToCity         String?
  shipToRegion       String?
  shipToPostalCode   String?
  shipToCountryCode  String? @db.VarChar(2)

  internalNotes   String? @db.Text
  notesToSupplier String? @db.Text

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow      Workflow             @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  requester     User                 @relation(fields: [requesterId], references: [id], onDelete: Restrict)
  supplier      Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  status        WorkflowStatus       @relation(fields: [statusId], references: [id], onDelete: Restrict)
  splitProposal SplitProposal?       @relation("SplitProposalDraftOrders", fields: [splitProposalId], references: [id], onDelete: SetNull)
  items         PurchaseOrderItem[]
  shipments     Shipment[]
  transitions   OrderTransitionLog[]
  chats         OrderChatMessage[]
  splitChildren PurchaseOrder[]      @relation("OrderSplitParent")
  splitParent   PurchaseOrder?       @relation("OrderSplitParent", fields: [splitParentId], references: [id])
  splitProposalsAsParent SplitProposal[] @relation("SplitProposalParent")

  @@unique([tenantId, orderNumber])
  @@index([tenantId, createdAt])
  @@index([tenantId, statusId])
  @@index([workflowId])
  @@index([splitParentId])
  @@index([splitProposalId])
}

model PurchaseOrderItem {
  id          String  @id @default(cuid())
  orderId     String
  lineNo      Int
  productId   String?
  description String
  quantity    Decimal @db.Decimal(14, 3)
  unitPrice   Decimal @db.Decimal(14, 4)
  lineTotal   Decimal @db.Decimal(14, 2)

  order              PurchaseOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product?           @relation(fields: [productId], references: [id], onDelete: SetNull)
  splitProposalLines SplitProposalLine[]
  shipmentItems      ShipmentItem[]

  @@unique([orderId, lineNo])
  @@index([orderId])
}

enum ShipmentStatus {
  SHIPPED
  RECEIVED
}

enum TransportMode {
  OCEAN
  AIR
  ROAD
  RAIL
}

model Shipment {
  id           String         @id @default(cuid())
  orderId      String
  shipmentNo   String?
  status       ShipmentStatus @default(SHIPPED)
  shippedAt    DateTime
  receivedAt   DateTime?
  carrier      String?
  trackingNo   String?
  transportMode TransportMode?
  estimatedVolumeCbm Decimal? @db.Decimal(12, 3)
  estimatedWeightKg Decimal? @db.Decimal(12, 3)
  notes        String?
  createdById  String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  order     PurchaseOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdBy User           @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items     ShipmentItem[]
  loadPlanShipment LoadPlanShipment?

  @@index([orderId, createdAt])
  @@index([status])
}

model ShipmentItem {
  id               String   @id @default(cuid())
  shipmentId       String
  orderItemId      String
  quantityShipped  Decimal  @db.Decimal(14, 3)
  quantityReceived Decimal  @default(0) @db.Decimal(14, 3)
  plannedShipDate  DateTime?

  shipment  Shipment          @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderItem  PurchaseOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict)

  @@index([shipmentId])
  @@index([orderItemId])
  @@unique([shipmentId, orderItemId])
}

enum WarehouseType {
  CFS
  WAREHOUSE
}

model Warehouse {
  id           String        @id @default(cuid())
  tenantId     String
  code         String?
  name         String
  type         WarehouseType @default(CFS)
  addressLine1 String?
  city         String?
  region       String?
  countryCode  String?       @db.VarChar(2)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loadPlans LoadPlan[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

enum LoadPlanStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

enum ContainerSize {
  LCL
  FCL_20
  FCL_40
  FCL_40HC
  TRUCK_13_6
  AIR_ULD
}

model LoadPlan {
  id          String         @id @default(cuid())
  tenantId    String
  reference   String
  warehouseId String
  transportMode TransportMode @default(OCEAN)
  containerSize ContainerSize @default(LCL)
  plannedEta  DateTime?
  status      LoadPlanStatus @default(DRAFT)
  notes       String?
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  createdBy    User               @relation(fields: [createdById], references: [id], onDelete: Restrict)
  assignments  LoadPlanShipment[]

  @@unique([tenantId, reference])
  @@index([tenantId, createdAt])
  @@index([warehouseId])
}

model LoadPlanShipment {
  id         String   @id @default(cuid())
  loadPlanId String
  shipmentId String   @unique
  createdAt  DateTime @default(now())

  loadPlan LoadPlan @relation(fields: [loadPlanId], references: [id], onDelete: Cascade)
  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@unique([loadPlanId, shipmentId])
  @@index([loadPlanId])
}

enum SplitProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model SplitProposal {
  id               String              @id @default(cuid())
  parentOrderId    String
  status           SplitProposalStatus @default(PENDING)
  version          Int                 @default(1)
  proposedByUserId String
  comment          String?
  createdAt        DateTime            @default(now())
  resolvedAt       DateTime?

  parentOrder    PurchaseOrder       @relation("SplitProposalParent", fields: [parentOrderId], references: [id], onDelete: Cascade)
  proposedBy     User                @relation(fields: [proposedByUserId], references: [id], onDelete: Restrict)
  lines          SplitProposalLine[]
  draftChildOrders PurchaseOrder[]   @relation("SplitProposalDraftOrders")

  @@index([parentOrderId])
  @@index([status])
}

model SplitProposalLine {
  id              String   @id @default(cuid())
  proposalId      String
  sourceLineId    String
  quantity        Decimal  @db.Decimal(14, 3)
  plannedShipDate DateTime
  childIndex      Int

  proposal   SplitProposal      @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  sourceLine PurchaseOrderItem  @relation(fields: [sourceLineId], references: [id], onDelete: Cascade)

  @@index([proposalId])
  @@index([sourceLineId])
}

model OrderTransitionLog {
  id           String   @id @default(cuid())
  orderId      String
  fromStatusId String?
  toStatusId   String
  actionCode   String
  actorUserId  String
  comment      String?
  createdAt    DateTime @default(now())

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor User          @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
}

model OrderChatMessage {
  id           String   @id @default(cuid())
  orderId      String
  authorUserId String
  body         String
  isInternal   Boolean  @default(true)
  createdAt    DateTime @default(now())

  order  PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  author User          @relation(fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([orderId, createdAt])
}
