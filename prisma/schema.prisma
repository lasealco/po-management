/// P2 — async mapping analysis job: structured rule proposals (deterministic heuristic today; LLM optional later).
model ApiHubMappingAnalysisJob {
  id                String    @id @default(cuid())
  tenantId          String
  requestedByUserId String
  /// `queued` | `processing` | `succeeded` | `failed`
  status            String    @default("queued")
  /// `{ schemaVersion, records, targetFields?, note? }` — no secrets; size-capped in API.
  inputPayload      Json
  /// `{ schemaVersion, engine, rules, notes?, stagingPreview? }` when succeeded.
  outputProposal    Json?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  startedAt         DateTime?
  finishedAt        DateTime?

  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedBy    User                 @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)
  stagingBatches ApiHubStagingBatch[]

  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
}

/// Normalized staging batch (pre-commit rows) for operator review — linked from mapping analysis or future ingest.
model ApiHubStagingBatch {
  id                         String    @id @default(cuid())
  tenantId                   String
  createdByUserId            String
  sourceMappingAnalysisJobId String?
  title                      String?
  /// `open` | `promoted` | `discarded`
  status                     String    @default("open")
  rowCount                   Int       @default(0)
  /// Set when rows were applied to downstream modules (SO/PO/CT audit) via API Hub apply.
  appliedAt                  DateTime?
  /// Last apply outcome: target, dryRun, row results (ids/errors).
  applySummary               Json?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

