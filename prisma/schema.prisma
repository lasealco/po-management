  id             String   @id @default(cuid())
  tenantId       String
  code           String
  description    String?
  movementType   InventoryMovementType?
  amountPerUnit  Decimal  @db.Decimal(14, 4)
  currency       String   @default("USD") @db.VarChar(3)
  isActive       Boolean  @default(true)
