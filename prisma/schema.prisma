  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  container    CtShipmentContainer  @relation(fields: [containerId], references: [id], onDelete: Cascade)
  shipmentItem ShipmentItem         @relation(fields: [shipmentItemId], references: [id], onDelete: Cascade)

  @@unique([containerId, shipmentItemId])
  @@index([tenantId, containerId])
  @@index([shipmentItemId])
