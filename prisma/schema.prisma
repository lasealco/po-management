  @@index([tenantId])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id               String  @id @default(cuid())
  roleId           String
  resource         String
  action           String
  effect           String
  workflowStatusId String?

  role           Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  workflowStatus WorkflowStatus? @relation(fields: [workflowStatusId], references: [id], onDelete: SetNull)

  @@unique([roleId, resource, action, workflowStatusId])
  @@index([roleId])
  @@index([workflowStatusId])
}

enum SrmSupplierCategory {
  product
  logistics
}

enum SupplierApprovalStatus {
  pending_approval
  approved
  rejected
}

/// Phase G (operator): coarse lifecycle step beyond the default checklist; not supplier portal.
enum SrmOnboardingStage {
  intake
  diligence
  review
  cleared
}

model Supplier {
  id       String  @id @default(cuid())
  tenantId String
  code     String?
  name     String
  email    String?
  phone    String?
  isActive Boolean @default(true)

  /// Procurement: materials vs logistics partners (forwarders, carriers-as-parties, etc.).
  srmCategory        SrmSupplierCategory    @default(product)
  /// Buyer-created suppliers start pending until an approver activates them.
  approvalStatus     SupplierApprovalStatus @default(approved)
  /// Operator-facing onboarding pipeline stage (Phase G; parallel to checklist tasks).
  srmOnboardingStage SrmOnboardingStage     @default(intake)

  /// Legal / registered business name if different from trade name.
  legalName String?
  /// VAT, EIN, company registration, etc.
  taxId     String?
  website   String?

  registeredAddressLine1 String?
  registeredAddressLine2 String?
  registeredCity         String?
  registeredRegion       String?
  registeredPostalCode   String?
  registeredCountryCode  String? @db.VarChar(2)

  /// e.g. 30 for Net 30; use with paymentTermsLabel.
  paymentTermsDays  Int?
  paymentTermsLabel String?
  creditLimit       Decimal? @db.Decimal(14, 2)
  creditCurrency    String?  @db.VarChar(3)
  defaultIncoterm   String?
  internalNotes     String?  @db.Text

  /// Hours allowed for booking confirmation after send (logistics partners). Null = tenant default (24h).
  bookingConfirmationSlaHours Int?
  /// AMP2: durable assistant-generated supplier performance brief for buyer review.
  assistantPerformanceBrief   String?   @db.Text
  /// AMP2: durable assistant-generated onboarding/compliance gap plan.
  assistantOnboardingGapPlan  String?   @db.Text
  assistantExecutionStatus    String    @default("PENDING") @db.VarChar(32)
  assistantExecutionNote      String?   @db.Text
  assistantLastReviewedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                    Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  portalLinkedUsers         User[]                      @relation("UserPortalLinkedSupplier")
  orders                    PurchaseOrder[]
  offices                   SupplierOffice[]
  contacts                  SupplierContact[]
  serviceCapabilities       SupplierServiceCapability[]
  productSuppliers          ProductSupplier[]
  shipmentBookings          ShipmentBooking[]
  shipmentsCarrier          Shipment[]                  @relation("ShipmentCarrierSupplier")
  ctShipmentLegsCarrier     CtShipmentLeg[]             @relation("CtLegCarrierSupplier")
  ctShipmentCostLinesVendor CtShipmentCostLine[]        @relation("CtCostLineVendorSupplier")
  quoteRequestRecipients    QuoteRequestRecipient[]
  onboardingTasks           SupplierOnboardingTask[]
  srmDocuments              SrmSupplierDocument[]
  srmOperatorNotifications  SrmOperatorNotification[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, assistantExecutionStatus, updatedAt])
}

/// SRM Phase B: checklist rows for supplier onboarding (assignee, due date, done).
model SupplierOnboardingTask {
  id             String    @id @default(cuid())
  tenantId       String
  supplierId     String
  /// Idempotent default key, e.g. `supplier_profile`.
  taskKey        String    @db.VarChar(64)
  title          String    @db.VarChar(256)
  sortOrder      Int       @default(0)
  done           Boolean   @default(false)
  assigneeUserId String?
  dueAt          DateTime?
  notes          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant                   Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier                 Supplier                  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  assignee                 User?                     @relation("SupplierOnboardingTaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  srmOperatorNotifications SrmOperatorNotification[]

  @@unique([supplierId, taskKey])
  @@index([tenantId, supplierId])
  @@index([tenantId, assigneeUserId])
}

/// SRM Phase C — compliance vault: uploaded files tied to a supplier.
enum SrmSupplierDocumentType {
  certificate_of_insurance
  w9
  code_of_conduct
  quality_agreement
  tax_certificate
  other
}

enum SrmSupplierDocumentStatus {
  active
  archived
  superseded
}

/// Metadata + object storage URL for a supplier compliance document.
model SrmSupplierDocument {
  id                   String                    @id @default(cuid())
  tenantId             String
  supplierId           String
  documentType         SrmSupplierDocumentType
  status               SrmSupplierDocumentStatus @default(active)
  title                String?                   @db.VarChar(256)
  fileName             String
  mimeType             String
  fileSize             Int
  /// Blob object basename or local key; optional when `fileUrl` is self-sufficient.
  storageKey           String?                   @db.VarChar(512)
  fileUrl              String                    @db.Text
  expiresAt            DateTime?
  uploadedById         String
  lastModifiedById     String?
  /// Phase I: all revisions in a chain share the same id (v1: random UUID; legacy rows: id of first in chain or backfilled to own id).
  revisionGroupId      String
  /// Monotonic per revision group (1 = first upload in group).
  revisionNumber       Int                       @default(1)
  /// When this row replaces a prior file, points to the previous document; prior row is set to `superseded`.
  supersedesDocumentId String?
  supersedesDocument   SrmSupplierDocument?      @relation("SrmDocumentRevision", fields: [supersedesDocumentId], references: [id], onDelete: SetNull)
  supersedingDocuments SrmSupplierDocument[]     @relation("SrmDocumentRevision")
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  tenant         Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier       Supplier                      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  uploadedBy     User                          @relation("SrmSupplierDocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)
  lastModifiedBy User?                         @relation("SrmSupplierDocumentLastTouchedBy", fields: [lastModifiedById], references: [id], onDelete: SetNull)
  auditLogs      SrmSupplierDocumentAuditLog[]

  @@unique([revisionGroupId, revisionNumber])
  @@index([tenantId, supplierId])
  @@index([tenantId, status])
  @@index([tenantId, expiresAt])
  @@index([tenantId, revisionGroupId])
}

/// Append-only triage for supplier documents (upload + metadata/single updates).
model SrmSupplierDocumentAuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  documentId  String
  at          DateTime @default(now())
  actorUserId String
  action      String   @db.VarChar(32)
  details     Json?

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document SrmSupplierDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  actor    User                @relation("SrmSupplierDocumentAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([documentId, at])
  @@index([tenantId, at])
}

/// SRM Phase E — replay cache for `POST` integration routes (e.g. supplier upsert) keyed by `Idempotency-Key`.
model SrmIntegrationIdempotency {
  id           String   @id @default(cuid())
  tenantId     String
  /// Route surface, e.g. `supplier_upsert_v1`.
  surface      String   @db.VarChar(64)
  key          String   @db.VarChar(256)
  bodySha256   String   @db.VarChar(64)
  statusCode   Int
  responseBody String   @db.Text
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, surface, key])
  @@index([tenantId, createdAt])
}

/// Phase G: in-app row for buyers/operators (not supplier portal). Task assign + future hooks.
model SrmOperatorNotification {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  /// e.g. ONBOARDING_TASK_ASSIGNED
  kind        String    @db.VarChar(64)
  title       String    @db.VarChar(256)
  body        String?   @db.Text
  readAt      DateTime?
  supplierId  String?
  /// Optional link for UI / deep-link.
  taskId      String?
  actorUserId String?
  createdAt   DateTime  @default(now())

  tenant   Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User                    @relation("SrmOperatorNotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  supplier Supplier?               @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  task     SupplierOnboardingTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  actor    User?                   @relation("SrmOperatorNotificationActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, userId, readAt])
  @@index([tenantId, userId, createdAt])
}

/// SRM: declared transport / service scope (modes, service lines, geography). See PRD “Service capabilities”.
model SupplierServiceCapability {
  id          String   @id @default(cuid())
  tenantId    String
  supplierId  String
  /// OCEAN | AIR | ROAD | RAIL when mode-specific; optional.
  mode        String?  @db.VarChar(16)
  subMode     String?  @db.VarChar(64)
  /// Short label, e.g. Freight forwarding, Customs brokerage.
  serviceType String   @db.VarChar(128)
  geography   String?  @db.VarChar(256)
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([tenantId, supplierId])
}

/// People at the supplier (sales, AP, operations).
model SupplierContact {
  id         String   @id @default(cuid())
  tenantId   String
  supplierId String
  name       String
  title      String?
  /// e.g. Sales, Accounts payable, Quality
  role       String?
  email      String?
  phone      String?
  notes      String?
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier         Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  shipmentBookings ShipmentBooking[]

  @@index([tenantId])
  @@index([supplierId])
}

/// Buyer-facing catalog category (Settings → category management).
model ProductCategory {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String?
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Organizational division for reporting and filters.
model ProductDivision {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  code      String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant               Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products             Product[]
  userProductDivisions UserProductDivision[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

/// Supplier office / site used on the product form (dropdown).
model SupplierOffice {
  id           String   @id @default(cuid())
  tenantId     String
  supplierId   String
  name         String
  addressLine1 String?
  addressLine2 String?
  city         String?
  region       String?
  postalCode   String?
  countryCode  String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier         Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  products         Product[]
  shipmentBookings ShipmentBooking[]

  @@unique([supplierId, name])
  @@index([tenantId])
  @@index([supplierId])
}

model Product {
  id          String  @id @default(cuid())
  tenantId    String
  /// Shown as “product code” in the legacy UI (e.g. BC-CB40).
  productCode String?
  sku         String?
  name        String
  description String? @db.VarChar(2000)
  unit        String?

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  divisionId String?
  division   ProductDivision? @relation(fields: [divisionId], references: [id], onDelete: SetNull)

  ean             String? @db.VarChar(32)
  customerName    String? @db.Text
  /// Legacy “product image” until blob storage is wired; can be a CDN URL.
  primaryImageUrl String?
  hsCode          String?

  isDangerousGoods    Boolean  @default(false)
  dangerousGoodsClass String?
  unNumber            String?
  properShippingName  String?
  packingGroup        String?
  flashPoint          Decimal? @db.Decimal(10, 2)
  flashPointUnit      String?
  msdsUrl             String?

  isTemperatureControlled Boolean @default(false)
  temperatureRangeText    String?
  temperatureUnit         String?
  coolingType             String?
  packagingNotes          String? @db.Text
  humidityRequirements    String?
  storageDescription      String? @db.Text
  isForReexport           Boolean @default(false)

  supplierOfficeId String?
  supplierOffice   SupplierOffice? @relation(fields: [supplierOfficeId], references: [id], onDelete: SetNull)

  /// AMP4: durable availability-to-promise summary and recovery proposal for warehouse/customer promise review.
  assistantPromiseStatus     String    @default("PENDING") @db.VarChar(32)
  assistantPromiseSummary    String?   @db.Text
  assistantRecoveryProposal  String?   @db.Text
  assistantPromiseReviewedAt DateTime?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderItems         PurchaseOrderItem[]
  salesOrderLines    SalesOrderLine[]
  inventoryBalances  InventoryBalance[]
  inventoryMovements InventoryMovement[]
  wmsBillingEvents   WmsBillingEvent[]
  wmsTasks           WmsTask[]
  replenishmentRules ReplenishmentRule[]
  outboundOrderLines OutboundOrderLine[]
  documents          ProductDocument[]
  productSuppliers   ProductSupplier[]

  @@unique([tenantId, sku])
  @@unique([tenantId, productCode])
  @@index([tenantId])
  @@index([tenantId, assistantPromiseStatus, updatedAt])
  @@index([categoryId])
  @@index([divisionId])
}

/// Which suppliers can supply this SKU (legacy “Suppliers: N” column).
model ProductSupplier {
  productId  String
  supplierId String
  createdAt  DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([productId, supplierId])
  @@index([supplierId])
}

enum ProductDocumentKind {
  PRIMARY_IMAGE
  MSDS
  OTHER
}

/// File metadata; `url` holds a storage URL (S3, Vercel Blob, etc.) when uploads exist.
model ProductDocument {
  id        String              @id @default(cuid())
  productId String
  kind      ProductDocumentKind @default(OTHER)
  fileName  String
  url       String
  mimeType  String?
  sizeBytes Int?
  createdAt DateTime            @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Workflow {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  code             String
  isDefault        Boolean  @default(false)
  supplierPortalOn Boolean  @default(false)
  allowSplitOrders Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  statuses    WorkflowStatus[]
  transitions WorkflowTransition[]
  actions     WorkflowAction[]
  orders      PurchaseOrder[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model WorkflowStatus {
  id         String   @id @default(cuid())
  workflowId String
  code       String
  label      String
  category   String?
  isStart    Boolean  @default(false)
  isEnd      Boolean  @default(false)
  sortOrder  Int
  createdAt  DateTime @default(now())

  workflow        Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromTransitions WorkflowTransition[] @relation("FromStatus")
  toTransitions   WorkflowTransition[] @relation("ToStatus")
  orders          PurchaseOrder[]
  permissions     RolePermission[]

  @@unique([workflowId, code])
  @@index([workflowId, sortOrder])
}

model WorkflowTransition {
  id              String  @id @default(cuid())
  workflowId      String
  fromStatusId    String
  toStatusId      String
  actionCode      String
  label           String
  requiresComment Boolean @default(false)

  workflow   Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  fromStatus WorkflowStatus @relation("FromStatus", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus   WorkflowStatus @relation("ToStatus", fields: [toStatusId], references: [id], onDelete: Cascade)

  @@unique([workflowId, fromStatusId, toStatusId, actionCode])
  @@index([workflowId, fromStatusId])
}

model WorkflowAction {
  id         String  @id @default(cuid())
  workflowId String
  code       String
  label      String
  isEnabled  Boolean @default(true)

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, code])
  @@index([workflowId])
}

model PurchaseOrder {
  id                    String    @id @default(cuid())
  tenantId              String
  workflowId            String
  orderNumber           String
  title                 String?
  requesterId           String
  supplierId            String?
  statusId              String
  currency              String    @default("USD")
  subtotal              Decimal   @db.Decimal(14, 2)
  taxAmount             Decimal   @db.Decimal(14, 2)
  totalAmount           Decimal   @db.Decimal(14, 2)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  splitParentId         String?
  splitIndex            Int?
  splitProposalId       String?
  /// Optional org (subsidiary / site) this PO is for — centralized procurement; see Phase 2 in `docs/organization-dimensions-and-delivery-phases.md`.
  servedOrgUnitId       String?
  /// 3PL / BCO: commercial shipper customer (same tenant `CrmAccount` as `Shipment.customerCrmAccountId`); optional.
  customerCrmAccountId  String?
  /// Buyer / internal reference (e.g. requisition #).
  buyerReference        String?
  /// Supplier acknowledgment or their order #.
  supplierReference     String?
  paymentTermsDays      Int?
  paymentTermsLabel     String?
  incoterm              String?
  requestedDeliveryDate DateTime?

  shipToName        String?
  shipToLine1       String?
  shipToLine2       String?
  shipToCity        String?
  shipToRegion      String?
  shipToPostalCode  String?
  shipToCountryCode String? @db.VarChar(2)

  internalNotes   String? @db.Text
  notesToSupplier String? @db.Text

  tenant                 Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow               Workflow             @relation(fields: [workflowId], references: [id], onDelete: Restrict)
  requester              User                 @relation(fields: [requesterId], references: [id], onDelete: Restrict)
  servedOrgUnit          OrgUnit?             @relation("PurchaseOrderServedOrg", fields: [servedOrgUnitId], references: [id], onDelete: SetNull)
  customerCrmAccount     CrmAccount?          @relation("PurchaseOrderCustomerCrm", fields: [customerCrmAccountId], references: [id], onDelete: SetNull)
  supplier               Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  status                 WorkflowStatus       @relation(fields: [statusId], references: [id], onDelete: Restrict)
  splitProposal          SplitProposal?       @relation("SplitProposalDraftOrders", fields: [splitProposalId], references: [id], onDelete: SetNull)
  items                  PurchaseOrderItem[]
  shipments              Shipment[]
  wmsTasks               WmsTask[]
  transitions            OrderTransitionLog[]
  chats                  OrderChatMessage[]
  splitChildren          PurchaseOrder[]      @relation("OrderSplitParent")
  splitParent            PurchaseOrder?       @relation("OrderSplitParent", fields: [splitParentId], references: [id])
  splitProposalsAsParent SplitProposal[]      @relation("SplitProposalParent")

  @@unique([tenantId, orderNumber])
  @@index([tenantId, createdAt])
  @@index([tenantId, statusId])
  @@index([workflowId])
  @@index([splitParentId])
  @@index([splitProposalId])
  @@index([tenantId, customerCrmAccountId])
  @@index([tenantId, servedOrgUnitId])
}

model PurchaseOrderItem {
  id          String  @id @default(cuid())
  orderId     String
  lineNo      Int
  productId   String?
  description String
  quantity    Decimal @db.Decimal(14, 3)
  unitPrice   Decimal @db.Decimal(14, 4)
  lineTotal   Decimal @db.Decimal(14, 2)

  order              PurchaseOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product?            @relation(fields: [productId], references: [id], onDelete: SetNull)
  splitProposalLines SplitProposalLine[]
  shipmentItems      ShipmentItem[]

  @@unique([orderId, lineNo])
  @@index([orderId])
}

model SalesOrder {
  id                      String           @id @default(cuid())
  tenantId                String
  soNumber                String
  status                  SalesOrderStatus @default(DRAFT)
  customerName            String
  /// Optional org this SO is for (same intent as `PurchaseOrder.servedOrgUnitId`).
  servedOrgUnitId         String?
  customerCrmAccountId    String?
  externalRef             String?
  requestedShipDate       DateTime?
  requestedDeliveryDate   DateTime?
  currency                String           @default("USD") @db.VarChar(3)
  notes                   String?          @db.Text
  /// AMP1: original customer request captured by the assistant before creating the draft.
  assistantSourceText     String?          @db.Text
  /// AMP1: structured parser snapshot for later review/debugging.
  assistantSourceSnapshot Json?
  /// AMP1: editable/copyable customer reply draft generated at intake time; never auto-sent.
  assistantDraftReply     String?          @db.Text
  assistantReviewStatus   String           @default("PENDING") @db.VarChar(32)
  assistantReviewNote     String?          @db.Text
  assistantReviewedAt     DateTime?
  assistantReviewedById   String?
  createdById             String
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  tenant                Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  servedOrgUnit         OrgUnit?               @relation("SalesOrderServedOrg", fields: [servedOrgUnitId], references: [id], onDelete: SetNull)
  customerCrmAccount    CrmAccount?            @relation(fields: [customerCrmAccountId], references: [id], onDelete: SetNull)
  createdBy             User                   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  assistantReviewedBy   User?                  @relation("SalesOrderAssistantReviewedBy", fields: [assistantReviewedById], references: [id], onDelete: SetNull)
  lines                 SalesOrderLine[]
  shipments             Shipment[]
  assistantEmailThreads AssistantEmailThread[]

  @@unique([tenantId, soNumber])
  @@index([tenantId, status, createdAt])
  @@index([customerCrmAccountId])
  @@index([tenantId, servedOrgUnitId])
  @@index([tenantId, assistantReviewStatus, updatedAt])
}

model SalesOrderLine {
  id           String   @id @default(cuid())
  tenantId     String
  salesOrderId String
  lineNo       Int
  productId    String?
  description  String
  quantity     Decimal  @db.Decimal(14, 3)
  unitPrice    Decimal  @db.Decimal(14, 4)
  lineTotal    Decimal  @db.Decimal(14, 2)
  currency     String   @default("USD") @db.VarChar(3)
  source       String?  @db.VarChar(64)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@unique([salesOrderId, lineNo])
  @@index([tenantId, salesOrderId])
  @@index([tenantId, productId])
}

enum ShipmentStatus {
  /// Internal draft: booking data captured, not yet submitted to forwarder.
  BOOKING_DRAFT
  /// Booking request sent; awaiting forwarder confirmation within SLA.
  BOOKING_SUBMITTED
  SHIPPED
  VALIDATED
  BOOKED
  IN_TRANSIT
  DELIVERED
  RECEIVED
}

enum ShipmentBookingStatus {
  DRAFT
  /// Sent to forwarder / carrier channel; awaiting confirmation.
  SENT
  CONFIRMED
  CANCELLED
}

enum ShipmentMilestoneCode {
  ASN_SUBMITTED
  ASN_VALIDATED
  BOOKING_CONFIRMED
  DEPARTED
  ARRIVED
  DELIVERED
  RECEIVED
}

enum ShipmentMilestoneSource {
  SUPPLIER
  INTERNAL
  FORWARDER
  SYSTEM
}

enum TransportMode {
  OCEAN
  AIR
  ROAD
  RAIL
}

enum SalesOrderStatus {
  DRAFT
  OPEN
  CLOSED
}

model Shipment {
  id                      String         @id @default(cuid())
  orderId                 String
  salesOrderId            String?
  shipmentNo              String?
  status                  ShipmentStatus @default(BOOKING_DRAFT)
  shippedAt               DateTime
  receivedAt              DateTime?
  /// Supplier / forwarder ASN or notice id (WMS receiving layer).
  asnReference            String?
  /// Expected arrival at CFS / warehouse for receiving planning.
  expectedReceiveAt       DateTime?
  carrierSupplierId       String?
  carrier                 String?
  trackingNo              String?
  transportMode           TransportMode?
  estimatedVolumeCbm      Decimal?       @db.Decimal(12, 3)
  estimatedWeightKg       Decimal?       @db.Decimal(12, 3)
  /// Outward package / collo count (forwarder cargo).
  cargoOuterPackageCount  Int?
  /// Chargeable / billable weight where different from estimatedWeightKg (e.g. air).
  cargoChargeableWeightKg Decimal?       @db.Decimal(12, 3)
  /// Freeform dimensions (e.g. 120×80×100 cm) until structured L/W/H exist.
  cargoDimensionsText     String?        @db.VarChar(512)
  /// Main commodity description for customs / booking screens.
  cargoCommoditySummary   String?        @db.Text
  notes                   String?
  /// Logistics customer (e.g. 3PL shipper account) for visibility and reporting.
  customerCrmAccountId    String?
  /// Primary Control Tower / ops owner for this shipment (optional).
  opsAssigneeUserId       String?
  createdById             String
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  order                      PurchaseOrder                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  salesOrder                 SalesOrder?                   @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  carrierSupplier            Supplier?                     @relation("ShipmentCarrierSupplier", fields: [carrierSupplierId], references: [id], onDelete: SetNull)
  customerCrmAccount         CrmAccount?                   @relation("ShipmentCustomerAccount", fields: [customerCrmAccountId], references: [id], onDelete: SetNull)
  opsAssignee                User?                         @relation("ShipmentOpsAssignee", fields: [opsAssigneeUserId], references: [id], onDelete: SetNull)
  createdBy                  User                          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  items                      ShipmentItem[]
  loadPlanShipment           LoadPlanShipment?
  booking                    ShipmentBooking?
  milestones                 ShipmentMilestone[]
  wmsTasks                   WmsTask[]
  ctReferences               CtShipmentReference[]
  ctTrackingMilestones       CtTrackingMilestone[]
  ctDocuments                CtShipmentDocument[]
  ctNotes                    CtShipmentNote[]
  ctFinancialSnapshots       CtShipmentFinancialSnapshot[]
  ctAlerts                   CtAlert[]
  ctExceptions               CtException[]
  ctAuditLogs                CtAuditLog[]
  ctLegs                     CtShipmentLeg[]
  ctContainers               CtShipmentContainer[]
  ctCostLines                CtShipmentCostLine[]
  tariffShipmentApplications TariffShipmentApplication[]

  @@index([orderId, createdAt])
  @@index([status])
  @@index([customerCrmAccountId])
  @@index([carrierSupplierId])
  @@index([salesOrderId])
  @@index([opsAssigneeUserId])
}

model ShipmentItem {
  id                  String    @id @default(cuid())
  shipmentId          String
  orderItemId         String
  quantityShipped     Decimal   @db.Decimal(14, 3)
  quantityReceived    Decimal   @default(0) @db.Decimal(14, 3)
  plannedShipDate     DateTime?
  /// Line-level outward packages (optional; may differ from PO qty unit).
  cargoPackageCount   Int?
  cargoGrossWeightKg  Decimal?  @db.Decimal(14, 3)
  cargoVolumeCbm      Decimal?  @db.Decimal(12, 6)
  cargoDimensionsText String?   @db.VarChar(512)

  shipment            Shipment               @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  orderItem           PurchaseOrderItem      @relation(fields: [orderItemId], references: [id], onDelete: Restrict)
  containerCargoLines CtContainerCargoLine[]

  @@unique([shipmentId, orderItemId])
  @@index([shipmentId])
  @@index([orderItemId])
}

model ShipmentBooking {
  id                     String                @id @default(cuid())
  shipmentId             String                @unique
  status                 ShipmentBookingStatus @default(DRAFT)
  bookingNo              String?
  serviceLevel           String?
  forwarderSupplierId    String?
  forwarderOfficeId      String?
  forwarderContactId     String?
  mode                   TransportMode?
  originCode             String?
  destinationCode        String?
  etd                    DateTime?
  eta                    DateTime?
  latestEta              DateTime?
  /// When the booking request was submitted to the forwarder (EDI / email / portal).
  bookingSentAt          DateTime?
  /// Deadline for forwarder booking confirmation per SLA (derived from Supplier or default).
  bookingConfirmSlaDueAt DateTime?
  notes                  String?
  createdById            String
  updatedById            String
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  shipment          Shipment                 @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  forwarderSupplier Supplier?                @relation(fields: [forwarderSupplierId], references: [id], onDelete: SetNull)
  forwarderOffice   SupplierOffice?          @relation(fields: [forwarderOfficeId], references: [id], onDelete: SetNull)
  forwarderContact  SupplierContact?         @relation(fields: [forwarderContactId], references: [id], onDelete: SetNull)
  createdBy         User                     @relation("ShipmentBookingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy         User                     @relation("ShipmentBookingUpdatedBy", fields: [updatedById], references: [id], onDelete: Restrict)
  pricingSnapshots  BookingPricingSnapshot[]

  @@index([status])
  @@index([forwarderSupplierId])
}

model ShipmentMilestone {
  id          String                  @id @default(cuid())
  shipmentId  String
  code        ShipmentMilestoneCode
  source      ShipmentMilestoneSource @default(INTERNAL)
  plannedAt   DateTime?
  actualAt    DateTime?
  note        String?
  updatedById String
  createdAt   DateTime                @default(now())

  shipment  Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  updatedBy User     @relation(fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([shipmentId, createdAt])
  @@index([code])
}

/// Extra reference numbers (master/house B/L, AWB, etc.) for Control Tower.
model CtShipmentReference {
  id         String   @id @default(cuid())
  shipmentId String
  refType    String
  refValue   String
  createdAt  DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([refValue])
}

/// Flexible planned / predicted / actual milestones (beyond enum `ShipmentMilestone`).
model CtTrackingMilestone {
  id          String    @id @default(cuid())
  tenantId    String
  shipmentId  String
  code        String
  label       String?
  plannedAt   DateTime?
  predictedAt DateTime?
  actualAt    DateTime?
  sourceType  String    @default("MANUAL")
  sourceRef   String?
  confidence  Int?
  notes       String?   @db.Text
  updatedById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment  Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  updatedBy User     @relation(fields: [updatedById], references: [id], onDelete: Restrict)

  @@index([tenantId, shipmentId])
  @@index([code])
}

enum CtDocVisibility {
  INTERNAL
  CUSTOMER_SHAREABLE
}

enum CtShipmentDocumentSource {
  UPLOAD
  INTEGRATION
}

model CtShipmentDocument {
  id                  String                   @id @default(cuid())
  tenantId            String
  shipmentId          String
  /// Canonical code (see `shipment-document-types.ts`) or integration-specific code.
  docType             String
  fileName            String
  /// File URL in object storage (or public path in local dev) — not the file bytes.
  blobUrl             String
  visibility          CtDocVisibility          @default(INTERNAL)
  version             Int                      @default(1)
  uploadedById        String
  createdAt           DateTime                 @default(now())
  source              CtShipmentDocumentSource @default(UPLOAD)
  /// When `source` is INTEGRATION: e.g. CARGOWISE, FREIGHTOS.
  integrationProvider String?
  /// External document / message id for dedupe and support (optional).
  externalRef         String?

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([shipmentId])
  @@index([shipmentId, source])
}

enum CtNoteVisibility {
  INTERNAL
  SHARED
}

model CtShipmentNote {
  id          String           @id @default(cuid())
  tenantId    String
  shipmentId  String
  body        String           @db.Text
  visibility  CtNoteVisibility @default(INTERNAL)
  createdById String
  createdAt   DateTime         @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment  Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([shipmentId])
}

model CtShipmentFinancialSnapshot {
  id                  String   @id @default(cuid())
  tenantId            String
  shipmentId          String
  customerVisibleCost Decimal? @db.Decimal(14, 2)
  internalCost        Decimal? @db.Decimal(14, 2)
  internalRevenue     Decimal? @db.Decimal(14, 2)
  internalNet         Decimal? @db.Decimal(14, 2)
  internalMarginPct   Decimal? @db.Decimal(9, 4)
  currency            String   @default("USD") @db.VarChar(3)
  asOf                DateTime @default(now())
  createdById         String

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment  Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([shipmentId, asOf])
}

enum CtAlertSeverity {
  INFO
  WARN
  CRITICAL
}

enum CtAlertStatus {
  OPEN
  ACKNOWLEDGED
  CLOSED
}

model CtAlert {
  id               String          @id @default(cuid())
  tenantId         String
  shipmentId       String
  type             String
  severity         CtAlertSeverity @default(WARN)
  title            String
  body             String?         @db.Text
  ownerUserId      String?
  acknowledgedAt   DateTime?
  acknowledgedById String?
  status           CtAlertStatus   @default(OPEN)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment       Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  owner          User?    @relation("CtAlertOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  acknowledgedBy User?    @relation("CtAlertAckBy", fields: [acknowledgedById], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([shipmentId])
}

enum CtExceptionStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

/// Tenant catalog of exception types for Control Tower (dropdown + defaults).
model CtExceptionCode {
  id              String          @id @default(cuid())
  tenantId        String
  code            String
  label           String
  defaultSeverity CtAlertSeverity @default(WARN)
  sortOrder       Int             @default(0)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model CtException {
  id                String            @id @default(cuid())
  tenantId          String
  shipmentId        String
  type              String
  severity          CtAlertSeverity   @default(WARN)
  ownerUserId       String?
  rootCause         String?           @db.Text
  status            CtExceptionStatus @default(OPEN)
  customerImpact    String?           @db.Text
  recoveryState     String            @default("TRIAGE") @db.VarChar(32)
  recoveryPlan      String?           @db.Text
  carrierDraft      String?           @db.Text
  customerDraft     String?           @db.Text
  playbookSteps     Json?
  recoveryUpdatedAt DateTime?
  claimAmount       Decimal?          @db.Decimal(14, 2)
  resolvedAt        DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  owner    User?    @relation("CtExceptionOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([shipmentId])
  @@index([tenantId, status])
  @@index([tenantId, recoveryState, updatedAt])
}

model CtAuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  shipmentId  String?
  entityType  String
  entityId    String
  action      String
  payload     Json?
  actorUserId String
  createdAt   DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)
  actor    User      @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, shipmentId])
  @@index([entityType, entityId])
}

model CtSavedFilter {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  name        String
  filtersJson Json
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Which product domain a saved report belongs to (unified reporting; engines vary by dataset).
enum ReportDataset {
  CONTROL_TOWER
  PO
  CRM
  WMS
}

enum CtReportScheduleFrequency {
  DAILY
  WEEKLY
}

model CtReportSchedule {
  id             String                    @id @default(cuid())
  tenantId       String
  userId         String
  savedReportId  String
  recipientEmail String                    @db.VarChar(320)
  frequency      CtReportScheduleFrequency
  hourUtc        Int
  /// 0 = Sunday … 6 = Saturday (UTC). Required when frequency is WEEKLY; must be null when DAILY.
  dayOfWeek      Int?
  isActive       Boolean                   @default(true)
  lastRunAt      DateTime?
  lastError      String?                   @db.Text
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedReport CtSavedReport @relation(fields: [savedReportId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive, hourUtc])
}

model CtSavedReport {
  id          String        @id @default(cuid())
  tenantId    String
  userId      String
  name        String
  description String?
  configJson  Json
  isShared    Boolean       @default(false)
  dataset     ReportDataset @default(CONTROL_TOWER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  dashboardWidgets CtDashboardWidget[]
  reportSchedules  CtReportSchedule[]

  @@index([tenantId, userId, createdAt])
  @@index([tenantId, isShared, createdAt])
  @@index([tenantId, dataset, createdAt])
}

model CtDashboardWidget {
  id            String   @id @default(cuid())
  tenantId      String
  userId        String
  savedReportId String
  title         String
  sortOrder     Int      @default(0)
  layoutJson    Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedReport CtSavedReport @relation(fields: [savedReportId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, sortOrder, createdAt])
  @@index([savedReportId])
}

model CtFxRate {
  id            String   @id @default(cuid())
  tenantId      String
  baseCurrency  String   @db.VarChar(3)
  quoteCurrency String   @db.VarChar(3)
  rate          Decimal  @db.Decimal(18, 8)
  rateDate      DateTime
  provider      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, baseCurrency, quoteCurrency, rateDate])
  @@index([tenantId, baseCurrency, quoteCurrency, rateDate])
}

model CtShipmentCostLine {
  id               String    @id @default(cuid())
  tenantId         String
  shipmentId       String
  category         String
  description      String?
  vendorSupplierId String?
  vendor           String?
  invoiceNo        String?
  invoiceDate      DateTime?
  amountMinor      BigInt
  currency         String    @db.VarChar(3)
  createdById      String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment       Shipment  @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  vendorSupplier Supplier? @relation("CtCostLineVendorSupplier", fields: [vendorSupplierId], references: [id], onDelete: SetNull)
  createdBy      User      @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([tenantId, shipmentId, createdAt])
  @@index([shipmentId, currency])
  @@index([vendorSupplierId])
}

/// Multi-leg routing (ocean/air/truck segments) for Control Tower.
model CtShipmentLeg {
  id                String         @id @default(cuid())
  tenantId          String
  shipmentId        String
  legNo             Int            @default(1)
  originCode        String?
  destinationCode   String?
  carrierSupplierId String?
  carrier           String?
  transportMode     TransportMode?
  plannedEtd        DateTime?
  plannedEta        DateTime?
  actualAtd         DateTime?
  actualAta         DateTime?
  notes             String?        @db.Text
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment        Shipment              @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  carrierSupplier Supplier?             @relation("CtLegCarrierSupplier", fields: [carrierSupplierId], references: [id], onDelete: SetNull)
  containers      CtShipmentContainer[]

  @@unique([shipmentId, legNo])
  @@index([tenantId, shipmentId])
  @@index([carrierSupplierId])
}

model CtShipmentContainer {
  id              String    @id @default(cuid())
  tenantId        String
  shipmentId      String
  legId           String?
  containerNumber String
  containerType   String?
  seal            String?
  status          String?
  gateInAt        DateTime?
  gateOutAt       DateTime?
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment   Shipment               @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  leg        CtShipmentLeg?         @relation(fields: [legId], references: [id], onDelete: SetNull)
  cargoLines CtContainerCargoLine[]

  @@index([shipmentId])
  @@index([tenantId, containerNumber])
  @@index([legId])
}

/// Quantities of a shipment line allocated to a specific container (stuffing / load plan).
model CtContainerCargoLine {
  id             String   @id @default(cuid())
  tenantId       String
  containerId    String
  shipmentItemId String
  /// Same unit as `ShipmentItem.quantityShipped` (order line UOM).
  quantity       Decimal  @db.Decimal(14, 3)
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  container    CtShipmentContainer @relation(fields: [containerId], references: [id], onDelete: Cascade)
  shipmentItem ShipmentItem        @relation(fields: [shipmentItemId], references: [id], onDelete: Cascade)

  @@unique([containerId, shipmentItemId])
  @@index([tenantId, containerId])
  @@index([shipmentItemId])
}

enum WarehouseType {
  CFS
  WAREHOUSE
}

enum LocationCodeType {
  UN_LOCODE
  PORT
  AIRPORT
}

model LocationCode {
  id          String           @id @default(cuid())
  tenantId    String
  type        LocationCodeType
  code        String
  name        String
  countryCode String?          @db.VarChar(2)
  subdivision String?
  source      String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, type, code])
  @@index([tenantId, type, isActive])
  @@index([tenantId, code])
}

model Warehouse {
  id           String        @id @default(cuid())
  tenantId     String
  code         String?
  name         String
  type         WarehouseType @default(CFS)
  addressLine1 String?
  city         String?
  region       String?
  countryCode  String?       @db.VarChar(2)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loadPlans          LoadPlan[]
  zones              WarehouseZone[]
  bins               WarehouseBin[]
  inventoryBalances  InventoryBalance[]
  inventoryMovements InventoryMovement[]
  wmsTasks           WmsTask[]
  wmsWaves           WmsWave[]
  replenishmentRules ReplenishmentRule[]
  outboundOrders     OutboundOrder[]
  wmsBillingEvents   WmsBillingEvent[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

enum WarehouseZoneType {
  RECEIVING
  PICKING
  RESERVE
  QUARANTINE
  STAGING
  SHIPPING
}

model WarehouseZone {
  id          String            @id @default(cuid())
  tenantId    String
  warehouseId String
  code        String
  name        String
  zoneType    WarehouseZoneType
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse   Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  bins        WarehouseBin[]
  sourceRules ReplenishmentRule[] @relation("ReplenishmentSourceZone")
  targetRules ReplenishmentRule[] @relation("ReplenishmentTargetZone")

  @@unique([warehouseId, code])
  @@index([tenantId, warehouseId, zoneType])
}

enum BinStorageType {
  PALLET
  FLOOR
  SHELF
  QUARANTINE
  STAGING
}

model WarehouseBin {
  id            String         @id @default(cuid())
  tenantId      String
  warehouseId   String
  zoneId        String?
  code          String
  name          String
  storageType   BinStorageType @default(PALLET)
  isPickFace    Boolean        @default(false)
  maxPallets    Int?
  /// Groups bins into one physical rack / bay run for layout maps (e.g. `R-A01`).
  rackCode      String?        @db.VarChar(64)
  aisle         String?        @db.VarChar(32)
  bay           String?        @db.VarChar(32)
  /// 1-based shelf level (floor = 1) when using rack maps.
  level         Int?
  /// 1-based slot along the rack front (width axis) for grid columns.
  positionIndex Int?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warehouse          Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
