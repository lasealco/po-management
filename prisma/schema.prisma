/// Mega-Phase 4: external mail thread as an attention item (pilot; feature-flagged in app).
enum AssistantEmailThreadStatus {
  OPEN
  REPLIED
  RESOLVED
}

/// One inbound “thread” row (MVP: one message per row; extensible to multi-message threads).
model AssistantEmailThread {
  id                  String                     @id @default(cuid())
  tenantId            String
  /// When present, used to deduplicate re-ingest (e.g. Message-Id, provider id).
  providerMsgId       String?                    @db.VarChar(500)
  subject             String
  fromAddress         String
  toAddress           String
  /// Short preview for lists (first ~300 chars of body, plain text).
  preview             String                     @db.VarChar(500)
  bodyText            String                     @db.Text
  receivedAt          DateTime
  status              AssistantEmailThreadStatus @default(OPEN)
  /// Staged reply text — never auto-sent.
  draftReply          String?                    @db.Text
  lastSendConfirmAt   DateTime?
  lastSendConfirmById String?
  lastSendMode        String?                    @db.VarChar(32) /// e.g. mailto, audit_only, smtp
  /// Optional link to CRM account when user associates the conversation.
  linkedCrmAccountId  String?
  /// Optional draft sales order created from this email (MP5/MP7 traceability).
  salesOrderId        String?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  tenant            Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lastSendConfirmBy User?       @relation("AssistantEmailSendConfirmBy", fields: [lastSendConfirmById], references: [id], onDelete: SetNull)
  linkedCrmAccount  CrmAccount? @relation(fields: [linkedCrmAccountId], references: [id], onDelete: SetNull)
  salesOrder        SalesOrder? @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)

  @@unique([tenantId, providerMsgId])
  @@index([tenantId, receivedAt])
  @@index([tenantId, status])
  @@index([tenantId, salesOrderId])
}

/// Integration / API hub — registry row for an external or internal data source (Phase 1 stub).
model ApiHubConnector {
  id            String    @id @default(cuid())
  tenantId      String
  name          String
  /// High-level source label until taxonomy lands (e.g. `stub`, `file`, `api`).
  sourceKind    String    @default("unspecified")
  /// Auth mode metadata only (no credential values in this table).
  authMode      String    @default("none")
  /// Secret manager / vault reference, never plaintext credentials.
  authConfigRef String?
  /// Operator-facing configuration readiness state.
  authState     String    @default("not_configured")
  status        String    @default("draft")
  /// Populated when sync jobs exist; nullable for stub rows.
  lastSyncAt    DateTime?
  /// Operator-facing health / connectivity summary (no secrets).
  healthSummary String?
  /// Operator-written metadata (non-secret); capped in API layer.
  opsNote       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs     ApiHubConnectorAuditLog[]
  ingestionRuns ApiHubIngestionRun[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  /// Connector list filters + sort (Slice 58).
  @@index([tenantId, status, createdAt])
  @@index([tenantId, authMode, createdAt])
  @@index([tenantId, updatedAt])
}

model ApiHubConnectorAuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  connectorId String
  actorUserId String
  action      String
  note        String?
  createdAt   DateTime @default(now())

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connector ApiHubConnector @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  actorUser User            @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@index([connectorId, createdAt])
  @@index([actorUserId, createdAt])
}

model ApiHubIngestionRun {
  id                String    @id @default(cuid())
  tenantId          String
  connectorId       String?
  requestedByUserId String
  idempotencyKey    String?
  status            String    @default("queued")
  /// How the run was triggered (`manual` | `api` | `scheduled`); list filter in Slice 22.
  triggerKind       String    @default("api")
  attempt           Int       @default(1)
  maxAttempts       Int       @default(3)
  resultSummary     String?
  errorCode         String?
  errorMessage      String?
  enqueuedAt        DateTime  @default(now())
  startedAt         DateTime?
  finishedAt        DateTime?
  retryOfRunId      String?
  /// Set when mapping/results were applied to downstream systems (Slice 28).
  appliedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connector   ApiHubConnector?     @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  requestedBy User                 @relation(fields: [requestedByUserId], references: [id], onDelete: Restrict)
  retryOf     ApiHubIngestionRun?  @relation("ApiHubIngestionRunRetryChain", fields: [retryOfRunId], references: [id], onDelete: SetNull)
  retries     ApiHubIngestionRun[] @relation("ApiHubIngestionRunRetryChain")

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, createdAt])
  @@index([tenantId, status, createdAt])
  @@index([connectorId, createdAt])
  @@index([requestedByUserId, createdAt])
  @@index([retryOfRunId, createdAt])
  /// List + keyset pagination when filtering by connector (Slice 58).
  @@index([tenantId, connectorId, createdAt])
  /// In-flight counts and connector-scoped status filters (Slice 58).
  @@index([tenantId, connectorId, status])
  /// List runs filtered by trigger kind (Slice 58).
  @@index([tenantId, triggerKind, createdAt])
  /// Retry-tree expansion under tenant scope (Slice 58).
  @@index([tenantId, retryOfRunId])
}

/// Cached apply POST outcomes for safe client retries (Slice 42).
model ApiHubIngestionApplyIdempotency {
  id                 String   @id @default(cuid())
  tenantId           String
  idempotencyKey     String
  ingestionRunId     String
  dryRun             Boolean
  /// Stable hash of apply shape (marker vs downstream target/rows/matchKey) for safe idempotent replay.
  requestFingerprint String   @default("v1:marker")
  responseStatus     Int
  responseBody       Json
  createdAt          DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, ingestionRunId])
}

/// Append-only audit for ingestion apply / retry decisions (Slice 45). `ingestionRunId` is not a FK so history survives run deletes.
