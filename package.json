{
  "name": "po-management",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:invoice-audit": "vitest run src/lib/invoice-audit src/lib/booking-pricing-snapshot src/app/api/booking-pricing-snapshots",
    "test:tariff-rfq": "vitest run src/lib/rfq src/lib/tariff src/app/api/tariffs src/app/api/rfq",
    "test:sctwin": "vitest run src/lib/supply-chain-twin src/app/api/supply-chain-twin",
    "test:sctwin:contracts": "vitest run src/app/api/supply-chain-twin/happy-path.contract.test.ts src/app/api/supply-chain-twin/schema-conformance.contract.test.ts src/app/api/supply-chain-twin/contract-snapshot-baseline.contract.test.ts",
    "smoke:sctwin:e2e": "node scripts/sctwin-smoke-pack.mjs",
    "verify:sctwin": "npx tsc --noEmit && npm run test:sctwin",
    "check:sctwin:lint": "eslint \"src/lib/supply-chain-twin/**/*.{ts,tsx}\" \"src/app/api/supply-chain-twin/**/*.{ts,tsx}\" \"src/app/supply-chain-twin/**/*.{ts,tsx}\" \"src/components/supply-chain-twin/**/*.{ts,tsx}\"",
    "verify:sctwin:full": "npm run verify:sctwin && npm run test:sctwin:contracts && npm run check:sctwin:lint",
    "test:watch": "vitest",
    "check:invoice-audit": "eslint \"src/lib/invoice-audit/**/*.{ts,tsx}\" \"src/lib/booking-pricing-snapshot/**/*.ts\" \"src/app/invoice-audit/**/*.{ts,tsx}\" \"src/app/api/invoice-audit/**/*.{ts,tsx}\" \"src/app/api/booking-pricing-snapshots/**/*.{ts,tsx}\" \"src/components/invoice-audit/**/*.{ts,tsx}\" \"src/components/pricing-snapshots/**/*.{ts,tsx}\" \"src/app/pricing-snapshots/**/*.{ts,tsx}\" && npm run test:invoice-audit",
    "check:tariff-rfq": "eslint \"src/lib/tariff/**/*.ts\" \"src/lib/rfq/**/*.ts\" \"src/components/tariffs/**/*.{ts,tsx}\" \"src/app/tariffs/**/*.{ts,tsx}\" \"src/app/api/tariffs/**/*.{ts,tsx}\" \"src/components/rfq/**/*.{ts,tsx}\" \"src/app/rfq/**/*.{ts,tsx}\" \"src/app/api/rfq/**/*.{ts,tsx}\" && npm run test:tariff-rfq",
    "verify:tariff-engine": "npm run check:invoice-audit && npm run check:tariff-rfq && npx tsc --noEmit",
    "postinstall": "prisma generate",
    "db:migrate": "cross-env PRISMA_SCHEMA_DISABLE_ADVISORY_LOCK=1 prisma migrate deploy",
    "db:migrate:local": "bash scripts/db-migrate-local.sh",
    "db:ping": "node scripts/db-ping.mjs",
    "db:migrate:pg": "node scripts/prisma-migrate-pg.mjs",
    "db:migrate:deploy": "npm run db:migrate",
    "db:repair:supplier-migration": "node scripts/repair-failed-supplier-migration.cjs",
    "db:repair:gen-workbench": "node scripts/repair-gen-workbench-demo.mjs",
    "vercel-build": "node scripts/vercel-build.cjs",
    "db:seed": "node prisma/seed.mjs",
    "db:seed:ct-volume": "node prisma/ct-demo-shipments-volume.mjs",
    "db:seed:ct-volume:balanced": "CT_VOL_BALANCED=1 node prisma/ct-demo-shipments-volume.mjs",
    "db:seed:ct-volume:balanced:fast": "CT_VOL_BALANCED=1 CT_VOL_BATCH=80 node prisma/ct-demo-shipments-volume.mjs",
    "db:seed:ct-volume:dry-run": "node prisma/ct-demo-shipments-volume.mjs --dry-run",
    "db:seed:ct-volume:balanced:dry-run": "CT_VOL_BALANCED=1 node prisma/ct-demo-shipments-volume.mjs --dry-run",
    "db:seed:crm-demo": "node prisma/crm-demo-seed.mjs",
    "db:seed:wms-demo": "node prisma/wms-demo-seed.mjs",
    "db:seed:demo-full": "node scripts/seed-demo-full.mjs",
    "db:seed:product-trace-demo": "node prisma/product-trace-demo-repair.mjs",
    "db:seed:invoice-audit-demo": "node prisma/seed-invoice-audit-demo.mjs",
    "db:seed:tariff-fra-chi-demo": "node prisma/seed-tariff-fra-chi-demo.mjs",
    "db:seed:tariff-deham-uschi-investor-demo": "node prisma/seed-tariff-deham-uschi-investor-demo.mjs",
    "db:seed:supply-chain-twin-demo": "node prisma/seed-supply-chain-twin-demo.mjs",
    "db:seed:supply-chain-twin-large-fixture": "node prisma/seed-supply-chain-twin-large-tenant-fixture.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@vercel/blob": "^2.3.3",
    "leaflet": "^1.9.4",
    "next": "16.2.2",
    "pdf-lib": "^1.17.1",
    "pg": "^8.16.3",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
