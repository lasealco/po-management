# BF-17 — Bearer secret for POST /api/wms/tms-webhook (no app-session cookie; external TMS / middleware calls only).
# Generate a long random string for production. Leave unset locally unless testing the stub.
TMS_WEBHOOK_SECRET=

# BF-25 — optional separate secret for HMAC-SHA256 over the raw JSON body.
# When set, callers MUST send: X-TMS-Signature: sha256=<64 lowercase hex chars>
# where hex = HMAC_SHA256(secret, rawBodyUtf8).
TMS_WEBHOOK_HMAC_SECRET=

# BF-74 — Bearer secret for POST /api/wms/yard-geofence-webhook (telematics / geofence arrival pings).
# Distinct from TMS_WEBHOOK_SECRET so carriers vs yard vendors can rotate independently.
WMS_YARD_GEOFENCE_WEBHOOK_SECRET=

# BF-74 — optional HMAC-SHA256 over the raw JSON body (same hex format as TMS_WEBHOOK_HMAC_SECRET).
# When set, callers MUST send: X-Yard-Geofence-Signature: sha256=<64 lowercase hex chars>
WMS_YARD_GEOFENCE_WEBHOOK_HMAC_SECRET=
